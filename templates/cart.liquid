{%- layout 'theme' -%}

{%- comment -%}
  Base Note — Subscription Cart Page
  Every purchase = subscription enrollment. Cart displays plan selector,
  subscription disclosure, and FTC-compliant terms checkbox.
{%- endcomment -%}

{%- assign monthly_price = settings.sub_plan_monthly_price | default: '$20' -%}
{%- assign monthly_per_mo = settings.sub_plan_monthly_per_month | default: '$20/mo' -%}
{%- assign quarterly_price = settings.sub_plan_quarterly_price | default: '$48' -%}
{%- assign quarterly_per_mo = settings.sub_plan_quarterly_per_month | default: '$16/mo' -%}
{%- assign annual_price = settings.sub_plan_annual_price | default: '$168' -%}
{%- assign annual_per_mo = settings.sub_plan_annual_per_month | default: '$14/mo' -%}

<section class="cart-section">
  <div class="container">

    {%- if cart.item_count > 0 -%}

      {%- comment -%} Detect if cart has subscription items {%- endcomment -%}
      {%- assign has_subscription = false -%}
      {%- for item in cart.items -%}
        {%- if item.selling_plan_allocation -%}
          {%- assign has_subscription = true -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      <div class="cart-header">
        <h1 class="cart-header__title">Your Subscription</h1>
        <p class="cart-header__subtitle">Review your next fragrance before checkout</p>
      </div>

      <form action="{{ routes.cart_url }}" method="post" class="cart-form">
        <div class="cart-layout">

          {%- comment -%} === LEFT COLUMN: Cart Items + Plan Selector + Perks === {%- endcomment -%}
          <div class="cart-main">

            {%- comment -%} Cart Items — "Your Next Fragrance" {%- endcomment -%}
            <div class="cart-items">
              <div class="cart-items__header">
                <h2 class="cart-items__section-title">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                  Your Next Fragrance
                </h2>
                <p class="cart-items__section-subtitle">This fragrance ships with your next subscription order</p>
              </div>
              {%- for item in cart.items -%}
                <div class="cart-item" data-item-key="{{ item.key }}">
                  <div class="cart-item__image">
                    {%- if item.image -%}
                      <a href="{{ item.url }}">
                        <img src="{{ item.image | image_url: width: 300 }}" alt="{{ item.title }}" loading="lazy">
                      </a>
                    {%- else -%}
                      <div class="cart-item__placeholder">
                        <svg viewBox="0 0 80 120" fill="none" stroke="currentColor" stroke-width="1.5">
                          <rect x="20" y="30" width="40" height="80" rx="4"/>
                          <rect x="30" y="10" width="20" height="20"/>
                          <rect x="35" y="0" width="10" height="10" rx="2"/>
                        </svg>
                      </div>
                    {%- endif -%}
                  </div>

                  <div class="cart-item__details">
                    <div class="cart-item__meta">
                      {%- if item.selling_plan_allocation -%}
                        <span class="cart-item__badge">THIS MONTH'S SELECTION</span>
                      {%- endif -%}
                      <h3 class="cart-item__title">
                        <a href="{{ item.url }}">{{ item.product.title }}</a>
                      </h3>
                      {%- if item.variant.title != 'Default Title' -%}
                        <p class="cart-item__variant">{{ item.variant.title }}</p>
                      {%- endif -%}
                      <p class="cart-item__size">5ml Atomizer (~30 sprays)</p>

                      {%- if item.selling_plan_allocation -%}
                        <p class="cart-item__selling-plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}

                      {%- if item.product.metafields.custom.scent_notes -%}
                        <p class="cart-item__notes">
                          <span class="cart-item__notes-label">Notes:</span>
                          {{ item.product.metafields.custom.scent_notes }}
                        </p>
                      {%- endif -%}

                      {%- if item.product.price > 0 -%}
                        <p class="cart-item__retail-value">
                          {{ item.product.price | money }} retail value
                        </p>
                      {%- endif -%}
                    </div>

                    <div class="cart-item__actions">
                      {%- if item.selling_plan_allocation -%}
                        <a href="/collections/all" class="cart-item__swap">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                            <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                          </svg>
                          Swap Fragrance
                        </a>
                      {%- endif -%}
                      <button type="button" class="cart-item__remove" data-remove-item="{{ item.key }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                          <polyline points="3 6 5 6 21 6"/>
                          <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        </svg>
                        Remove
                      </button>
                    </div>
                  </div>
                </div>
              {%- endfor -%}

              <div class="cart-items__footer">
                <a href="/collections/all" class="cart-continue">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                    <line x1="19" y1="12" x2="5" y2="12"/>
                    <polyline points="12 19 5 12 12 5"/>
                  </svg>
                  Continue Browsing
                </a>
              </div>
            </div>

            {%- comment -%} Rotation List — fragrances queued for future months {%- endcomment -%}
            <div class="rotation-list" id="rotationList" style="display:none;">
              <div class="rotation-list__header">
                <h3 class="rotation-list__title">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                  </svg>
                  My Rotation — Upcoming Months
                </h3>
                <p class="rotation-list__subtitle">These fragrances will be auto-selected for your future shipments</p>
              </div>
              <div class="rotation-list__items" id="rotationListItems">
                <!-- Populated by JavaScript from localStorage -->
              </div>
            </div>

            {%- comment -%} Plan Selector {%- endcomment -%}
            <div class="plan-selector">
              <h3 class="plan-selector__heading">Select Your Plan</h3>
              <div class="plan-selector__options">

                <label class="plan-option is-selected" data-plan="monthly">
                  <input type="radio" name="subscription_plan" value="monthly" checked>
                  <span class="plan-option__name">Monthly</span>
                  <span class="plan-option__price">{{ monthly_per_mo }}</span>
                  <span class="plan-option__detail">Billed monthly</span>
                </label>

                <label class="plan-option" data-plan="quarterly">
                  <span class="plan-option__badge">SAVE 20%</span>
                  <input type="radio" name="subscription_plan" value="quarterly">
                  <span class="plan-option__name">Quarterly</span>
                  <span class="plan-option__price">{{ quarterly_per_mo }}</span>
                  <span class="plan-option__detail">{{ quarterly_price }} billed every 3 months</span>
                </label>

                <label class="plan-option" data-plan="annual">
                  <span class="plan-option__badge plan-option__badge--gold">BEST VALUE</span>
                  <input type="radio" name="subscription_plan" value="annual">
                  <span class="plan-option__name">Annual</span>
                  <span class="plan-option__price">{{ annual_per_mo }}</span>
                  <span class="plan-option__detail">{{ annual_price }} billed annually — 2 months free</span>
                </label>

              </div>
            </div>

            {%- comment -%} Perks {%- endcomment -%}
            <div class="cart-perks">
              <h3 class="cart-perks__heading">What's Included</h3>
              <div class="cart-perks__grid">
                <div class="cart-perk">
                  <div class="cart-perk__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                      <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                    </svg>
                  </div>
                  <div>
                    <strong>Free shipping, always</strong>
                    <p>Every order ships free to the US & Canada</p>
                  </div>
                </div>
                <div class="cart-perk">
                  <div class="cart-perk__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                      <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
                    </svg>
                  </div>
                  <div>
                    <strong>Swap, skip, or cancel anytime</strong>
                    <p>Full flexibility from your account dashboard</p>
                  </div>
                </div>
                <div class="cart-perk">
                  <div class="cart-perk__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                  </div>
                  <div>
                    <strong>Free travel case</strong>
                    <p>Included with quarterly & annual plans</p>
                  </div>
                </div>
                <div class="cart-perk">
                  <div class="cart-perk__icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                  </div>
                  <div>
                    <strong>30-day satisfaction guarantee</strong>
                    <p>Not happy? We'll make it right</p>
                  </div>
                </div>
              </div>
            </div>

          </div>

          {%- comment -%} === RIGHT COLUMN: Order Summary === {%- endcomment -%}
          <div class="cart-sidebar">
            <div class="cart-summary__card">
              <h2 class="cart-summary__title">Order Summary</h2>

              {%- comment -%} Order lines {%- endcomment -%}
              {%- for item in cart.items -%}
                <div class="cart-summary__row">
                  <span>{{ item.product.title }} (5ml)</span>
                  <span class="text-gold">Included</span>
                </div>
              {%- endfor -%}

              <div class="cart-summary__row">
                <span data-summary-plan-label>Monthly Plan</span>
                <span data-summary-plan-price>{{ monthly_price }}</span>
              </div>

              <div class="cart-summary__row cart-summary__row--light">
                <span>Shipping</span>
                <span class="text-success">FREE</span>
              </div>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="cart-summary__row cart-summary__row--discount">
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}

              <div class="cart-summary__divider"></div>

              <div class="cart-summary__row cart-summary__row--total">
                <span>Due Today</span>
                <span data-summary-total>{{ monthly_price }}</span>
              </div>

              <p class="cart-summary__renewal" data-summary-renewal>
                Then {{ monthly_price }}/month. Cancel anytime.
              </p>

              {%- comment -%} Promo Code {%- endcomment -%}
              <div class="cart-promo">
                <button type="button" class="cart-promo__toggle" data-promo-toggle>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>
                  </svg>
                  Have a promo code?
                  <svg class="cart-promo__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </button>
                <div class="cart-promo__form" style="display:none;">
                  <input type="text" id="promoCodeInput" class="cart-promo__input" placeholder="Enter code">
                  <button type="button" class="btn btn--small" id="applyPromoBtn">Apply</button>
                </div>
                <div class="cart-promo__message" id="promoMessage" style="display:none;"></div>
              </div>

              {%- comment -%} Subscription Disclosure (FTC Compliant) {%- endcomment -%}
              <div class="cart-disclosure">
                <div class="cart-disclosure__icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="cart-disclosure__content">
                  <h4 class="cart-disclosure__heading">Subscription Terms</h4>
                  <p class="cart-disclosure__text" data-disclosure-text>
                    {{ settings.sub_disclosure_text | default: 'By proceeding, you agree to a recurring subscription. Your subscription will auto-renew until cancelled. You can cancel, skip, or swap anytime from your account dashboard.' }}
                  </p>
                  {%- if settings.sub_disclosure_checkbox_required != false -%}
                    <label class="cart-disclosure__checkbox">
                      <input type="checkbox" id="termsCheckbox" required>
                      <span>I understand this is a recurring subscription and agree to the <a href="/pages/terms" target="_blank">Terms of Service</a> and <a href="/pages/privacy" target="_blank">Privacy Policy</a>.</span>
                    </label>
                  {%- endif -%}
                </div>
              </div>

              {%- comment -%} Checkout Button {%- endcomment -%}
              <button
                type="submit"
                name="checkout"
                id="checkoutBtn"
                class="btn btn--primary btn--full btn--large cart-checkout-btn"
                {% if settings.sub_disclosure_checkbox_required != false %}disabled{% endif %}
              >
                PROCEED TO CHECKOUT
              </button>

              {%- comment -%} Trust Badges {%- endcomment -%}
              <div class="cart-trust">
                <div class="cart-trust__item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  <span>Secure Checkout</span>
                </div>
                <div class="cart-trust__item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  <span>Satisfaction Guarantee</span>
                </div>
                <div class="cart-trust__item">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                    <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                  <span>Free Shipping</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </form>

    {%- else -%}

      {%- comment -%} Empty Cart {%- endcomment -%}
      <div class="cart-empty">
        <div class="cart-empty__icon">
          <svg viewBox="0 0 80 120" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="20" y="30" width="40" height="80" rx="4"/>
            <rect x="30" y="10" width="20" height="20"/>
            <rect x="35" y="0" width="10" height="10" rx="2"/>
            <text x="40" y="78" text-anchor="middle" font-size="12" fill="currentColor" stroke="none">?</text>
          </svg>
        </div>
        <h2 class="cart-empty__title">Your Queue is Empty</h2>
        <p class="cart-empty__text">Start your fragrance journey with Base Note. Discover luxury scents curated just for you.</p>
        <div class="cart-empty__actions">
          <a href="/collections/all" class="btn btn--primary btn--large">Browse Fragrances</a>
          <a href="/pages/quiz" class="btn btn--outline btn--large">Take the Scent Quiz</a>
        </div>

        <div class="cart-empty__featured">
          <h3>Popular This Month</h3>
          <div class="cart-empty__products">
            {%- for product in collections['all'].products limit: 3 -%}
              <a href="{{ product.url }}" class="featured-product-mini">
                <div class="featured-product-mini__image">
                  {%- if product.featured_image -%}
                    <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title }}" loading="lazy">
                  {%- endif -%}
                </div>
                <h4 class="featured-product-mini__title">{{ product.title }}</h4>
                <span class="featured-product-mini__price">{{ product.price | money }}</span>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>

    {%- endif -%}
  </div>
</section>

<style>
  .cart-section {
    padding: calc(var(--header-height, 110px) + 3rem) 0 4rem;
    min-height: 100vh;
    background: var(--color-background, #FAF8F5);
  }

  /* Header */
  .cart-header { text-align: center; margin-bottom: 2.5rem; }
  .cart-header__title { font-size: 2.5rem; font-family: var(--font-heading, 'Cormorant Garamond', serif); margin: 0 0 0.25rem; color: var(--color-primary, #2D4641); }
  .cart-header__subtitle { color: #666; font-size: 1rem; margin: 0; }

  /* Layout */
  .cart-layout { display: grid; grid-template-columns: 1fr 420px; gap: 2.5rem; align-items: start; }
  .cart-main { display: flex; flex-direction: column; gap: 1.5rem; }

  /* Cart Items */
  .cart-items { background: #fff; border: 1px solid var(--color-border, #E8E6E3); border-radius: 10px; overflow: hidden; }
  .cart-item { display: grid; grid-template-columns: 120px 1fr; gap: 1.25rem; padding: 1.5rem; border-bottom: 1px solid var(--color-border, #E8E6E3); }
  .cart-item:last-of-type { border-bottom: none; }
  .cart-item__image { aspect-ratio: 3/4; background: #f5f5f5; border-radius: 8px; overflow: hidden; }
  .cart-item__image img { width: 100%; height: 100%; object-fit: cover; }
  .cart-item__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #ccc; }
  .cart-item__placeholder svg { width: 50%; height: auto; }
  .cart-item__details { display: flex; flex-direction: column; justify-content: space-between; }
  .cart-item__badge {
    display: inline-block; padding: 3px 10px; background: var(--color-primary, #2D4641); color: #fff;
    font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; border-radius: 999px; margin-bottom: 0.5rem;
  }
  .cart-item__title { font-size: 1.25rem; font-family: var(--font-heading, 'Cormorant Garamond', serif); margin: 0 0 0.25rem; }
  .cart-item__title a { color: inherit; text-decoration: none; }
  .cart-item__variant, .cart-item__size { font-size: 0.85rem; color: #666; margin: 0.125rem 0; }
  .cart-item__selling-plan { font-size: 0.8rem; color: var(--color-secondary, #C9A962); font-weight: 600; margin: 0.25rem 0; }
  .cart-item__notes { font-size: 0.8rem; color: #999; margin: 0.25rem 0; }
  .cart-item__notes-label { font-weight: 600; color: #666; }
  .cart-item__retail-value { font-size: 0.8rem; color: #999; font-style: italic; margin: 0.25rem 0; }
  .cart-item__actions { margin-top: 0.75rem; }
  .cart-item__remove { display: inline-flex; align-items: center; gap: 0.25rem; background: none; border: none; font-size: 0.85rem; color: #999; cursor: pointer; padding: 0.25rem 0; transition: color 0.2s; }
  .cart-item__remove:hover { color: #c0392b; }
  .cart-items__footer { padding: 1rem 1.5rem; background: #fafafa; border-top: 1px solid var(--color-border, #E8E6E3); }
  .cart-continue { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.875rem; color: #666; text-decoration: none; transition: color 0.2s; }
  .cart-continue:hover { color: var(--color-secondary, #C9A962); }

  /* Plan Selector */
  .plan-selector { background: #fff; border: 1px solid var(--color-border, #E8E6E3); border-radius: 10px; padding: 1.5rem; }
  .plan-selector__heading { font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1.25rem; color: var(--color-primary, #2D4641); }
  .plan-selector__options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
  .plan-option {
    position: relative; display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: 1.5rem 1rem; border: 2px solid var(--color-border, #E8E6E3); border-radius: 10px;
    cursor: pointer; transition: all 0.2s; background: #fff;
  }
  .plan-option input[type="radio"] { position: absolute; opacity: 0; pointer-events: none; }
  .plan-option.is-selected {
    border-color: var(--color-secondary, #C9A962);
    background: linear-gradient(135deg, rgba(201,169,98,0.08) 0%, rgba(201,169,98,0.02) 100%);
    box-shadow: 0 0 0 1px var(--color-secondary, #C9A962);
  }
  .plan-option:hover { border-color: var(--color-secondary, #C9A962); }
  .plan-option__badge {
    position: absolute; top: -10px; left: 50%; transform: translateX(-50%);
    background: var(--color-secondary, #C9A962); color: #fff; padding: 2px 12px;
    font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
    border-radius: 999px; white-space: nowrap;
  }
  .plan-option__badge--gold { background: #d4af37; }
  .plan-option__name { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary, #2D4641); margin-bottom: 0.5rem; }
  .plan-option__price { font-size: 1.5rem; font-weight: 700; color: var(--color-primary, #2D4641); margin-bottom: 0.25rem; font-family: var(--font-heading, 'Cormorant Garamond', serif); }
  .plan-option__detail { font-size: 0.75rem; color: #999; }

  /* Perks */
  .cart-perks { background: #fff; border: 1px solid var(--color-border, #E8E6E3); border-radius: 10px; padding: 1.5rem; }
  .cart-perks__heading { font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1.25rem; color: var(--color-primary, #2D4641); }
  .cart-perks__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .cart-perk { display: flex; gap: 1rem; align-items: flex-start; }
  .cart-perk__icon { flex-shrink: 0; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: rgba(201,169,98,0.1); border-radius: 10px; color: var(--color-secondary, #C9A962); }
  .cart-perk strong { display: block; font-size: 0.875rem; color: var(--color-primary, #2D4641); margin-bottom: 0.125rem; }
  .cart-perk p { font-size: 0.8rem; color: #999; margin: 0; }

  /* Sidebar */
  .cart-sidebar { position: sticky; top: calc(var(--header-height, 110px) + 1rem); }
  .cart-summary__card { background: #fff; border: 1px solid var(--color-border, #E8E6E3); border-radius: 10px; padding: 1.5rem; }
  .cart-summary__title { font-size: 1.25rem; margin: 0 0 1.25rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--color-border, #E8E6E3); color: var(--color-primary, #2D4641); }
  .cart-summary__row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.625rem; font-size: 0.9rem; }
  .cart-summary__row--light { color: #999; font-size: 0.85rem; }
  .cart-summary__row--discount { color: #27ae60; }
  .cart-summary__row--total { font-size: 1.25rem; font-weight: 700; margin-top: 0.75rem; }
  .cart-summary__divider { height: 1px; background: var(--color-border, #E8E6E3); margin: 0.75rem 0; }
  .cart-summary__renewal { font-size: 0.8rem; color: #999; margin: 0.5rem 0 1.25rem; }
  .text-gold { color: var(--color-secondary, #C9A962); font-weight: 600; }
  .text-success { color: #27ae60; font-weight: 600; }

  /* Promo Code */
  .cart-promo { margin-bottom: 1.25rem; }
  .cart-promo__toggle { display: flex; align-items: center; gap: 0.5rem; width: 100%; background: none; border: none; font-size: 0.85rem; color: #666; cursor: pointer; padding: 0.5rem 0; }
  .cart-promo__toggle svg { flex-shrink: 0; }
  .cart-promo__chevron { margin-left: auto; transition: transform 0.2s; }
  .cart-promo__toggle.is-active .cart-promo__chevron { transform: rotate(180deg); }
  .cart-promo__form { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
  .cart-promo__input { flex: 1; padding: 0.5rem 0.75rem; border: 1px solid var(--color-border, #E8E6E3); border-radius: 6px; font-size: 0.85rem; }
  .cart-promo__message { margin-top: 0.5rem; padding: 0.5rem 0.75rem; border-radius: 6px; font-size: 0.8rem; }
  .cart-promo__message--success { background: rgba(39,174,96,0.1); color: #27ae60; border: 1px solid #27ae60; }
  .cart-promo__message--error { background: rgba(192,57,43,0.1); color: #c0392b; border: 1px solid #c0392b; }
  .cart-promo__message--info { background: rgba(201,169,98,0.1); color: var(--color-secondary, #C9A962); border: 1px solid var(--color-secondary, #C9A962); }

  /* Subscription Disclosure */
  .cart-disclosure {
    display: flex; gap: 0.75rem; padding: 1rem; margin-bottom: 1.25rem;
    background: rgba(243,156,18,0.08); border: 1px solid rgba(243,156,18,0.3);
    border-radius: 8px;
  }
  .cart-disclosure__icon { flex-shrink: 0; color: #f39c12; margin-top: 2px; }
  .cart-disclosure__heading { font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-primary, #2D4641); margin: 0 0 0.375rem; }
  .cart-disclosure__text { font-size: 0.8rem; color: #666; margin: 0 0 0.75rem; line-height: 1.5; }
  .cart-disclosure__checkbox { display: flex; gap: 0.5rem; align-items: flex-start; font-size: 0.8rem; color: var(--color-primary, #2D4641); cursor: pointer; line-height: 1.4; }
  .cart-disclosure__checkbox input { margin-top: 3px; accent-color: var(--color-secondary, #C9A962); flex-shrink: 0; }
  .cart-disclosure__checkbox a { color: var(--color-secondary, #C9A962); }

  /* Checkout Button */
  .cart-checkout-btn { font-size: 1rem; padding: 1rem; letter-spacing: 0.1em; text-transform: uppercase; transition: all 0.2s; }
  .cart-checkout-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  /* Trust */
  .cart-trust { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid var(--color-border, #E8E6E3); }
  .cart-trust__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.25rem; color: #999; }
  .cart-trust__item svg { color: var(--color-secondary, #C9A962); }
  .cart-trust__item span { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; }

  /* Empty Cart */
  .cart-empty { text-align: center; padding: 4rem 1rem; max-width: 600px; margin: 0 auto; padding-top: calc(var(--header-height, 110px) + 4rem); }
  .cart-empty__icon { width: 120px; height: 150px; margin: 0 auto 2rem; color: #ccc; opacity: 0.5; }
  .cart-empty__icon svg { width: 100%; height: 100%; }
  .cart-empty__title { font-size: 2rem; font-family: var(--font-heading, 'Cormorant Garamond', serif); margin-bottom: 0.75rem; }
  .cart-empty__text { color: #666; font-size: 1.05rem; margin-bottom: 2rem; }
  .cart-empty__actions { display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 4rem; }
  .cart-empty__featured { margin-top: 4rem; padding-top: 2.5rem; border-top: 1px solid var(--color-border, #E8E6E3); }
  .cart-empty__featured h3 { font-size: 1.25rem; margin-bottom: 1.5rem; }
  .cart-empty__products { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .featured-product-mini { text-decoration: none; color: inherit; }
  .featured-product-mini__image { aspect-ratio: 1; background: #f5f5f5; border-radius: 10px; margin-bottom: 0.75rem; overflow: hidden; }
  .featured-product-mini__image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
  .featured-product-mini:hover .featured-product-mini__image img { transform: scale(1.05); }
  .featured-product-mini__title { font-size: 0.85rem; margin-bottom: 0.25rem; }
  .featured-product-mini__price { font-weight: 600; color: var(--color-secondary, #C9A962); }

  /* Cart Items Header */
  .cart-items__header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--color-border, #E8E6E3); }
  .cart-items__section-title { display: flex; align-items: center; gap: 0.5rem; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.25rem; color: var(--color-primary, #2D4641); }
  .cart-items__section-title svg { color: var(--color-secondary, #C9A962); }
  .cart-items__section-subtitle { font-size: 0.8rem; color: #999; margin: 0; }

  /* Swap Link */
  .cart-item__swap { display: inline-flex; align-items: center; gap: 0.25rem; font-size: 0.85rem; color: var(--color-secondary, #C9A962); text-decoration: none; font-weight: 600; transition: opacity 0.2s; margin-right: 1rem; }
  .cart-item__swap:hover { opacity: 0.7; }

  /* Rotation List */
  .rotation-list { background: #fff; border: 1px solid var(--color-border, #E8E6E3); border-radius: 10px; overflow: hidden; }
  .rotation-list__header { padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--color-border, #E8E6E3); }
  .rotation-list__title { display: flex; align-items: center; gap: 0.5rem; font-size: 1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 0.25rem; color: var(--color-primary, #2D4641); }
  .rotation-list__title svg { color: var(--color-secondary, #C9A962); }
  .rotation-list__subtitle { font-size: 0.8rem; color: #999; margin: 0; }
  .rotation-list__items { padding: 0; }
  .rotation-item { display: grid; grid-template-columns: 80px 1fr auto; gap: 1rem; padding: 1rem 1.5rem; border-bottom: 1px solid var(--color-border, #E8E6E3); align-items: center; }
  .rotation-item:last-child { border-bottom: none; }
  .rotation-item__image { width: 80px; height: 80px; border-radius: 8px; overflow: hidden; background: #f5f5f5; }
  .rotation-item__image img { width: 100%; height: 100%; object-fit: cover; }
  .rotation-item__info h4 { font-size: 1rem; font-family: var(--font-heading, 'Cormorant Garamond', serif); margin: 0 0 0.25rem; }
  .rotation-item__info p { font-size: 0.8rem; color: #999; margin: 0; }
  .rotation-item__month { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-secondary, #C9A962); background: rgba(201,169,98,0.1); padding: 4px 10px; border-radius: 999px; }
  .rotation-item__remove { background: none; border: none; color: #999; cursor: pointer; padding: 0.25rem; transition: color 0.2s; }
  .rotation-item__remove:hover { color: #c0392b; }
  .rotation-list__empty { padding: 2rem 1.5rem; text-align: center; color: #999; font-size: 0.9rem; }

  /* Responsive */
  @media (max-width: 992px) {
    .cart-layout { grid-template-columns: 1fr; }
    .cart-sidebar { position: static; }
    .plan-selector__options { grid-template-columns: 1fr; }
    .cart-perks__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .cart-item { grid-template-columns: 100px 1fr; padding: 1.25rem; }
    .cart-header__title { font-size: 2rem; }
    .cart-trust { grid-template-columns: 1fr; gap: 0.5rem; }
    .cart-trust__item { flex-direction: row; justify-content: center; }
    .cart-empty__actions { flex-direction: column; }
    .cart-empty__products { grid-template-columns: 1fr; max-width: 250px; margin: 0 auto; }
  }
  @media (max-width: 576px) {
    .cart-item { grid-template-columns: 80px 1fr; padding: 1rem; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  'use strict';

  // Plan pricing data
  var plans = {
    monthly:   { label: 'Monthly Plan',   perMo: '{{ monthly_per_mo }}',   total: '{{ monthly_price }}',   renewal: 'Then {{ monthly_price }}/month. Cancel anytime.', detail: 'monthly' },
    quarterly: { label: 'Quarterly Plan',  perMo: '{{ quarterly_per_mo }}', total: '{{ quarterly_price }}', renewal: 'Then {{ quarterly_price }} every 3 months. Cancel anytime.', detail: 'every 3 months' },
    annual:    { label: 'Annual Plan',     perMo: '{{ annual_per_mo }}',    total: '{{ annual_price }}',    renewal: 'Then {{ annual_price }}/year. Cancel anytime.', detail: 'annually' }
  };

  // Plan selector
  var planOptions = document.querySelectorAll('.plan-option');
  var planRadios = document.querySelectorAll('[name="subscription_plan"]');

  planRadios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      var plan = plans[radio.value];
      if (!plan) return;

      // Update visual selection
      planOptions.forEach(function(opt) { opt.classList.remove('is-selected'); });
      radio.closest('.plan-option').classList.add('is-selected');

      // Update summary
      var planLabel = document.querySelector('[data-summary-plan-label]');
      var planPrice = document.querySelector('[data-summary-plan-price]');
      var totalEl = document.querySelector('[data-summary-total]');
      var renewalEl = document.querySelector('[data-summary-renewal]');

      if (planLabel) planLabel.textContent = plan.label;
      if (planPrice) planPrice.textContent = plan.total;
      if (totalEl) totalEl.textContent = plan.total;
      if (renewalEl) renewalEl.textContent = plan.renewal;

      // Store for thank-you page
      localStorage.setItem('basenote_selected_plan', radio.value);
    });
  });

  // Terms checkbox gates checkout
  var termsCheckbox = document.getElementById('termsCheckbox');
  var checkoutBtn = document.getElementById('checkoutBtn');

  if (termsCheckbox && checkoutBtn) {
    termsCheckbox.addEventListener('change', function() {
      checkoutBtn.disabled = !termsCheckbox.checked;
    });
  }

  // Remove item
  document.querySelectorAll('[data-remove-item]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var key = this.dataset.removeItem;
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      }).then(function() { window.location.reload(); });
    });
  });

  // Rotation List
  (function() {
    var QUEUE_KEY = 'basenotes_queue';
    var rotationList = document.getElementById('rotationList');
    var rotationItems = document.getElementById('rotationListItems');
    if (!rotationList || !rotationItems) return;

    function getQueue() {
      try { return JSON.parse(localStorage.getItem(QUEUE_KEY)) || []; }
      catch(e) { return []; }
    }

    function saveQueue(queue) {
      localStorage.setItem(QUEUE_KEY, JSON.stringify(queue));
    }

    function renderRotation() {
      var queue = getQueue();
      if (queue.length === 0) {
        rotationList.style.display = 'none';
        return;
      }

      rotationList.style.display = '';
      var months = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];
      var now = new Date();

      var html = '';
      queue.forEach(function(item, index) {
        var futureMonth = new Date(now.getFullYear(), now.getMonth() + index + 1, 1);
        var monthLabel = months[futureMonth.getMonth()] + ' ' + futureMonth.getFullYear();

        html += '<div class="rotation-item" data-rotation-index="' + index + '">' +
          '<div class="rotation-item__image">' +
            (item.image ? '<img src="' + item.image + '" alt="' + item.title + '" loading="lazy">' : '') +
          '</div>' +
          '<div class="rotation-item__info">' +
            '<h4><a href="' + item.url + '" style="color:inherit;text-decoration:none;">' + item.title + '</a></h4>' +
            '<span class="rotation-item__month">' + monthLabel + '</span>' +
          '</div>' +
          '<button type="button" class="rotation-item__remove" data-remove-rotation="' + index + '" aria-label="Remove from rotation">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
          '</button>' +
        '</div>';
      });

      rotationItems.innerHTML = html;

      // Bind remove buttons
      rotationItems.querySelectorAll('[data-remove-rotation]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var idx = parseInt(this.dataset.removeRotation);
          var q = getQueue();
          q.splice(idx, 1);
          saveQueue(q);
          renderRotation();
        });
      });
    }

    renderRotation();
  })();

  // Promo code toggle
  var promoToggle = document.querySelector('[data-promo-toggle]');
  if (promoToggle) {
    promoToggle.addEventListener('click', function() {
      this.classList.toggle('is-active');
      var form = this.nextElementSibling;
      form.style.display = form.style.display === 'none' ? 'flex' : 'none';
    });
  }

  // Promo code apply
  var promoInput = document.getElementById('promoCodeInput');
  var applyBtn = document.getElementById('applyPromoBtn');
  var promoMsg = document.getElementById('promoMessage');

  if (applyBtn && promoInput) {
    applyBtn.addEventListener('click', applyPromo);
    promoInput.addEventListener('keypress', function(e) {
      if (e.key === 'Enter') { e.preventDefault(); applyPromo(); }
    });

    // Restore stored code
    var stored = localStorage.getItem('basenote_discount_code');
    if (stored) {
      promoInput.value = stored;
      showPromo('Code "' + stored + '" will be applied at checkout', 'info');
      addDiscountInput(stored);
      if (promoToggle) { promoToggle.classList.add('is-active'); promoToggle.nextElementSibling.style.display = 'flex'; }
    }
  }

  function applyPromo() {
    var code = promoInput.value.trim().toUpperCase();
    if (!code) { showPromo('Please enter a promo code', 'error'); return; }
    localStorage.setItem('basenote_discount_code', code);
    showPromo('Code "' + code + '" will be applied at checkout!', 'success');
    addDiscountInput(code);
  }

  function showPromo(msg, type) {
    if (promoMsg) { promoMsg.textContent = msg; promoMsg.className = 'cart-promo__message cart-promo__message--' + type; promoMsg.style.display = 'block'; }
  }

  function addDiscountInput(code) {
    var form = document.querySelector('.cart-form');
    if (!form) return;
    var input = form.querySelector('input[name="discount"]');
    if (!input) { input = document.createElement('input'); input.type = 'hidden'; input.name = 'discount'; form.appendChild(input); }
    input.value = code;
  }
});
</script>
