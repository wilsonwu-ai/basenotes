{%- layout 'theme' -%}

{%- assign is_subscriber = false -%}
{%- if customer.tags contains 'subscriber' or customer.tags contains 'active_subscriber' -%}
  {%- assign is_subscriber = true -%}
{%- endif -%}

{%- assign member_since = customer.created_at | date: '%s' -%}
{%- assign now_ts = 'now' | date: '%s' -%}
{%- assign diff_seconds = now_ts | minus: member_since -%}
{%- assign months_active = diff_seconds | divided_by: 2592000 -%}
{%- if months_active < 1 -%}{%- assign months_active = 1 -%}{%- endif -%}

<section class="acct">
  <div class="container">
    <div class="acct__layout">

      <!-- ═══ Sidebar ═══ -->
      <aside class="acct__sidebar">
        <div class="acct__user">
          <div class="acct__avatar">{{ customer.first_name | slice: 0 }}{{ customer.last_name | slice: 0 }}</div>
          <div>
            <p class="acct__user-greeting">Welcome back,</p>
            <p class="acct__user-name">{{ customer.first_name }} {{ customer.last_name }}</p>
            <p class="acct__user-email">{{ customer.email }}</p>
          </div>
        </div>

        <nav class="acct__nav">
          <a href="#dashboard" class="acct__nav-link is-active" data-nav="dashboard">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="#history" class="acct__nav-link" data-nav="history">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Fragrance History
          </a>
          <a href="#next-shipment" class="acct__nav-link" data-nav="next-shipment">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            Next Shipment
          </a>
          <a href="#subscription" class="acct__nav-link" data-nav="subscription">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            My Subscription
          </a>
          <a href="#orders" class="acct__nav-link" data-nav="orders">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Order History
          </a>
          <a href="{{ routes.account_addresses_url }}" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Addresses
          </a>
        </nav>

        <div class="acct__sidebar-footer">
          <a href="{{ routes.account_logout_url }}" class="acct__logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Sign Out
          </a>
        </div>
      </aside>

      <!-- ═══ Main Content ═══ -->
      <main class="acct__main">

        <!-- ────── Dashboard ────── -->
        <div data-view="dashboard" class="acct__view">

          <!-- Welcome Banner -->
          <div class="acct__welcome-banner">
            <div class="acct__welcome-content">
              <p class="acct__welcome-eyebrow">
                {%- if is_subscriber -%}Active Member{%- else -%}Welcome{%- endif -%}
              </p>
              <h2 class="acct__welcome-title">Welcome back, {{ customer.first_name }}!</h2>
              <p class="acct__welcome-meta">Member since {{ customer.created_at | date: '%B %Y' }}</p>
            </div>
            {%- if is_subscriber -%}
              <span class="acct__status-badge acct__status-badge--active">Active</span>
            {%- endif -%}
          </div>

          <!-- Quick Stats -->
          <div class="acct__stats">
            <div class="acct__stat">
              <span class="acct__stat-num" id="statFragrances">{{ customer.orders_count }}</span>
              <span class="acct__stat-label">Fragrances Discovered</span>
            </div>
            <div class="acct__stat">
              <span class="acct__stat-num">
                {%- if is_subscriber -%}Monthly{%- else -%}—{%- endif -%}
              </span>
              <span class="acct__stat-label">Current Plan</span>
            </div>
            <div class="acct__stat">
              <span class="acct__stat-num" id="statNextShipment">—</span>
              <span class="acct__stat-label">Next Shipment</span>
            </div>
            <div class="acct__stat">
              <span class="acct__stat-num">{{ months_active }}</span>
              <span class="acct__stat-label">Months Active</span>
            </div>
          </div>

          <!-- Upcoming Shipment (condensed) -->
          {%- if is_subscriber -%}
          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Upcoming Shipment</h3>
              <a href="#next-shipment" class="acct__text-link">Manage</a>
            </div>
            <div class="acct__shipment-preview" id="dashShipmentPreview">
              <div class="acct__shipment-placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                <p>Choose your next fragrance</p>
                <a href="#next-shipment" class="btn btn--primary btn--small">Select Fragrance</a>
              </div>
            </div>
          </div>
          {%- else -%}
          <div class="acct__card acct__card--cta">
            <span class="acct__cta-badge">Start Your Journey</span>
            <h3 class="acct__cta-title">Join Base Note</h3>
            <p class="acct__cta-desc">Get a new luxury fragrance delivered every month for just $20 + free shipping.</p>
            <a href="/collections/all" class="btn btn--gold">Subscribe Now</a>
          </div>
          {%- endif -%}

          <!-- Recent Orders (condensed) -->
          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Recent Activity</h3>
              <a href="#orders" class="acct__text-link">View All</a>
            </div>
            {%- if customer.orders.size > 0 -%}
              <div class="acct__order-list">
                {%- for order in customer.orders limit: 3 -%}
                <a href="{{ order.customer_url }}" class="acct__order-row">
                  <div class="acct__order-info">
                    <span class="acct__order-num">{{ order.name }}</span>
                    <span class="acct__order-date">{{ order.created_at | date: '%b %d, %Y' }}</span>
                  </div>
                  <span class="acct__order-status acct__order-status--{{ order.fulfillment_status | default: 'processing' }}">
                    {{ order.fulfillment_status_label | default: 'Processing' }}
                  </span>
                  <span class="acct__order-total">{{ order.total_price | money }}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="acct__empty">
                <p>No orders yet</p>
                <a href="/collections/all" class="btn btn--primary btn--small">Start Shopping</a>
              </div>
            {%- endif -%}
          </div>

        </div>

        <!-- ────── Fragrance History ────── -->
        <div data-view="history" class="acct__view" style="display:none;">

          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Your Fragrance Journey</h3>
            </div>

            {%- comment -%}
              Data source: customer.metafields.subscription.fragrance_history
              Expected JSON array: [{ "month":"March 2026", "product_title":"Midnight Oud", "product_handle":"midnight-oud", "product_image":"...", "family":"Woody", "top_notes":"Bergamot, Saffron", "heart_notes":"Oud, Rose", "base_notes":"Sandalwood, Musk" }, ...]
            {%- endcomment -%}
            {%- assign fh_json = customer.metafields.subscription.fragrance_history -%}

            <div class="fh-timeline" id="fragranceTimeline">
              <!-- Populated by JS from metafield or localStorage fallback -->
            </div>

            <div class="fh-empty" id="fragranceTimelineEmpty" style="display:none;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              <h4>Your journey starts soon!</h4>
              <p>Once you receive your first fragrance, your scent history will appear here.</p>
              <a href="/collections/all" class="btn btn--primary btn--small">Browse Fragrances</a>
            </div>
          </div>

        </div>

        <!-- ────── Next Shipment ────── -->
        <div data-view="next-shipment" class="acct__view" style="display:none;">

          {%- if is_subscriber -%}
          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Next Shipment</h3>
              <span class="ns-status-badge" id="nsStatusBadge">Action Needed</span>
            </div>

            <!-- Selected fragrance display -->
            <div class="ns-selected" id="nsSelected" style="display:none;">
              <div class="ns-selected__card">
                <div class="ns-selected__image" id="nsImage"></div>
                <div class="ns-selected__info">
                  <h4 class="ns-selected__name" id="nsName"></h4>
                  <span class="ns-selected__family" id="nsFamily"></span>
                  <p class="ns-selected__ship">Ships in <span id="nsShipDays">—</span> days</p>
                </div>
              </div>
              <div class="ns-actions">
                <button class="btn btn--outline btn--small" id="nsSwapBtn">Swap Fragrance</button>
                <button class="btn btn--outline btn--small ns-skip-btn" id="nsSkipBtn">Skip This Month</button>
              </div>
            </div>

            <!-- No selection / action needed -->
            <div class="ns-choose" id="nsChoose">
              <div class="ns-choose__content">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
                <h4>Choose Your Next Fragrance</h4>
                <p>Select from our exclusive collection before the auto-selection date.</p>
                <button class="btn btn--primary" id="nsChooseBtn">Choose Now</button>
              </div>
            </div>

            <!-- Skipped state -->
            <div class="ns-skipped" id="nsSkipped" style="display:none;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40">
                <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
              </svg>
              <h4>Month Skipped</h4>
              <p>You've skipped this month's shipment. Your subscription will resume next month.</p>
              <button class="btn btn--outline btn--small" id="nsUndoSkip">Undo Skip</button>
            </div>
          </div>
          {%- else -%}
          <div class="acct__card acct__card--cta">
            <span class="acct__cta-badge">Get Started</span>
            <h3 class="acct__cta-title">Subscribe to Base Note</h3>
            <p class="acct__cta-desc">Choose your own fragrance each month or let us surprise you with our expert picks.</p>
            <a href="/collections/all" class="btn btn--gold">Start Your Subscription</a>
          </div>
          {%- endif -%}

        </div>

        <!-- ────── Subscription Management ────── -->
        <div data-view="subscription" class="acct__view" style="display:none;">

          {%- if is_subscriber -%}
          <!-- Featured card -->
          <div class="acct__welcome-banner">
            <div class="acct__welcome-content">
              <span class="acct__status-badge acct__status-badge--active" style="margin-bottom:12px;">Active</span>
              <h2 class="acct__welcome-title" style="font-size:1.5rem;">Monthly Subscription</h2>
              <p class="acct__welcome-meta">{{ settings.sub_plan_monthly_per_month | default: '$20/mo' }}</p>
            </div>
            <p class="acct__welcome-meta">Member since {{ customer.created_at | date: '%B %Y' }}</p>
          </div>

          <!-- Billing Countdown -->
          <div class="acct__card billing-countdown" id="billingCountdown">
            <div class="billing-countdown__header">
              <h3 class="acct__card-title">Next Billing</h3>
              <span class="billing-countdown__days" id="billingDaysLeft">— days</span>
            </div>
            <div class="billing-countdown__bar-wrap">
              <div class="billing-countdown__bar" id="billingBar" style="width:0%"></div>
            </div>
            <p class="billing-countdown__date" id="billingDateText">Next charge on —</p>
            <div class="billing-countdown__cancel-window" id="cancelWindowNotice">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <span>Cancel before <strong id="cancelDeadline">—</strong> to avoid the next charge</span>
            </div>
          </div>

          <!-- Plan Details -->
          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Plan Details</h3>
            </div>
            <div class="sub-details">
              <div class="sub-details__row">
                <span class="sub-details__label">Plan</span>
                <span class="sub-details__value">Monthly</span>
              </div>
              <div class="sub-details__row">
                <span class="sub-details__label">Price</span>
                <span class="sub-details__value">{{ settings.sub_plan_monthly_per_month | default: '$20/mo' }}</span>
              </div>
              <div class="sub-details__row">
                <span class="sub-details__label">Next Billing</span>
                <span class="sub-details__value" id="subNextBilling">—</span>
              </div>
              <div class="sub-details__row">
                <span class="sub-details__label">Payment Method</span>
                <span class="sub-details__value">•••• •••• •••• ——</span>
              </div>
              <div class="sub-details__row">
                <span class="sub-details__label">Shipping Address</span>
                <span class="sub-details__value">
                  {%- if customer.default_address -%}
                    {{ customer.default_address.address1 }}, {{ customer.default_address.city }}
                  {%- else -%}
                    Not set
                  {%- endif -%}
                </span>
              </div>
            </div>
          </div>

          <!-- Actions -->
          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Subscription Actions</h3>
            </div>
            <div class="sub-actions">
              <a href="{{ settings.subscription_portal_url | default: settings.appstle_portal_url | default: settings.recharge_portal_url | default: '/pages/contact' }}" class="sub-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Change Plan
              </a>
              <a href="{{ settings.subscription_portal_url | default: settings.appstle_portal_url | default: settings.recharge_portal_url | default: '/pages/contact' }}" class="sub-action-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                Update Payment
              </a>
              <button class="sub-action-btn" id="subSkipBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><polygon points="5 4 15 12 5 20 5 4"/><line x1="19" y1="5" x2="19" y2="19"/></svg>
                Skip Next Month
              </button>
              <button class="sub-action-btn" id="subPauseBtn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
                Pause Subscription
              </button>
            </div>
            <div class="sub-cancel">
              <button class="sub-cancel__link" id="subCancelBtn">Cancel subscription</button>
            </div>
          </div>
          {%- else -%}
          <div class="acct__card acct__card--cta">
            <span class="acct__cta-badge">Start Your Journey</span>
            <h3 class="acct__cta-title">Join Base Note</h3>
            <p class="acct__cta-desc">Discover a new luxury fragrance every month. Plans start at just $14/mo.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap;">
              <a href="/collections/all" class="btn btn--gold">Subscribe Now</a>
              <a href="/pages/quiz" class="btn btn--outline">Take the Scent Quiz</a>
            </div>
          </div>
          {%- endif -%}

        </div>

        <!-- ────── Order History ────── -->
        <div data-view="orders" class="acct__view" style="display:none;">

          <div class="acct__card">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Order History</h3>
            </div>

            {%- if customer.orders.size > 0 -%}
              <div class="acct__order-list">
                {%- for order in customer.orders -%}
                <a href="{{ order.customer_url }}" class="acct__order-row">
                  <div class="acct__order-info">
                    <span class="acct__order-num">{{ order.name }}</span>
                    <span class="acct__order-date">{{ order.created_at | date: '%B %d, %Y' }}</span>
                  </div>
                  <span class="acct__order-status acct__order-status--{{ order.fulfillment_status | default: 'processing' }}">
                    {{ order.fulfillment_status_label | default: 'Processing' }}
                  </span>
                  <span class="acct__order-total">{{ order.total_price | money }}</span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
                {%- endfor -%}
              </div>
            {%- else -%}
              <div class="acct__empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" width="48" height="48">
                  <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <p>No orders yet</p>
                <a href="/collections/all" class="btn btn--primary btn--small">Start Shopping</a>
              </div>
            {%- endif -%}
          </div>

        </div>

      </main>
    </div>
  </div>
</section>

{%- if is_subscriber -%}
  {% render 'fragrance-selector', mode: 'modal' %}
  {% render 'cancellation-flow' %}
{%- endif -%}

<!-- ═══════════════════════════════════════ -->
<!-- STYLES                                  -->
<!-- ═══════════════════════════════════════ -->
<style>
  /* ── Layout ── */
  .acct { padding-top: calc(var(--header-height, 110px) + 2.5rem); padding-bottom: 4rem; min-height: 100vh; background: #F5F3F0; }
  .acct__layout { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; }

  /* ── Sidebar ── */
  .acct__sidebar { background: #fff; border-radius: 12px; padding: 1.5rem; height: fit-content; position: sticky; top: calc(var(--header-height, 110px) + 1.5rem); }
  .acct__user { display: flex; align-items: center; gap: 12px; padding-bottom: 1.25rem; border-bottom: 1px solid #E8E6E3; margin-bottom: 1.25rem; }
  .acct__avatar { width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; background: #2D4641; color: #fff; border-radius: 50%; font-weight: 700; font-size: 14px; flex-shrink: 0; }
  .acct__user-greeting { font-size: 12px; color: #999; margin: 0; }
  .acct__user-name { font-weight: 700; font-size: 14px; margin: 0; color: #2D4641; }
  .acct__user-email { font-size: 12px; color: #999; margin: 0; }
  .acct__nav { display: flex; flex-direction: column; gap: 4px; }
  .acct__nav-link { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; color: #666; text-decoration: none; transition: all 0.2s; }
  .acct__nav-link:hover { background: #F5F3F0; color: #2D4641; }
  .acct__nav-link.is-active { background: #2D4641; color: #fff; }
  .acct__sidebar-footer { margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid #E8E6E3; }
  .acct__logout { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #999; text-decoration: none; }
  .acct__logout:hover { color: #2D4641; }

  /* ── Main ── */
  .acct__main { display: flex; flex-direction: column; gap: 1.5rem; min-width: 0; }
  .acct__view { display: flex; flex-direction: column; gap: 1.5rem; }

  /* ── Welcome Banner ── */
  .acct__welcome-banner { background: linear-gradient(135deg, #2D4641 0%, #1a2927 100%); border-radius: 12px; padding: 2rem; color: #fff; display: flex; justify-content: space-between; align-items: center; position: relative; overflow: hidden; }
  .acct__welcome-banner::before { content: ''; position: absolute; top: -40%; right: -20%; width: 60%; height: 180%; background: radial-gradient(ellipse, rgba(201,169,98,0.08) 0%, transparent 70%); pointer-events: none; }
  .acct__welcome-content { position: relative; }
  .acct__welcome-eyebrow { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.15em; color: #C9A962; margin: 0 0 8px; }
  .acct__welcome-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.75rem; font-weight: 600; margin: 0 0 4px; }
  .acct__welcome-meta { font-size: 13px; opacity: 0.6; margin: 0; }
  .acct__status-badge { display: inline-block; padding: 5px 14px; border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; }
  .acct__status-badge--active { background: rgba(76,175,80,0.15); color: #4CAF50; border: 1px solid rgba(76,175,80,0.3); }

  /* ── Stats ── */
  .acct__stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; }
  .acct__stat { background: #fff; border-radius: 12px; padding: 1.25rem; text-align: center; }
  .acct__stat-num { display: block; font-size: 1.5rem; font-weight: 700; color: #C9A962; margin-bottom: 4px; font-family: 'Cormorant Garamond', Georgia, serif; }
  .acct__stat-label { font-size: 12px; color: #999; }

  /* ── Card ── */
  .acct__card { background: #fff; border-radius: 12px; padding: 1.5rem; }
  .acct__card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem; }
  .acct__card-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: #2D4641; margin: 0; }
  .acct__text-link { color: #C9A962; font-size: 13px; font-weight: 600; text-decoration: none; }
  .acct__text-link:hover { text-decoration: underline; }

  /* ── CTA card ── */
  .acct__card--cta { background: linear-gradient(135deg, #2D4641 0%, #1a2927 100%); color: #fff; text-align: center; padding: 2.5rem; }
  .acct__cta-badge { display: inline-block; padding: 5px 16px; background: rgba(201,169,98,0.15); border: 1px solid rgba(201,169,98,0.4); border-radius: 999px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #C9A962; margin-bottom: 16px; }
  .acct__cta-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 600; margin: 0 0 8px; }
  .acct__cta-desc { font-size: 14px; opacity: 0.75; margin: 0 0 24px; max-width: 400px; margin-left: auto; margin-right: auto; line-height: 1.6; }

  /* ── Orders ── */
  .acct__order-list { display: flex; flex-direction: column; }
  .acct__order-row { display: flex; align-items: center; gap: 1rem; padding: 12px 0; border-bottom: 1px solid #F0EDE8; text-decoration: none; color: inherit; transition: background 0.15s; }
  .acct__order-row:last-child { border-bottom: none; }
  .acct__order-row:hover { background: #FAF8F5; margin: 0 -12px; padding-left: 12px; padding-right: 12px; border-radius: 8px; }
  .acct__order-info { flex: 1; min-width: 0; }
  .acct__order-num { font-weight: 700; font-size: 14px; display: block; color: #2D4641; }
  .acct__order-date { font-size: 12px; color: #999; }
  .acct__order-status { padding: 3px 10px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; border-radius: 999px; white-space: nowrap; }
  .acct__order-status--fulfilled { background: rgba(76,175,80,0.1); color: #4CAF50; }
  .acct__order-status--unfulfilled, .acct__order-status--processing { background: rgba(201,169,98,0.1); color: #C9A962; }
  .acct__order-total { font-weight: 700; font-size: 14px; color: #2D4641; }

  /* ── Empty ── */
  .acct__empty { text-align: center; padding: 2.5rem 1rem; }
  .acct__empty svg { color: #ccc; margin-bottom: 12px; }
  .acct__empty p { color: #999; font-size: 14px; margin: 0 0 16px; }

  /* ── Shipment Preview ── */
  .acct__shipment-placeholder { text-align: center; padding: 2rem; color: #999; }
  .acct__shipment-placeholder svg { margin-bottom: 12px; color: #ccc; }
  .acct__shipment-placeholder p { margin: 0 0 16px; font-size: 14px; }

  /* ── Fragrance History Timeline ── */
  .fh-timeline { position: relative; padding-left: 32px; }
  .fh-timeline::before { content: ''; position: absolute; left: 11px; top: 0; bottom: 0; width: 2px; background: #E8E6E3; }
  .fh-entry { position: relative; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid #F0EDE8; }
  .fh-entry:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
  .fh-entry__dot { position: absolute; left: -32px; top: 4px; width: 22px; height: 22px; background: #2D4641; border: 3px solid #fff; border-radius: 50%; box-shadow: 0 0 0 2px #E8E6E3; }
  .fh-entry__month { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #C9A962; margin-bottom: 12px; }
  .fh-entry__grid { display: grid; grid-template-columns: 120px 1fr; gap: 1.25rem; }
  .fh-entry__image { width: 120px; height: 120px; border-radius: 10px; overflow: hidden; background: #F5F3F0; }
  .fh-entry__image img { width: 100%; height: 100%; object-fit: cover; }
  .fh-entry__name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.1rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; color: #C9A962; margin: 0 0 4px; }
  .fh-entry__family { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #2D4641; background: #F0EDE8; padding: 3px 10px; border-radius: 999px; margin-bottom: 10px; }
  .fh-entry__notes { font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 12px; }
  .fh-entry__notes strong { color: #2D4641; font-weight: 700; }

  /* Star rating */
  .fh-stars { display: flex; gap: 4px; margin-bottom: 10px; }
  .fh-star { cursor: pointer; width: 22px; height: 22px; color: #ddd; transition: color 0.15s; }
  .fh-star.is-filled { color: #C9A962; }
  .fh-star:hover { color: #C9A962; }

  /* User notes */
  .fh-user-note { display: flex; gap: 8px; margin-bottom: 12px; }
  .fh-user-note textarea { flex: 1; border: 1px solid #E8E6E3; border-radius: 8px; padding: 8px 12px; font-size: 13px; font-family: inherit; resize: vertical; min-height: 40px; }
  .fh-user-note textarea:focus { outline: none; border-color: #C9A962; }
  .fh-user-note button { padding: 8px 16px; background: #2D4641; color: #fff; border: none; border-radius: 8px; font-size: 12px; font-weight: 700; cursor: pointer; white-space: nowrap; }

  /* Action buttons */
  .fh-entry__actions { display: flex; gap: 8px; flex-wrap: wrap; }
  .fh-entry__actions a, .fh-entry__actions button { padding: 6px 14px; font-size: 12px; font-weight: 600; border-radius: 6px; text-decoration: none; cursor: pointer; transition: all 0.2s; }
  .fh-action--again { background: #2D4641; color: #fff; border: none; }
  .fh-action--fullsize { background: transparent; color: #2D4641; border: 1px solid #E8E6E3; }

  .fh-empty { text-align: center; padding: 3rem 1rem; }
  .fh-empty svg { color: #ccc; margin-bottom: 16px; }
  .fh-empty h4 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; color: #2D4641; margin: 0 0 8px; }
  .fh-empty p { color: #999; font-size: 14px; margin: 0 0 20px; line-height: 1.5; }

  /* ── Next Shipment ── */
  .ns-status-badge { padding: 4px 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; border-radius: 999px; }
  .ns-status-badge.ns-confirmed { background: rgba(76,175,80,0.1); color: #4CAF50; }
  .ns-status-badge.ns-auto { background: rgba(201,169,98,0.1); color: #C9A962; }
  .ns-status-badge.ns-action { background: rgba(255,152,0,0.1); color: #FF9800; }
  .ns-status-badge.ns-skipped { background: rgba(158,158,158,0.1); color: #9E9E9E; }
  .ns-selected__card { display: flex; align-items: center; gap: 1.25rem; padding: 1.25rem; background: #FAF8F5; border-radius: 12px; margin-bottom: 1.25rem; }
  .ns-selected__image { width: 100px; height: 100px; border-radius: 10px; overflow: hidden; background: #F0EDE8; flex-shrink: 0; }
  .ns-selected__image img { width: 100%; height: 100%; object-fit: cover; }
  .ns-selected__name { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.15rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; color: #2D4641; margin: 0 0 4px; }
  .ns-selected__family { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #C9A962; margin-bottom: 8px; }
  .ns-selected__ship { font-size: 13px; color: #666; margin: 0; }
  .ns-actions { display: flex; gap: 10px; }
  .ns-skip-btn { color: #999 !important; border-color: #ddd !important; }
  .ns-choose__content { text-align: center; padding: 2.5rem 1rem; }
  .ns-choose__content svg { color: #ccc; margin-bottom: 16px; }
  .ns-choose__content h4 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.2rem; color: #2D4641; margin: 0 0 8px; }
  .ns-choose__content p { font-size: 14px; color: #999; margin: 0 0 20px; }
  .ns-skipped { text-align: center; padding: 2.5rem 1rem; }
  .ns-skipped svg { color: #ccc; margin-bottom: 16px; }
  .ns-skipped h4 { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.2rem; color: #2D4641; margin: 0 0 8px; }
  .ns-skipped p { font-size: 14px; color: #999; margin: 0 0 20px; }

  /* ── Subscription Details ── */
  .sub-details { display: flex; flex-direction: column; }
  .sub-details__row { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #F0EDE8; }
  .sub-details__row:last-child { border-bottom: none; }
  .sub-details__label { font-size: 13px; color: #999; }
  .sub-details__value { font-size: 14px; font-weight: 600; color: #2D4641; }
  .sub-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem; }
  .sub-action-btn { display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: #FAF8F5; border: 1px solid #E8E6E3; border-radius: 10px; font-size: 13px; font-weight: 600; color: #2D4641; text-decoration: none; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .sub-action-btn:hover { border-color: #C9A962; background: rgba(201,169,98,0.04); }
  .sub-cancel { text-align: center; padding-top: 1rem; border-top: 1px solid #F0EDE8; }
  .sub-cancel__link { background: none; border: none; color: #999; font-size: 12px; cursor: pointer; font-family: inherit; text-decoration: underline; }
  .sub-cancel__link:hover { color: #c62828; }

  /* ── Billing Countdown ── */
  .billing-countdown__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .billing-countdown__days { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #C9A962; }
  .billing-countdown__bar-wrap { height: 6px; background: #F0EDE8; border-radius: 3px; overflow: hidden; margin-bottom: 12px; }
  .billing-countdown__bar { height: 100%; background: linear-gradient(90deg, #2D4641, #C9A962); border-radius: 3px; transition: width 0.6s ease; }
  .billing-countdown__date { font-size: 13px; color: #666; margin: 0 0 12px; }
  .billing-countdown__cancel-window { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(255,152,0,0.06); border: 1px solid rgba(255,152,0,0.2); border-radius: 8px; font-size: 12px; color: #666; }
  .billing-countdown__cancel-window svg { color: #FF9800; flex-shrink: 0; }
  .billing-countdown__cancel-window strong { color: #2D4641; }

  /* ── Buttons ── */
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 12px 24px; font-weight: 700; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; text-transform: uppercase; letter-spacing: 0.08em; font-size: 13px; border: 2px solid transparent; font-family: inherit; }
  .btn--primary { background: #2D4641; color: #fff; border-color: #2D4641; }
  .btn--primary:hover { background: #1a2927; }
  .btn--gold { background: #C9A962; color: #2D4641; border-color: #C9A962; }
  .btn--gold:hover { background: #b8963f; }
  .btn--outline { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
  .btn--outline:hover { border-color: #fff; }
  .btn--small { padding: 8px 18px; font-size: 12px; }

  /* ── Responsive ── */
  @media (max-width: 992px) {
    .acct__layout { grid-template-columns: 1fr; }
    .acct__sidebar { position: static; }
    .acct__nav { flex-direction: row; flex-wrap: wrap; gap: 6px; }
    .acct__nav-link { padding: 8px 14px; font-size: 12px; }
    .acct__stats { grid-template-columns: repeat(2, 1fr); }
    .sub-actions { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .acct { padding-top: calc(var(--header-height, 110px) + 1.5rem); }
    .acct__welcome-banner { flex-direction: column; align-items: flex-start; gap: 12px; padding: 1.5rem; }
    .acct__welcome-title { font-size: 1.35rem; }
    .fh-entry__grid { grid-template-columns: 80px 1fr; gap: 1rem; }
    .fh-entry__image { width: 80px; height: 80px; }
    .ns-selected__card { flex-direction: column; text-align: center; }
    .ns-actions { justify-content: center; }
  }
  @media (max-width: 576px) {
    .acct__stats { grid-template-columns: 1fr 1fr; gap: 8px; }
    .acct__stat { padding: 1rem; }
    .acct__stat-num { font-size: 1.25rem; }
  }
</style>

