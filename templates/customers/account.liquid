  function setupEventListeners() {
    // Next Shipment buttons
    var chooseBtn = $('#nsChooseBtn');
    var swapBtn = $('#nsSwapBtn');
    var skipBtn = $('#nsSkipBtn');
    var undoSkipBtn = $('#nsUndoSkip');
    if (chooseBtn) {
      chooseBtn.addEventListener('click', function() {
        openFragranceSelector();
      });
    }
    if (swapBtn) {
      swapBtn.addEventListener('click', function() {
        openFragranceSelector();
      });
    }
    if (skipBtn) {
      skipBtn.addEventListener('click', async function() {
        if (!confirm('Skip this month\'s shipment?')) return;
        var sub = state.subscription;
        if (sub && sub.contractId) {
          try {
            await AppstleAPI.skipNextOrder(sub.contractId);
            state.nextShipment = { status: 'skipped' };
            saveNextShipmentState();
            renderNextShipment();
            renderDashShipmentPreview();
          } catch (e) {
            alert('Unable to skip. Please try again or contact support.');
          }
        } else {
          state.nextShipment = { status: 'skipped' };
          saveNextShipmentState();
          renderNextShipment();
          renderDashShipmentPreview();
        }
      });
    }
    if (undoSkipBtn) {
      undoSkipBtn.addEventListener('click', function() {
        state.nextShipment = null;
        saveNextShipmentState();
        renderNextShipment();
        renderDashShipmentPreview();
      });
    }
    // Fragrance selection listener
    document.addEventListener('fragrance:selected', function(e) {
      var frag = e.detail;
      var monthKey = frag.monthKey;
      if (monthKey) {
        // Adding to future queue
        state.futureQueue[monthKey] = {
          productId: frag.id,
          variantId: frag.variantId,
          title: frag.title,
          image: frag.image,
          handle: frag.handle,
          vendor: frag.vendor || frag.family
        };
        saveFutureQueue();
        renderFutureMonths();
        renderDashQueuePreview();
      } else {
        // Setting next shipment
        state.nextShipment = {
          fragrance: {
            id: frag.id,
            variantId: frag.variantId,
            handle: frag.handle,
            title: frag.title,
            image: frag.image,
            family: frag.vendor || frag.family
          },
          autoSelected: false,
          status: 'confirmed',
          timestamp: new Date().toISOString()
        };
        saveNextShipmentState();
        renderNextShipment();
        renderDashShipmentPreview();
        // If we have an active contract, update the line item via API
        var sub = state.subscription;
        if (sub && sub.contractId && sub.lines && sub.lines.length > 0) {
          var lineId = sub.lines[0].id;
          AppstleAPI.updateLineItem(sub.contractId, lineId, frag.variantId, frag.sellingPlanId)
            .catch(function(e) {
              console.error('Failed to update line item:', e);
            });
        }
      }
    });
    // Subscription action buttons
    var subUpdatePaymentBtn = $('#subUpdatePaymentBtn');
    var subUpdateAddressBtn = $('#subUpdateAddressBtn');
    var subSkipBtn = $('#subSkipBtn');
    var subPauseBtn = $('#subPauseBtn');
    var subCancelBtn = $('#subCancelBtn');
    if (subUpdatePaymentBtn) {
      subUpdatePaymentBtn.addEventListener('click', async function() {
        var sub = state.subscription;
        if (!sub || !sub.contractId) {
          alert('No active subscription found.');
          return;
        }
        var btn = this;
        var originalHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg viewBox="0 0 24 24" width="20" height="20"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="31.4"><animateTransform attributeName="transform" type="rotate" dur="0.8s" from="0 12 12" to="360 12 12" repeatCount="indefinite"/></circle></svg> Sending…';
        try {
          await AppstleAPI.updatePaymentMethod(sub.contractId);
          btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="#4CAF50" stroke-width="2" width="20" height="20"><polyline points="20 6 9 17 4 12"/></svg> Email sent!';
          btn.style.borderColor = '#4CAF50';
          showPaymentUpdateModal();
        } catch (e) {
          btn.innerHTML = originalHtml;
          btn.disabled = false;
          alert('Could not send email. Please try again.');
        }
      });
    }
    if (subUpdateAddressBtn) {
      subUpdateAddressBtn.addEventListener('click', function() {
        window.location.href = '{{ routes.account_addresses_url }}';
      });
    }
    if (subSkipBtn) {
      subSkipBtn.addEventListener('click', async function() {
        if (!confirm('Skip next month\'s shipment?')) return;
        var sub = state.subscription;
        if (sub && sub.contractId) {
          try {
            await AppstleAPI.skipNextOrder(sub.contractId);
            alert('Next month\'s shipment has been skipped.');
            await AppstleAPI.refresh();
          } catch (e) {
            alert('Unable to skip. Please try again.');
          }
        }
      });
    }
    if (subPauseBtn) {
      subPauseBtn.addEventListener('click', async function() {
        if (!confirm('Pause your subscription? You can resume anytime.')) return;
        var sub = state.subscription;
        if (sub && sub.contractId) {
          try {
            await AppstleAPI.pauseSubscription(sub.contractId);
            alert('Your subscription has been paused.');
            await AppstleAPI.refresh();
          } catch (e) {
            alert('Unable to pause. Please contact support.');
          }
        }
      });
    }
    if (subCancelBtn) {
      subCancelBtn.addEventListener('click', function() {
        document.dispatchEvent(new Event('cancellation:open'));
      });
    }
  }
  function showPaymentUpdateModal() {
