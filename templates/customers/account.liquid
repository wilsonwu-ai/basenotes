          var item = state.futureQueue[monthKey];
          queueHtml += '<div class="fm-queue-item">' +
            '<div class="fm-queue-item__num">' + (idx + 1) + '</div>' +
            (item.image ? '<img class="fm-queue-item__img" src="' + item.image + '">' : '<div class="fm-queue-item__img"></div>') +
            '<div class="fm-queue-item__info">' +
            '<div class="fm-queue-item__month">' + getMonthLabel(monthKey) + '</div>' +
            '<div class="fm-queue-item__name">' + item.title + '</div>' +
            '</div>' +
            '<div class="fm-queue-item__actions">' +
            '<button class="fm-queue-item__btn" data-edit-month="' + monthKey + '" title="Change">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
            '</button>' +
            '<button class="fm-queue-item__btn fm-queue-item__btn--remove" data-remove-month="' + monthKey + '" title="Remove">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
            '</button>' +
            '</div></div>';
        });
        queueHtml += '</div>';
        queueEl.innerHTML = queueHtml;
      }
    }
    // Attach event listeners
    grid.querySelectorAll('.fm-month-card').forEach(function(card) {
      card.addEventListener('click', function(e) {
        if (e.target.closest('[data-clear-month]')) return;
        var monthKey = this.dataset.month;
        openFragranceSelector(monthKey);
      });
    });
    grid.querySelectorAll('[data-clear-month]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
