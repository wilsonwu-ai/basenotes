  .sub-details__value { font-size: 14px; font-weight: 600; color: #2D4641; }
  .sub-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.5rem; }
  .sub-actions .sub-action-btn:last-child:nth-child(odd) { grid-column: 1 / -1; }
  .sub-action-btn { display: flex; align-items: center; gap: 10px; padding: 14px 16px; background: #FAF8F5; border: 1px solid #E8E6E3; border-radius: 10px; font-size: 13px; font-weight: 600; color: #2D4641; text-decoration: none; cursor: pointer; transition: all 0.2s; font-family: inherit; }
  .sub-action-btn:hover { border-color: #C9A962; background: rgba(201,169,98,0.04); }
  .sub-cancel { text-align: center; padding-top: 1rem; border-top: 1px solid #F0EDE8; }
  .sub-cancel__link { background: none; border: none; color: #999; font-size: 12px; cursor: pointer; font-family: inherit; text-decoration: underline; }
  .sub-cancel__link:hover { color: #c62828; }

  /* ── Billing Countdown ── */
  .billing-countdown__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .billing-countdown__days { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #C9A962; }
  .billing-countdown__bar-wrap { height: 6px; background: #F0EDE8; border-radius: 3px; overflow: hidden; margin-bottom: 12px; }
  .billing-countdown__bar { height: 100%; background: linear-gradient(90deg, #2D4641, #C9A962); border-radius: 3px; transition: width 0.6s ease; }
  .billing-countdown__date { font-size: 13px; color: #666; margin: 0 0 12px; }
  .billing-countdown__cancel-window { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(255,152,0,0.06); border: 1px solid rgba(255,152,0,0.2); border-radius: 8px; font-size: 12px; color: #666; }
  .billing-countdown__cancel-window svg { color: #FF9800; flex-shrink: 0; }
  .billing-countdown__cancel-window strong { color: #2D4641; }

  /* ── Buttons ── */
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 12px 24px; font-weight: 700; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; text-transform: uppercase; letter-spacing: 0.08em; font-size: 13px; border: 2px solid transparent; font-family: inherit; }
  .btn--primary { background: #2D4641; color: #fff; border-color: #2D4641; }
  .btn--primary:hover { background: #1a2927; }
  .btn--gold { background: #C9A962; color: #2D4641; border-color: #C9A962; }
  .btn--gold:hover { background: #b8963f; }
  .btn--outline { background: transparent; color: #2D4641; border-color: #D5D0C8; }
  .btn--outline:hover { border-color: #C9A962; color: #C9A962; }
  .acct__card--cta .btn--outline { color: #fff; border-color: rgba(255,255,255,0.4); }
  .acct__card--cta .btn--outline:hover { border-color: #fff; color: #fff; }
  .btn--small { padding: 8px 18px; font-size: 12px; }

  /* ── Responsive ── */
  @media (max-width: 992px) {
    .acct__layout { grid-template-columns: 1fr; }
    .acct__sidebar { position: static; }
    .acct__nav { flex-direction: row; flex-wrap: wrap; gap: 6px; }
    .acct__nav-link { padding: 8px 14px; font-size: 12px; }
    .acct__stats { grid-template-columns: repeat(2, 1fr); }
    .sub-actions { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .acct { padding-top: calc(var(--header-height, 110px) + 1.5rem); }
    .acct__welcome-banner { flex-direction: column; align-items: flex-start; gap: 12px; padding: 1.5rem; }
    .acct__welcome-title { font-size: 1.35rem; }
    .fh-entry__grid { grid-template-columns: 80px 1fr; gap: 1rem; }
    .fh-entry__image { width: 80px; height: 80px; }
    .ns-selected__card { flex-direction: column; text-align: center; }
    .ns-actions { justify-content: center; }
  }
  @media (max-width: 576px) {
    .acct__stats { grid-template-columns: 1fr 1fr; gap: 8px; }
    .acct__stat { padding: 1rem; }
    .acct__stat-num { font-size: 1.25rem; }
  }

  /* ═══ Dashboard Card Grid (PRD-05) ═══ */
  .acct__card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media (max-width: 860px) { .acct__card-grid { grid-template-columns: 1fr; } }

  /* ═══ Fragrance Journey Timeline (PRD-05) ═══ */
  .fj-timeline { display: flex; gap: 20px; overflow-x: auto; padding: 20px 2px; position: relative; scroll-snap-type: x proximity; -webkit-overflow-scrolling: touch; }
  .fj-timeline::after { content: ''; position: absolute; top: 50%; left: 12px; right: 12px; height: 2px; background: repeating-linear-gradient(90deg, #EEE9DF 0, #EEE9DF 6px, transparent 6px, transparent 12px); z-index: 0; }
  .fj-stop { flex: 0 0 auto; min-width: 100px; display: flex; flex-direction: column; align-items: center; gap: 8px; position: relative; z-index: 1; scroll-snap-align: start; }
  .fj-stop__dot { width: 52px; height: 52px; border-radius: 50%; background: #fff; border: 2px solid #EEE9DF; display: flex; align-items: center; justify-content: center; overflow: hidden; color: #C9A962; transition: border-color 0.2s, transform 0.2s; }
  .fj-stop--past .fj-stop__dot { border-color: #2D4641; background: #2D4641; color: #fff; }
  .fj-stop--current .fj-stop__dot { border-color: #C9A962; box-shadow: 0 0 0 4px rgba(201,169,98,0.18); transform: scale(1.08); }
  .fj-stop--future .fj-stop__dot { border-style: dashed; }
  .fj-stop__dot img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .fj-stop__month { font-size: 11px; font-weight: 700; color: #2D4641; text-transform: uppercase; letter-spacing: 0.07em; }
  .fj-stop__label { font-size: 11px; color: #8a918e; text-align: center; max-width: 92px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  /* ═══ Dashboard Queue Preview (PRD-05) ═══ */
  .dash-queue-preview { display: flex; flex-direction: column; gap: 10px; padding: 4px 0; min-height: 120px; }
  .dash-qp-row { display: flex; align-items: center; gap: 12px; padding: 10px; background: #FAF8F5; border-radius: 10px; text-decoration: none; color: inherit; transition: background 0.15s, transform 0.15s; }
  .dash-qp-row:hover { background: #F5F3EF; transform: translateX(2px); }
  .dash-qp-row__img { width: 40px; height: 40px; border-radius: 6px; background: #fff; object-fit: cover; flex-shrink: 0; border: 1px solid #EEE9DF; }
  .dash-qp-row__info { flex: 1; min-width: 0; }
  .dash-qp-row__month { font-size: 10px; color: #C9A962; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; }
  .dash-qp-row__title { font-size: 13px; font-weight: 700; color: #2D4641; margin: 2px 0 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .dash-qp-row__chev { color: #B8B0A0; flex-shrink: 0; }
  .dash-qp-row--empty { background: #fff; border: 1px dashed #EEE9DF; color: #8a918e; }
  .dash-qp-row--empty .dash-qp-row__img { background: #F5F3EF; display: flex; align-items: center; justify-content: center; color: #C9A962; }
  .dash-qp-empty-wrap { text-align: center; padding: 1.25rem; color: #8a918e; font-size: 13px; }
  .dash-qp-empty-wrap a { color: #C9A962; font-weight: 700; text-decoration: none; }
  .dash-qp-empty-wrap a:hover { text-decoration: underline; }

  /* ═══ My Subscription List / Queue (PRD-01) ═══ */
  .bq-sublabel { font-size: 13px; color: #8a918e; margin: 4px 0 0; font-weight: 400; }
  .bq-count-badge { background: #2D4641; color: #fff; padding: 4px 12px; border-radius: 999px; font-size: 11px; font-weight: 700; letter-spacing: 0.04em; white-space: nowrap; }
  .bq-strip { display: flex; gap: 14px; overflow-x: auto; padding: 16px 2px 20px; scroll-snap-type: x proximity; -webkit-overflow-scrolling: touch; }
  .bq-strip::-webkit-scrollbar { height: 6px; }
  .bq-strip::-webkit-scrollbar-track { background: #F5F3EF; border-radius: 3px; }
  .bq-strip::-webkit-scrollbar-thumb { background: #D5CFC3; border-radius: 3px; }
  .bq-strip::-webkit-scrollbar-thumb:hover { background: #C9A962; }

  .bq-card { flex: 0 0 180px; scroll-snap-align: start; background: #fff; border: 1px solid #EEE9DF; border-radius: 14px; padding: 14px; display: flex; flex-direction: column; gap: 12px; position: relative; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s; cursor: default; }
  .bq-card:hover { border-color: #C9A962; box-shadow: 0 6px 18px rgba(45,70,65,0.06); }
  .bq-card.is-dragging { opacity: 0.4; transform: scale(0.98); }
  .bq-card.is-ghost { border-style: dashed; background: #FAF8F5; }
  .bq-card__drag-handle { position: absolute; top: 10px; right: 10px; width: 28px; height: 28px; background: transparent; border: none; cursor: grab; color: #B8B0A0; border-radius: 6px; display: flex; align-items: center; justify-content: center; transition: color 0.15s, background 0.15s; }
  .bq-card__drag-handle:hover { color: #2D4641; background: #F5F3EF; }
  .bq-card__drag-handle:active { cursor: grabbing; }
  .bq-card--empty .bq-card__drag-handle { opacity: 0.35; }
  .bq-card__drag-handle[disabled] { display: none; }

  .bq-card__image { width: 100%; aspect-ratio: 1/1.1; background: #F5F3EF url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="%23D5CFC3" stroke-width="1.5"><path d="M9 2h6v4h-6z"/><path d="M7 6h10v16H7z"/></svg>') center/35% no-repeat; border-radius: 10px; overflow: hidden; display: flex; align-items: center; justify-content: center; }
  .bq-card__image img { width: 100%; height: 100%; object-fit: cover; }
  .bq-card__title { font-size: 14px; font-weight: 700; color: #2D4641; margin: 0; line-height: 1.3; letter-spacing: -0.005em; }
  .bq-card__family { font-size: 11px; color: #8a918e; text-transform: uppercase; letter-spacing: 0.08em; margin: 2px 0 0; }
  .bq-card__month-label { display: flex; flex-direction: column; gap: 2px; font-size: 12px; margin: 0; padding-top: 8px; border-top: 1px dashed #EEE9DF; }
  .bq-card__month { font-weight: 700; color: #2D4641; font-size: 13px; }
  .bq-card__ship-status { color: #8a918e; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; }
  .bq-card__ship-status--immediate { color: #C9A962; }
  .bq-card__swap { display: inline-flex; align-items: center; justify-content: center; gap: 4px; margin-top: 4px; padding: 6px 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; background: transparent; border: 1px solid #EEE9DF; border-radius: 6px; color: #2D4641; cursor: pointer; font-family: inherit; transition: border-color 0.15s, color 0.15s, background 0.15s; }
  .bq-card__swap:hover { border-color: #C9A962; color: #C9A962; background: #FAF8F5; }
  .bq-card__swap svg { color: currentColor; }
  .bq-card__remove { position: absolute; top: 10px; left: 10px; width: 24px; height: 24px; background: rgba(255,255,255,0.9); border: 1px solid #EEE9DF; border-radius: 50%; cursor: pointer; color: #8a918e; display: flex; align-items: center; justify-content: center; padding: 0; transition: color 0.15s, border-color 0.15s; opacity: 0; }
  .bq-card:hover .bq-card__remove { opacity: 1; }
  .bq-card__remove:hover { color: #c62828; border-color: #c62828; }
  .bq-card__remove:focus-visible { opacity: 1; outline: 2px solid #C9A962; outline-offset: 2px; }

  .bq-card__empty-slot { display: flex; align-items: center; justify-content: center; flex: 1; }
  .bq-card__empty-link { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 8px; text-decoration: none; color: inherit; padding: 12px 4px; width: 100%; border-radius: 10px; transition: background 0.15s; }
  .bq-card__empty-link:hover { background: #FAF8F5; }
  .bq-card__plus { width: 48px; height: 48px; border-radius: 50%; background: #F5F3EF; color: #C9A962; display: flex; align-items: center; justify-content: center; transition: background 0.15s; }
  .bq-card__empty-link:hover .bq-card__plus { background: #fff; border: 1px solid #C9A962; }
  .bq-card__empty-title { font-size: 13px; font-weight: 700; color: #2D4641; margin: 0; letter-spacing: -0.005em; }
  .bq-card__empty-sub { font-size: 10.5px; color: #8a918e; margin: 0; line-height: 1.35; max-width: 140px; }

  .bq-footnote { font-size: 12px; color: #8a918e; margin: 12px 0 0; line-height: 1.45; font-style: italic; }

  /* Mobile: cards a hair smaller, snap harder */
  @media (max-width: 640px) {
    .bq-card { flex: 0 0 160px; padding: 12px; }
    .bq-strip { scroll-snap-type: x mandatory; gap: 10px; }
    .bq-card__empty-sub { max-width: 120px; }
  }
</style>

<!-- ═══════════════════════════════════════ -->
<!-- JAVASCRIPT                              -->
<!-- ═══════════════════════════════════════ -->
<script src="{{ 'sortable.min.js' | asset_url }}" defer></script>
<script src="{{ 'queue-scheduler.js' | asset_url }}" defer></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  'use strict';

  // Subscription data from server (Liquid)
  var serverSubData = {
    isSubscriber: {{ is_subscriber | json }},
    {% if latest_sub_order %}
    orderDate: {{ latest_sub_order.created_at | json }},
    orderName: {{ latest_sub_order.name | json }},
    orderFulfilled: {{ latest_sub_order.fulfillment_status | json }},
    {% endif %}
    {% if latest_sub_item %}
    productTitle: {{ latest_sub_item.product.title | json }},
    productImage: {{ latest_sub_item.image | image_url: width: 200 | json }},
    productVendor: {{ latest_sub_item.product.vendor | json }},
    {% endif %}
    portalUrl: {{ settings.appstle_portal_url | default: '/apps/subscriptions' | json }},
    fotmEnabled: {{ settings.fotm_enabled | default: false | json }},
    fotmMonth: {{ settings.fotm_month | json }},
    {%- if settings.fotm_product -%}
    fotmProduct: {
      title: {{ settings.fotm_product.title | json }},
      image: {{ settings.fotm_product.featured_image | image_url: width: 200 | json }},
      vendor: {{ settings.fotm_product.vendor | json }},
      handle: {{ settings.fotm_product.handle | json }},
      variantId: {{ settings.fotm_product.selected_or_first_available_variant.id | json }},
      {%- if settings.fotm_product.selling_plan_groups.size > 0 -%}
      sellingPlanId: {{ settings.fotm_product.selling_plan_groups[0].selling_plans[0].id | json }},
      {%- endif -%}
    },
    {%- endif -%}
    fotmDisplayName: {{ settings.fotm_display_name | json }},
    isStaff: {{ customer.tags | join: ',' | downcase | contains: 'staff' | json }}
  };

  function isValidDate(d) {
    return d instanceof Date && !isNaN(d.getTime());
  }

  /* ── Hash Router (event-delegation, capture-phase to beat theme.js smooth-scroll) ── */
  var validRoutes = ['dashboard', 'history', 'next-shipment', 'subscription', 'orders'];

  function navigate(hash) {
    var route = (hash || '').replace(/^#/, '') || 'dashboard';
    if (validRoutes.indexOf(route) === -1) route = 'dashboard';

    var viewEls = document.querySelectorAll('[data-view]');
    var navLinkEls = document.querySelectorAll('[data-nav]');

    viewEls.forEach(function(v) {
      v.style.display = v.dataset.view === route ? '' : 'none';
    });

    navLinkEls.forEach(function(link) {
      if (link.dataset.nav === route) link.classList.add('is-active');
      else link.classList.remove('is-active');
    });

    if (location.hash.replace(/^#/, '') !== route) {
      try { history.replaceState(null, '', '#' + route); } catch(e) {}
    }

    try { window.scrollTo({ top: 0, behavior: 'smooth' }); } catch(e) { window.scrollTo(0, 0); }
  }

  // Event delegation: catch EVERY click on any in-page hash link anywhere on the page.
  // Using capture phase (third arg true) so we run BEFORE theme.js's a[href^="#"] smooth-scroll
  // handler. stopImmediatePropagation prevents theme.js from then preventDefault'ing on
  // a non-existent id selector and leaving the browser in a stuck state.
  document.addEventListener('click', function(e) {
    var a = e.target.closest ? e.target.closest('a[href^="#"]') : null;
    if (!a) return;
    var hash = a.getAttribute('href') || '';
    var route = hash.replace(/^#/, '');
    if (validRoutes.indexOf(route) === -1) return;
    e.preventDefault();
    e.stopImmediatePropagation();
    navigate(hash);
  }, true);

  window.addEventListener('hashchange', function() { navigate(location.hash); });
  navigate(location.hash);

  /* ── Fragrance History ── */
  var timelineEl = document.getElementById('fragranceTimeline');
  var timelineEmptyEl = document.getElementById('fragranceTimelineEmpty');

  // Try metafield data first, fall back to localStorage
  var historyData = null;
  {% if fh_json != blank %}
    try { historyData = {{ fh_json }}; } catch(e) {}
  {% endif %}

  if (!historyData) {
    try { historyData = JSON.parse(localStorage.getItem('bn_fragrance_history') || 'null'); } catch(e) {}
  }

  function getHistoryRatings() {
    try { return JSON.parse(localStorage.getItem('bn_history_ratings') || '{}'); } catch(e) { return {}; }
  }

  function getHistoryNotes() {
    try { return JSON.parse(localStorage.getItem('bn_history_notes') || '{}'); } catch(e) { return {}; }
  }

  function renderTimeline() {
    if (!timelineEl) return;
    if (!historyData || !historyData.length) {
      if (timelineEl) timelineEl.style.display = 'none';
      if (timelineEmptyEl) timelineEmptyEl.style.display = 'block';
      return;
    }

    if (timelineEmptyEl) timelineEmptyEl.style.display = 'none';
    timelineEl.style.display = 'block';

    var ratings = getHistoryRatings();
    var notes = getHistoryNotes();

    // Group entries by month
    var grouped = {};
    var monthOrder = [];
    historyData.forEach(function(entry, i) {
      var monthKey = entry.month || 'Month ' + (i + 1);
      if (!grouped[monthKey]) {
        grouped[monthKey] = [];
        monthOrder.push(monthKey);
      }
      grouped[monthKey].push({ entry: entry, index: i });
    });

    var html = '';
    monthOrder.forEach(function(monthKey) {
      html += '<div class="fh-month-group">';
      html += '<div class="fh-entry__dot"></div>';
      html += '<div class="fh-entry__month">' + monthKey + '</div>';

      grouped[monthKey].forEach(function(item) {
        var entry = item.entry;
        var i = item.index;
        var rating = ratings[i] || 0;
        var note = notes[i] || '';
        var stars = '';
        for (var s = 1; s <= 5; s++) {
          stars += '<svg class="fh-star' + (s <= rating ? ' is-filled' : '') + '" data-entry="' + i + '" data-star="' + s + '" viewBox="0 0 24 24" fill="' + (s <= rating ? 'currentColor' : 'none') + '" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
        }

        var notesHtml = '';
        if (entry.top_notes) notesHtml += '<strong>Top:</strong> ' + entry.top_notes + '<br>';
        if (entry.heart_notes) notesHtml += '<strong>Heart:</strong> ' + entry.heart_notes + '<br>';
        if (entry.base_notes) notesHtml += '<strong>Base:</strong> ' + entry.base_notes;

        html += '<div class="fh-entry">' +
          '<div class="fh-entry__grid">' +
            '<div class="fh-entry__image">' +
              (entry.product_image ? '<img src="' + entry.product_image + '" alt="' + entry.product_title + '" loading="lazy">' : '') +
            '</div>' +
            '<div>' +
              '<h4 class="fh-entry__name">' + (entry.product_title || 'Unknown Fragrance') + '</h4>' +
              (entry.family ? '<span class="fh-entry__family">' + entry.family + '</span>' : '') +
              (notesHtml ? '<div class="fh-entry__notes">' + notesHtml + '</div>' : '') +
              '<div class="fh-stars">' + stars + '</div>' +
              '<div class="fh-user-note">' +
                '<textarea placeholder="Add your notes..." data-note-entry="' + i + '">' + note + '</textarea>' +
                '<button data-save-note="' + i + '">Save</button>' +
              '</div>' +
              '<div class="fh-entry__actions">' +
                (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--again">Get This Again</a>' : '') +
                (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--fullsize">Buy Full Size</a>' : '') +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      });

      html += '</div>';
    });

    timelineEl.innerHTML = html;

    // Star click handlers
    timelineEl.querySelectorAll('.fh-star').forEach(function(star) {
      star.addEventListener('click', function() {
        var entryIdx = this.dataset.entry;
        var starVal = parseInt(this.dataset.star);
        var r = getHistoryRatings();
        r[entryIdx] = starVal;
        localStorage.setItem('bn_history_ratings', JSON.stringify(r));
        // TODO: Appstle API — persist rating server-side
        renderTimeline();
      });
    });

    // Note save handlers
    timelineEl.querySelectorAll('[data-save-note]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = this.dataset.saveNote;
        var textarea = timelineEl.querySelector('[data-note-entry="' + idx + '"]');
        if (textarea) {
          var n = getHistoryNotes();
          n[idx] = textarea.value;
          localStorage.setItem('bn_history_notes', JSON.stringify(n));
          // TODO: Appstle API — persist notes server-side
          btn.textContent = 'Saved!';
          setTimeout(function() { btn.textContent = 'Save'; }, 1500);
        }
      });
    });
  }

  renderTimeline();


  /* ── Next Shipment ── */
  var nsStatusBadge = document.getElementById('nsStatusBadge');
  var nsSelected = document.getElementById('nsSelected');
  var nsChoose = document.getElementById('nsChoose');
  var nsSkipped = document.getElementById('nsSkipped');
  var nsImage = document.getElementById('nsImage');
  var nsName = document.getElementById('nsName');
  var nsFamily = document.getElementById('nsFamily');

  function getNextShipment() {
    try { return JSON.parse(localStorage.getItem('bn_next_shipment') || 'null'); } catch(e) { return null; }
  }

  function saveNextShipment(data) {
    localStorage.setItem('bn_next_shipment', JSON.stringify(data));
    // TODO: Appstle API — update next shipment server-side
    renderNextShipment();
  }

  function renderNextShipment() {
    if (!nsStatusBadge) return;
    var data = getNextShipment();

    if (data && data.status === 'skipped') {
      nsStatusBadge.textContent = 'Skipped';
      nsStatusBadge.className = 'ns-status-badge ns-skipped';
      if (nsSelected) nsSelected.style.display = 'none';
      if (nsChoose) nsChoose.style.display = 'none';
      if (nsSkipped) nsSkipped.style.display = 'block';
      return;
    }

    if (data && data.fragrance) {
      var isAuto = data.autoSelected;
      var badgeText = 'Confirmed';
      var badgeClass = 'ns-confirmed';
      if (isAuto && data.source === 'fotm') {
        badgeText = 'Curated Pick';
        badgeClass = 'ns-auto';
      } else if (isAuto) {
        badgeText = 'Auto-Selected';
        badgeClass = 'ns-auto';
      }
      nsStatusBadge.textContent = badgeText;
      nsStatusBadge.className = 'ns-status-badge ' + badgeClass;
      if (nsSelected) {
        nsSelected.style.display = 'block';
        if (nsImage) nsImage.innerHTML = data.fragrance.image ? '<img src="' + data.fragrance.image + '" alt="' + data.fragrance.title + '" style="width:100%;height:100%;object-fit:cover;border-radius:10px;">' : '';
        if (nsName) nsName.textContent = data.fragrance.title;
        if (nsFamily) nsFamily.textContent = data.fragrance.family || '';
      }
      if (nsChoose) nsChoose.style.display = 'none';
      if (nsSkipped) nsSkipped.style.display = 'none';

      // Also update dashboard preview
      var dashPreview = document.getElementById('dashShipmentPreview');
      if (dashPreview) {
        dashPreview.innerHTML = '<div style="display:flex;align-items:center;gap:16px;padding:8px;">' +
          (data.fragrance.image ? '<img src="' + data.fragrance.image + '" style="width:60px;height:60px;border-radius:8px;object-fit:cover;">' : '') +
          '<div><strong style="color:#2D4641;">' + data.fragrance.title + '</strong>' +
          '<br><span style="font-size:12px;color:#C9A962;">' + (data.fragrance.family || '') + '</span></div></div>';
      }
    } else if (serverSubData.productTitle && serverSubData.orderFulfilled !== 'fulfilled') {
      // Default to the subscription product from order history (only if not yet fulfilled)
      nsStatusBadge.textContent = 'Confirmed';
      nsStatusBadge.className = 'ns-status-badge ns-confirmed';
      if (nsSelected) {
        nsSelected.style.display = 'block';
        if (nsImage && serverSubData.productImage) nsImage.innerHTML = '<img src="' + serverSubData.productImage + '" alt="' + serverSubData.productTitle + '" style="width:100%;height:100%;object-fit:cover;border-radius:10px;">';
        if (nsName) nsName.textContent = serverSubData.productTitle;
        if (nsFamily) nsFamily.textContent = serverSubData.productVendor || '';
      }
      if (nsChoose) nsChoose.style.display = 'none';
      if (nsSkipped) nsSkipped.style.display = 'none';
    } else {
      nsStatusBadge.textContent = 'Action Needed';
      nsStatusBadge.className = 'ns-status-badge ns-action';
      if (nsSelected) nsSelected.style.display = 'none';
      if (nsChoose) nsChoose.style.display = 'block';
      if (nsSkipped) nsSkipped.style.display = 'none';
    }

    // PRD-APR23v2 Issue D: Do NOT guess the next ship date from order anniversary — it was showing
    // "Apr 7" to users whose real Appstle ship date was May 21. Let the Appstle fetch below
    // populate #statNextShipment and #nsShipDays with authoritative values. If Appstle is
    // unavailable, these stay at their default "—" placeholder, which is honest.
  }

  renderNextShipment();

  /* ── Auto-Selection Logic ── */
  function autoSelectFragrance() {
    if (!serverSubData.isSubscriber) return;

    // Skip if user already chose or skipped
    var existing = null;
    try { existing = JSON.parse(localStorage.getItem('bn_next_shipment') || 'null'); } catch(e) {}
    if (existing && (existing.fragrance || existing.status === 'skipped')) return;

    // Only auto-select within 3 days of billing
    var nextBill = getNextBillingDate();
    var now = new Date();
    var daysUntilBill = Math.ceil((nextBill - now) / 86400000);
    if (daysUntilBill > 3) return;

    // Priority 1: Rotation queue
    var queue = [];
    try { queue = JSON.parse(localStorage.getItem('basenotes_queue') || '[]'); } catch(e) {}
    if (queue.length > 0) {
      var nextItem = queue.shift();
      localStorage.setItem('basenotes_queue', JSON.stringify(queue));
      var selection = {
        fragrance: {
          title: nextItem.title || nextItem.name,
          image: nextItem.image || nextItem.featured_image,
          family: nextItem.vendor || nextItem.family || '',
          handle: nextItem.handle || ''
        },
        autoSelected: true,
        source: 'queue',
        timestamp: new Date().toISOString()
      };
      localStorage.setItem('bn_next_shipment', JSON.stringify(selection));
      renderNextShipment();
      var queueCountEl = document.querySelector('[data-queue-count]');
      if (queueCountEl) queueCountEl.textContent = queue.length;
      return;
    }

    // Priority 2: Fragrance of the Month
    var currentMonth = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
    if (serverSubData.fotmEnabled && serverSubData.fotmProduct && serverSubData.fotmMonth === currentMonth) {
      var fotm = serverSubData.fotmProduct;
      var selection = {
        fragrance: {
          title: serverSubData.fotmDisplayName || fotm.title,
          image: fotm.image,
          family: fotm.vendor || '',
          handle: fotm.handle || ''
        },
        autoSelected: true,
        source: 'fotm',
        timestamp: new Date().toISOString()
      };
      localStorage.setItem('bn_next_shipment', JSON.stringify(selection));
      renderNextShipment();
      return;
    }

    // Priority 3: Safety net — first product from fragrances collection
    fetch('/collections/fragrances/products.json?limit=1')
      .then(function(r) { return r.ok ? r.json() : Promise.reject('no-collection'); })
      .then(function(data) {
        if (!data.products || !data.products.length) return;
        var prod = data.products[0];
        var selection = {
          fragrance: {
            title: prod.title,
            image: prod.images && prod.images.length ? prod.images[0].src : '',
            family: prod.vendor || '',
            handle: prod.handle || ''
          },
          autoSelected: true,
          source: 'popular',
          timestamp: new Date().toISOString()
        };
        localStorage.setItem('bn_next_shipment', JSON.stringify(selection));
        renderNextShipment();
      })
      .catch(function() {});
  }

  autoSelectFragrance();

  /* ── Staff FOTM Warning ── */
  (function checkFotmStaleness() {
    if (!serverSubData.isStaff) return;
    var now = new Date();
    var currentMonth = now.getFullYear() + '-' + String(now.getMonth() + 1).padStart(2, '0');
    var monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];

    if (!serverSubData.fotmMonth || serverSubData.fotmMonth !== currentMonth) {
      var warningEl = document.getElementById('staffFotmWarning');
      var monthEl = document.getElementById('staffFotmMonth');
      if (warningEl) {
        warningEl.style.display = 'block';
        if (monthEl) monthEl.textContent = monthNames[now.getMonth()] + ' ' + now.getFullYear();
      }
    }
  })();

  /* ── Billing Countdown ── */
  function getNextBillingDate() {
    var now = new Date();
    var nextBill = null;

    // Try 1: localStorage (set during checkout on this device)
    try {
      var subData = JSON.parse(localStorage.getItem('bn_active_subscription') || 'null');
      if (subData && subData.nextBillDate) {
        var d = new Date(subData.nextBillDate);
        if (isValidDate(d)) nextBill = d;
      }
    } catch(e) {}

    // Try 2: Anniversary billing from server order date
    if (!nextBill && serverSubData.orderDate) {
      var orderDate = new Date(serverSubData.orderDate);
      if (isValidDate(orderDate)) {
        var billingDay = orderDate.getDate();
        nextBill = new Date(now.getFullYear(), now.getMonth(), billingDay);
      }
    }

    // Try 3: Fallback to first of next month
    if (!nextBill) {
      nextBill = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    }

    // Advance to future if in the past
    while (nextBill <= now) {
      nextBill.setMonth(nextBill.getMonth() + 1);
    }

    return nextBill;
  }

  function renderBillingCountdown() {
    var countdownEl = document.getElementById('billingCountdown');
    if (!countdownEl) return;

    var now = new Date();
    var nextBill = getNextBillingDate();

    // Days remaining
    var msPerDay = 86400000;
    var daysLeft = Math.max(0, Math.ceil((nextBill - now) / msPerDay));

    // Progress bar (30-day cycle)
    var cycleDays = 30;
    var elapsed = cycleDays - daysLeft;
    var pct = Math.min(100, Math.max(0, (elapsed / cycleDays) * 100));

    // Update DOM
    var daysEl = document.getElementById('billingDaysLeft');
    var barEl = document.getElementById('billingBar');
    var dateTextEl = document.getElementById('billingDateText');
    var cancelDeadlineEl = document.getElementById('cancelDeadline');

    if (daysEl) daysEl.textContent = daysLeft + ' day' + (daysLeft !== 1 ? 's' : '');
    if (barEl) barEl.style.width = pct + '%';

    var dateOpts = { month: 'long', day: 'numeric', year: 'numeric' };
    if (dateTextEl) dateTextEl.textContent = 'Next charge on ' + nextBill.toLocaleDateString('en-US', dateOpts);

    // Cancel deadline = 1 day before billing
    var cancelDate = new Date(nextBill);
    cancelDate.setDate(cancelDate.getDate() - 1);
    if (cancelDeadlineEl) cancelDeadlineEl.textContent = cancelDate.toLocaleDateString('en-US', dateOpts);

    // Also update the plan details billing field
    var subBillingEl = document.getElementById('subNextBilling');
    if (subBillingEl) subBillingEl.textContent = nextBill.toLocaleDateString('en-US', dateOpts);
  }

