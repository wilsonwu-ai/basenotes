  .acct__card-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.25rem; font-weight: 600; color: #2D4641; margin: 0; }
  .acct__text-link { color: #C9A962; font-size: 13px; font-weight: 600; text-decoration: none; }
