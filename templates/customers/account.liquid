        '<div class="fm-month-card__label">Shipment</div>' +
        '<div class="fm-month-card__month">' + month.label + '</div>' +
        '<div class="fm-month-card__status' + (hasSelection ? ' has-selection' : '') + '">' +
        (hasSelection ? '✓ Selected' : 'Not selected') +
        '</div>';
      if (hasSelection) {
        html += '<div class="fm-month-card__frag">' +
          (selection.image ? '<img class="fm-month-card__frag-img" src="' + selection.image + '">' : '') +
