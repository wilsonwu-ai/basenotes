  // ═══ Dashboard Fragrance Journey + Queue preview (PRD-05) ═══
  initFragranceJourney();
  initDashboardQueuePreview();

  function initFragranceJourney() {
    var el = document.getElementById('fragranceJourney');
    if (!el) return;

    // Wait for BasenoteQueue
    function whenReady(cb, tries) {
      tries = tries || 0;
      if (window.BasenoteQueue) return cb();
      if (tries > 40) return;
      setTimeout(function(){ whenReady(cb, tries + 1); }, 50);
    }
    whenReady(function() {
      var BQ = window.BasenoteQueue;

      // Past shipped orders from customer.orders — only fulfilled subscription orders
      var pastOrders = [];
      {%- if is_subscriber -%}
        {%- for order in customer.orders reversed limit: 12 -%}
          {%- if order.fulfillment_status == 'fulfilled' -%}
            {%- for line in order.line_items -%}
              {%- if line.selling_plan_allocation -%}
                pastOrders.push({
                  shipMonth: {{ order.created_at | date: '%Y-%m' | json }},
                  title: {{ line.product.title | json }},
                  image: {%- if line.image -%}{{ line.image | image_url: width: 120 | json }}{%- else -%}null{%- endif -%}
                });
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}

      // De-dup past by month (most recent wins), cap at last 4 for timeline fit
      var pastByMonth = {};
      pastOrders.forEach(function(p){ pastByMonth[p.shipMonth] = p; });
      var pastMonths = Object.keys(pastByMonth).sort().slice(-4);

      // The "Current" stop = the first month the queue considers visible (the next shipment month).
      // This is what's actively in-flight, not a generic future slot.
      var currentStopMonth = BQ.firstVisibleMonth();
      // Don't duplicate if last past month IS the current stop month (unlikely but guard it)
      if (pastMonths[pastMonths.length - 1] === currentStopMonth) {
        pastMonths = pastMonths.slice(0, -1);
      }

      var filled = BQ.load();
      var filledByMonth = {};
      filled.forEach(function(e){ filledByMonth[e.shipMonth] = e; });

      el.innerHTML = '';

      function appendStop(monthStr, data, kind) {
        var stop = document.createElement('div');
        stop.className = 'fj-stop fj-stop--' + kind;
        stop.setAttribute('role', 'listitem');
        var inner = '<div class="fj-stop__dot">';
        if (data && data.image) inner += '<img src="' + data.image + '" alt="" loading="lazy">';
        else inner += '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="22" height="22"><path d="M9 2h6v4h-6z"/><path d="M7 6h10v16H7z"/></svg>';
        inner += '</div>';
        var label;
        if (kind === 'current') {
          label = 'Current · ' + BQ.monthLabel(monthStr, { short: true });
        } else {
          label = BQ.monthLabel(monthStr, { short: true });
        }
        inner += '<div class="fj-stop__month">' + label + '</div>';
        inner += '<div class="fj-stop__label">' + (data && data.title ? escapeText(data.title) : 'To be picked') + '</div>';
        stop.innerHTML = inner;
        el.appendChild(stop);
      }

      pastMonths.forEach(function(m){ appendStop(m, pastByMonth[m], 'past'); });
      appendStop(currentStopMonth, filledByMonth[currentStopMonth] || null, 'current');

      function escapeText(s) {
        var div = document.createElement('div');
        div.textContent = String(s || '');
        return div.innerHTML;
      }

      BQ.on('change', function() { initFragranceJourney(); });
    });
  }

  function initDashboardQueuePreview() {
    var el = document.getElementById('dashQueuePreview');
    if (!el) return;

    function whenReady(cb, tries) {
      tries = tries || 0;
      if (window.BasenoteQueue) return cb();
      if (tries > 40) return;
      setTimeout(function(){ whenReady(cb, tries + 1); }, 50);
    }
    whenReady(function() {
      var BQ = window.BasenoteQueue;
      function render() {
        var months = BQ.slotsFromNow(3);
        var filled = BQ.load();
        var byMonth = {};
        filled.forEach(function(e){ byMonth[e.shipMonth] = e; });
        var anyFilled = months.some(function(m){ return !!byMonth[m]; });

        if (!anyFilled) {
          el.innerHTML = '<div class="dash-qp-empty-wrap">' +
            '<p>No fragrances queued yet.</p>' +
            '<a href="#next-shipment">Plan your next 3 months →</a>' +
            '</div>';
          return;
        }

        el.innerHTML = '';
        months.forEach(function(monthStr) {
          var entry = byMonth[monthStr];
          var row = document.createElement('a');
          row.href = '#next-shipment';
          row.className = entry ? 'dash-qp-row' : 'dash-qp-row dash-qp-row--empty';
          var img = entry && entry.image
            ? '<img class="dash-qp-row__img" src="' + entry.image + '" alt="" loading="lazy">'
            : '<span class="dash-qp-row__img"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></span>';
          var title = entry ? (function(s){ var d=document.createElement('div'); d.textContent=s; return d.innerHTML; })(entry.title) : 'Pick a fragrance';
          row.innerHTML = img +
            '<div class="dash-qp-row__info">' +
              '<div class="dash-qp-row__month">' + BQ.monthLabel(monthStr, { withYear: true }) + '</div>' +
              '<div class="dash-qp-row__title">' + title + '</div>' +
            '</div>' +
            '<svg class="dash-qp-row__chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="9 18 15 12 9 6"/></svg>';
          el.appendChild(row);
        });
      }
      render();
      BQ.on('change', function() { render(); });
    });
  }

  // ═══ My Subscription List — Scentbird-style queue (PRD-01) ═══
  initSubscriptionQueue();

  function initSubscriptionQueue() {
    var strip = document.getElementById('bqStrip');
    var badge = document.getElementById('bqCountBadge');
    if (!strip) return;

    // Wait for BasenoteQueue module (loaded async via asset_url + defer)
    function whenReady(cb, tries) {
      tries = tries || 0;
      if (window.BasenoteQueue) return cb();
      if (tries > 40) return;
      setTimeout(function(){ whenReady(cb, tries + 1); }, 50);
    }

    whenReady(function() {
      var SLOT_COUNT = 5;
      var BQ = window.BasenoteQueue;

      // PRD-APR23v2 Issue B: tell the scheduler what the customer has already received
      // so the queue's first slot is the next UN-shipped month (not calendar current).
      {%- if latest_shipped_sub_order -%}
        BQ.setShippedThrough({{ latest_shipped_sub_order.created_at | date: '%Y-%m' | json }});
      {%- endif -%}

      function render() {
        var months = BQ.slotsFromNow(SLOT_COUNT);
        var filled = BQ.load();
        var byMonth = {};
        filled.forEach(function(e){ byMonth[e.shipMonth] = e; });

        strip.innerHTML = '';
        months.forEach(function(monthStr, idx) {
          var entry = byMonth[monthStr];
          var card;
          if (entry) card = buildFilledCard(monthStr, entry, idx);
          else card = buildEmptyCard(monthStr, idx);
          strip.appendChild(card);
        });

        if (badge) {
          var pickedCount = Math.min(filled.length, SLOT_COUNT);
          badge.textContent = pickedCount + ' of ' + SLOT_COUNT + ' picked';
        }

        initSortable();
      }

      function buildFilledCard(monthStr, entry, idx) {
        var card = document.createElement('article');
        card.className = 'bq-card';
        card.setAttribute('data-month', monthStr);
        card.setAttribute('data-position', String(idx));
        card.setAttribute('role', 'listitem');

        // "Ships Immediately" only if the slot is the calendar current month AND it's the first visible slot.
        var isImmediate = idx === 0 && monthStr === BQ.currentMonth();
        var shipStatus = isImmediate ? 'Ships Immediately' : 'Ships in ' + BQ.monthLabel(monthStr, { short: true });
        var statusClass = isImmediate ? 'bq-card__ship-status--immediate' : '';

        card.innerHTML =
          '<button type="button" class="bq-card__drag-handle" aria-label="Drag to reorder">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">' +
              '<circle cx="9" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="18" r="1"/>' +
              '<circle cx="15" cy="6" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="18" r="1"/>' +
            '</svg>' +
          '</button>' +
          '<button type="button" class="bq-card__remove" aria-label="Remove ' + escapeHtml(entry.title || 'fragrance') + ' from ' + BQ.monthLabel(monthStr) + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="12" height="12" aria-hidden="true">' +
              '<line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>' +
            '</svg>' +
          '</button>' +
          '<a href="' + escapeAttr(entry.url || '#') + '" class="bq-card__image" aria-label="View ' + escapeAttr(entry.title || '') + '">' +
            (entry.image ? '<img src="' + escapeAttr(entry.image) + '" alt="' + escapeAttr(entry.title || '') + '" loading="lazy">' : '') +
          '</a>' +
          '<div>' +
            '<h4 class="bq-card__title">' + escapeHtml(entry.title || '—') + '</h4>' +
            (entry.family ? '<p class="bq-card__family">' + escapeHtml(entry.family) + '</p>' : '') +
          '</div>' +
          '<p class="bq-card__month-label">' +
            '<span class="bq-card__month">' + escapeHtml(BQ.monthLabel(monthStr, { withYear: true })) + '</span>' +
            '<span class="bq-card__ship-status ' + statusClass + '">' + shipStatus + '</span>' +
          '</p>' +
          '<button type="button" class="bq-card__swap" data-queue-swap-month="' + escapeAttr(monthStr) + '">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12" aria-hidden="true">' +
              '<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>' +
            '</svg>' +
            'Swap' +
          '</button>';

        var removeBtn = card.querySelector('.bq-card__remove');
        removeBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          BQ.clearSlot(monthStr);
          render();
        });

        var swapBtn = card.querySelector('.bq-card__swap');
        swapBtn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          window.__bqPendingTargetMonth = monthStr;
          document.dispatchEvent(new Event('fragrance-selector:open'));
        });

        return card;
      }

      function buildEmptyCard(monthStr, idx) {
        var card = document.createElement('article');
        card.className = 'bq-card bq-card--empty';
        card.setAttribute('data-month', monthStr);
        card.setAttribute('data-position', String(idx));
        card.setAttribute('role', 'listitem');
        card.innerHTML =
          '<button type="button" class="bq-card__drag-handle" aria-label="Drag to reorder" disabled>' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" aria-hidden="true">' +
              '<circle cx="9" cy="6" r="1"/><circle cx="9" cy="12" r="1"/><circle cx="9" cy="18" r="1"/>' +
              '<circle cx="15" cy="6" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="18" r="1"/>' +
            '</svg>' +
          '</button>' +
          '<div class="bq-card__empty-slot">' +
            '<button type="button" class="bq-card__empty-link" data-queue-pick-month="' + escapeAttr(monthStr) + '">' +
              '<div class="bq-card__plus" aria-hidden="true">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="28" height="28">' +
                  '<line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>' +
                '</svg>' +
              '</div>' +
              '<p class="bq-card__empty-title">Pick Your Next Scent</p>' +
              '<p class="bq-card__empty-sub">Empty on ship day → we send our Fragrance of the Month.</p>' +
            '</button>' +
          '</div>' +
          '<p class="bq-card__month-label">' +
            '<span class="bq-card__month">' + escapeHtml(BQ.monthLabel(monthStr, { withYear: true })) + '</span>' +
            '<span class="bq-card__ship-status">Select fragrance</span>' +
          '</p>';
        // Open the in-page fragrance selector modal with queue-target context
        var pickBtn = card.querySelector('[data-queue-pick-month]');
        pickBtn.addEventListener('click', function() {
          window.__bqPendingTargetMonth = monthStr;
          document.dispatchEvent(new Event('fragrance-selector:open'));
        });
        return card;
      }

      function initSortable() {
        if (typeof window.Sortable === 'undefined') return;
        if (strip.__sortable) { strip.__sortable.destroy(); }
        strip.__sortable = window.Sortable.create(strip, {
          animation: 180,
          handle: '.bq-card__drag-handle',
          draggable: '.bq-card',
          filter: '.bq-card__drag-handle[disabled]',
          preventOnFilter: false,
          ghostClass: 'is-ghost',
          dragClass: 'is-dragging',
          onEnd: function(evt) {
            // Determine the old + new month slots from the DOM ordering
            var months = BQ.slotsFromNow(SLOT_COUNT);
            var cards = Array.prototype.slice.call(strip.querySelectorAll('.bq-card'));
            // cards are now in visual order; map each card's CURRENT data-month to the month it's visually in
            var updates = [];
            cards.forEach(function(card, visualIdx) {
              var originalMonth = card.getAttribute('data-month');
              var targetMonth = months[visualIdx];
              if (originalMonth !== targetMonth) {
                updates.push({ from: originalMonth, to: targetMonth });
              }
            });
            // Apply updates all at once by rewriting the queue array based on the new visual order
            var filled = BQ.load();
            var byMonth = {};
            filled.forEach(function(e){ byMonth[e.shipMonth] = e; });
            var newQueue = [];
            cards.forEach(function(card, visualIdx) {
              var originalMonth = card.getAttribute('data-month');
              var entry = byMonth[originalMonth];
              if (entry) {
                newQueue.push(Object.assign({}, entry, { shipMonth: months[visualIdx] }));
              }
            });
            BQ.save(newQueue);
            render();
          }
        });
      }

      function escapeHtml(s) {
        return String(s || '').replace(/[&<>"']/g, function(c){
          return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c];
        });
      }
      function escapeAttr(s) { return escapeHtml(s); }

      // Subscribe to queue changes (other tabs / PDP → queue_target_month → back here)
      BQ.on('change', function() { render(); });
      window.addEventListener('storage', function(e){
        if (e.key === 'basenotes_queue') render();
      });

      render();
    });
  }
});
</script>
