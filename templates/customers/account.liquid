      try {
        var res = await fetch(
          '/apps/subscriptions/cp/api/subscription-contracts-update-payment-method?contractId=' + encodeURIComponent(contractId),
          { method: 'PUT', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' }, body: '{}' }
        );
