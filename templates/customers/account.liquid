    customerEmail: {{ customer.email | json }},
    customerId: {{ customer.id | json }},
    isSubscriberFromLiquid: {{ is_subscriber | json }},
    portalUrl: {{ settings.appstle_portal_url | default: '/apps/subscriptions' | json }},
    fotmEnabled: {{ settings.fotm_enabled | default: false | json }},
    fotmMonth: {{ settings.fotm_month | json }},
    {%- if settings.fotm_product -%}
    fotmProduct: {
      title: {{ settings.fotm_product.title | json }},
      image: {{ settings.fotm_product.featured_image | image_url: width: 200 | json }},
      vendor: {{ settings.fotm_product.vendor | json }},
      handle: {{ settings.fotm_product.handle | json }},
      variantId: {{ settings.fotm_product.selected_or_first_available_variant.id | json }}
    },
    {%- else -%}
    fotmProduct: null,
    {%- endif -%}
    isStaff: {{ customer.tags | join: ',' | downcase | contains: 'staff' | json }},
    monthNames: ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']
  };
  // ══════════════════════════════════════════
  // STATE
  // ══════════════════════════════════════════
  var state = {
    subscription: null,
    contracts: [],
    activeContract: null,
    isLoading: true,
    error: null,
    fragranceHistory: [],
    futureQueue: {}, // { 'YYYY-MM': { productId, title, image, handle, vendor } }
    nextShipment: null
  };
  // ══════════════════════════════════════════
  // UTILITIES
  // ══════════════════════════════════════════
  function $(selector) {
    return document.querySelector(selector);
  }
  function $$(selector) {
    return document.querySelectorAll(selector);
  }
  function isValidDate(d) {
    return d instanceof Date && !isNaN(d.getTime());
  }
  function formatDate(date, format) {
    if (!isValidDate(date)) return '—';
    var opts = format === 'short' 
      ? { month: 'short', day: 'numeric' }
      : { month: 'long', day: 'numeric', year: 'numeric' };
    return date.toLocaleDateString('en-US', opts);
  }
  function getMonthKey(date) {
    return date.getFullYear() + '-' + String(date.getMonth() + 1).padStart(2, '0');
  }
  function getMonthLabel(monthKey) {
    var parts = monthKey.split('-');
    var monthIndex = parseInt(parts[1], 10) - 1;
    return CONFIG.monthNames[monthIndex] + ' ' + parts[0];
  }
  function showError(message) {
    var banner = $('#apiErrorBanner');
    var msgEl = $('#apiErrorMessage');
    if (banner && msgEl) {
      msgEl.textContent = message;
      banner.style.display = 'block';
    }
    state.error = message;
  }
  function hideError() {
    var banner = $('#apiErrorBanner');
    if (banner) banner.style.display = 'none';
    state.error = null;
  }
  function showLoader() {
    var loader = $('#globalLoader');
    if (loader) loader.style.display = 'block';
  }
  function hideLoader() {
    var loader = $('#globalLoader');
    if (loader) loader.style.display = 'none';
  }
  // ══════════════════════════════════════════
  // LOCAL STORAGE
  // ══════════════════════════════════════════
  var Storage = {
    prefix: 'bn_',
    get: function(key) {
      try {
        var data = localStorage.getItem(this.prefix + key);
        return data ? JSON.parse(data) : null;
      } catch (e) {
        return null;
      }
    },
    set: function(key, value) {
      try {
        localStorage.setItem(this.prefix + key, JSON.stringify(value));
      } catch (e) {}
    },
    remove: function(key) {
      try {
        localStorage.removeItem(this.prefix + key);
      } catch (e) {}
    }
  };
  // ══════════════════════════════════════════
  // APPSTLE API SERVICE
  // ══════════════════════════════════════════
  var AppstleAPI = {
    /**
     * Fetch with error handling
     */
    fetch: async function(endpoint, options) {
      options = options || {};
      options.credentials = 'same-origin';
      options.headers = options.headers || {};
      options.headers['Content-Type'] = 'application/json';
      var response = await fetch(CONFIG.appstleApiBase + endpoint, options);
      
      if (!response.ok) {
        throw new Error('API Error: ' + response.status);
      }
      var text = await response.text();
      return text ? JSON.parse(text) : null;
    },
    /**
     * Get logged-in customer ID from Appstle
     */
    getCustomerId: async function() {
      return await this.fetch('/logged-in-customer');
    },
    /**
     * Get all subscription contracts for a customer
     */
    getContracts: async function(appstleCustomerId) {
      var data = await this.fetch('/subscription-customers-detail/valid/' + appstleCustomerId);
      return Array.isArray(data) ? data : [];
    },
    /**
     * Get contract details
     */
    getContractDetails: async function(contractId) {
      return await this.fetch('/subscription-contracts/' + contractId);
    },
    /**
     * Get order history for a contract
     */
    getOrderHistory: async function(contractId) {
      return await this.fetch('/subscription-contracts/' + contractId + '/orders');
    },
    /**
     * Skip next order
     */
    skipNextOrder: async function(contractId) {
      return await this.fetch('/subscription-contracts/' + contractId + '/skip-next-order', {
        method: 'POST'
      });
    },
    /**
     * Unskip order
     */
    unskipOrder: async function(contractId, billingAttemptId) {
      return await this.fetch('/subscription-contracts/' + contractId + '/unskip/' + billingAttemptId, {
        method: 'POST'
      });
    },
    /**
     * Pause subscription
     */
    pauseSubscription: async function(contractId) {
      return await this.fetch('/subscription-contracts/' + contractId + '/pause', {
        method: 'POST'
      });
    },
    /**
     * Resume subscription
     */
    resumeSubscription: async function(contractId) {
      return await this.fetch('/subscription-contracts/' + contractId + '/activate', {
        method: 'POST'
      });
    },
    /**
     * Update payment method (sends email)
     */
    updatePaymentMethod: async function(contractId) {
      return await this.fetch('/subscription-contracts-update-payment-method?contractId=' + contractId, {
        method: 'PUT',
        body: '{}'
      });
    },
    /**
     * Update line item (swap product)
     */
    updateLineItem: async function(contractId, lineId, variantId, sellingPlanId) {
      var body = {
        variantId: variantId
      };
      if (sellingPlanId) {
        body.sellingPlanId = sellingPlanId;
      }
      return await this.fetch('/subscription-contracts/' + contractId + '/lines/' + lineId, {
        method: 'PATCH',
        body: JSON.stringify(body)
      });
    },
    /**
     * Get customer metafields (for fragrance history)
     */
    getCustomerMetafields: async function(appstleCustomerId) {
      return await this.fetch('/subscription-customers/' + appstleCustomerId + '/metafields');
    },
    /**
     * Update customer metafield
     */
    updateCustomerMetafield: async function(appstleCustomerId, namespace, key, value, type) {
      return await this.fetch('/subscription-customers/' + appstleCustomerId + '/metafields', {
        method: 'POST',
        body: JSON.stringify({
          namespace: namespace,
          key: key,
          value: JSON.stringify(value),
          type: type || 'json'
        })
      });
    },
    /**
     * Refresh all data
     */
    refresh: async function() {
      hideError();
      showLoader();
      try {
        await loadSubscriptionData();
        renderAll();
      } catch (e) {
        showError('Failed to refresh data. Please try again.');
      } finally {
        hideLoader();
      }
    }
  };
  // Expose for retry button
  window.AppstleAPI = AppstleAPI;
  // ══════════════════════════════════════════
  // DATA LOADING
  // ══════════════════════════════════════════
  async function loadSubscriptionData() {
    state.isLoading = true;
    try {
      // Step 1: Get Appstle customer ID
      var appstleCustomerId = await AppstleAPI.getCustomerId();
      
      if (!appstleCustomerId) {
        // Customer not logged in to Appstle portal
        state.isLoading = false;
        return;
      }
      // Step 2: Get all contracts
      var contracts = await AppstleAPI.getContracts(appstleCustomerId);
      state.contracts = contracts;
      // Find active contract
      state.activeContract = contracts.find(function(c) {
        return c.status === 'ACTIVE';
      }) || contracts[0] || null;
      if (state.activeContract) {
        // Store contract info
        state.subscription = {
          id: state.activeContract.id,
          contractId: state.activeContract.subscriptionContractId || state.activeContract.contractId || state.activeContract.id,
          status: state.activeContract.status,
          nextBillingDate: parseNextDate(state.activeContract),
          nextOrderDate: parseNextOrderDate(state.activeContract),
          plan: extractPlanInfo(state.activeContract),
          lines: state.activeContract.lines || state.activeContract.lineItems || [],
          paymentMethod: extractPaymentMethod(state.activeContract),
          shippingAddress: extractShippingAddress(state.activeContract),
          appstleCustomerId: appstleCustomerId
        };
      }
      // Load fragrance history from metafields or localStorage
      await loadFragranceHistory(appstleCustomerId);
      // Load future queue from localStorage (or Appstle metafields in future)
      loadFutureQueue();
      // Load next shipment state
      loadNextShipmentState();
    } catch (e) {
      console.error('Error loading subscription data:', e);
      showError('Unable to load subscription data. Some features may be limited.');
    }
    state.isLoading = false;
  }
  function parseNextDate(contract) {
    var dateFields = [
      'nextOrderDate', 'nextOrderDateLocal',
      'nextBillingDate', 'nextBillingDateLocal',
      'billingDate', 'nextDeliveryDate'
    ];
    
    for (var i = 0; i < dateFields.length; i++) {
      var val = contract[dateFields[i]];
      if (val) {
        var d = new Date(val);
        if (isValidDate(d)) return d;
      }
    }
    
    // Fallback: first of next month
    var now = new Date();
    return new Date(now.getFullYear(), now.getMonth() + 1, 1);
  }
  function parseNextOrderDate(contract) {
    var val = contract.nextOrderDate || contract.nextOrderDateLocal;
    if (val) {
      var d = new Date(val);
      if (isValidDate(d)) return d;
    }
    return parseNextDate(contract);
  }
  function extractPlanInfo(contract) {
    var interval = contract.billingIntervalCount || 1;
    var unit = contract.billingInterval || 'MONTH';
    var price = contract.totalPrice || contract.price || 20;
    
    var planName = 'Monthly';
    if (unit === 'MONTH' && interval === 1) planName = 'Monthly';
    else if (unit === 'MONTH' && interval === 3) planName = 'Quarterly';
    else if (unit === 'YEAR' && interval === 1) planName = 'Annual';
    
    return {
      name: planName,
      interval: interval,
      unit: unit,
      price: price,
      priceFormatted: '$' + (price / 100).toFixed(2) + '/mo'
    };
  }
  function extractPaymentMethod(contract) {
    var pm = contract.paymentMethod || contract.paymentDetails || {};
    var brand = pm.brand || pm.cardBrand || '';
    var last4 = pm.last4 || pm.lastFourDigits || '';
    
    if (brand && last4) {
      return brand.charAt(0).toUpperCase() + brand.slice(1) + ' •••• ' + last4;
    }
    return '•••• •••• •••• ——';
  }
  function extractShippingAddress(contract) {
    var addr = contract.shippingAddress || contract.deliveryAddress || {};
    var parts = [];
    if (addr.address1) parts.push(addr.address1);
    if (addr.city) parts.push(addr.city);
    if (addr.provinceCode || addr.province) parts.push(addr.provinceCode || addr.province);
    return parts.length > 0 ? parts.join(', ') : 'Not set';
  }
  async function loadFragranceHistory(appstleCustomerId) {
    // Try Appstle metafields first
    try {
      var metafields = await AppstleAPI.getCustomerMetafields(appstleCustomerId);
      var historyMeta = metafields && metafields.find(function(m) {
        return m.namespace === 'subscription' && m.key === 'fragrance_history';
      });
      
      if (historyMeta && historyMeta.value) {
        state.fragranceHistory = JSON.parse(historyMeta.value);
        return;
      }
    } catch (e) {}
    // Fallback to localStorage
    state.fragranceHistory = Storage.get('fragrance_history') || [];
  }
  function loadFutureQueue() {
    state.futureQueue = Storage.get('future_queue') || {};
  }
  function saveFutureQueue() {
    Storage.set('future_queue', state.futureQueue);
    // TODO: Persist to Appstle metafields for cross-device sync
  }
  function loadNextShipmentState() {
    state.nextShipment = Storage.get('next_shipment');
  }
  function saveNextShipmentState() {
    Storage.set('next_shipment', state.nextShipment);
  }
  // ══════════════════════════════════════════
  // HASH ROUTER
  // ══════════════════════════════════════════
  var validRoutes = ['dashboard', 'history', 'next-shipment', 'future-months', 'subscription', 'orders'];
  function navigate(hash) {
    var route = (hash || '').replace('#', '') || 'dashboard';
    if (validRoutes.indexOf(route) === -1) route = 'dashboard';
    $$('[data-view]').forEach(function(v) {
      v.style.display = v.dataset.view === route ? '' : 'none';
    });
    $$('[data-nav]').forEach(function(link) {
      link.classList.toggle('is-active', link.dataset.nav === route);
    });
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  window.addEventListener('hashchange', function() {
    navigate(location.hash);
  });
  // ══════════════════════════════════════════
  // RENDER FUNCTIONS
  // ══════════════════════════════════════════
  function renderAll() {
    renderDashboard();
    renderFragranceHistory();
    renderNextShipment();
    renderFutureMonths();
    renderSubscription();
  }
  function renderDashboard() {
    var sub = state.subscription;
    // Stats
    var statFragrances = $('#statFragrances');
    var statPlan = $('#statPlan');
    var statNextShipment = $('#statNextShipment');
    if (statFragrances) {
      statFragrances.textContent = state.fragranceHistory.length || {{ customer.orders_count | json }};
    }
    if (statPlan) {
      if (sub) {
        statPlan.textContent = sub.plan ? sub.plan.name : 'Monthly';
      } else {
        statPlan.textContent = CONFIG.isSubscriberFromLiquid ? 'Monthly' : '—';
      }
    }
    if (statNextShipment && sub && sub.nextOrderDate) {
      statNextShipment.textContent = formatDate(sub.nextOrderDate, 'short');
    }
    // Dashboard shipment preview
    renderDashShipmentPreview();
    // Dashboard queue preview
    renderDashQueuePreview();
    // Status badge
    var statusBadge = $('#subscriptionStatusBadge');
    if (statusBadge && sub) {
      var status = sub.status || 'ACTIVE';
      statusBadge.textContent = status.charAt(0) + status.slice(1).toLowerCase();
      statusBadge.className = 'acct__status-badge';
      if (status === 'ACTIVE') statusBadge.classList.add('acct__status-badge--active');
      else if (status === 'PAUSED') statusBadge.classList.add('acct__status-badge--paused');
      else statusBadge.classList.add('acct__status-badge--cancelled');
    }
  }
  function renderDashShipmentPreview() {
    var preview = $('#dashShipmentPreview');
    if (!preview) return;
    var ns = state.nextShipment;
    var sub = state.subscription;
    // Priority: user selection > queue > current line item > FOTM
    var fragrance = null;
    var isAuto = false;
    var source = '';
    if (ns && ns.fragrance) {
      fragrance = ns.fragrance;
      isAuto = ns.autoSelected;
      source = ns.source;
    } else if (sub && sub.lines && sub.lines.length > 0) {
      var line = sub.lines[0];
      fragrance = {
        title: line.title || line.productTitle || 'Subscription Item',
        image: line.image || line.imageSrc || '',
        family: line.variantTitle || line.vendor || ''
      };
    }
    if (fragrance) {
      preview.innerHTML = '<div style="display:flex;align-items:center;gap:16px;padding:8px;">' +
        (fragrance.image ? '<img src="' + fragrance.image + '" style="width:60px;height:60px;border-radius:8px;object-fit:cover;">' : '') +
        '<div><strong style="color:#2D4641;">' + fragrance.title + '</strong>' +
        '<br><span style="font-size:12px;color:#C9A962;">' + (fragrance.family || '') + '</span>' +
        (isAuto ? '<br><span style="font-size:11px;color:#999;">Auto-selected' + (source === 'fotm' ? ' — Curated Pick' : '') + '</span>' : '') +
        '</div></div>';
    } else {
      preview.innerHTML = '<div class="acct__shipment-placeholder">' +
        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>' +
        '<p>Choose your next fragrance</p>' +
        '<a href="#next-shipment" class="btn btn--primary btn--small">Select Fragrance</a>' +
        '</div>';
    }
  }
  function renderDashQueuePreview() {
    var preview = $('#dashQueuePreview');
    if (!preview) return;
    var queueKeys = Object.keys(state.futureQueue).sort();
    
    if (queueKeys.length === 0) {
      preview.innerHTML = '<p class="dash-queue-empty">No fragrances queued. <a href="#future-months">Plan your next few months →</a></p>';
      return;
    }
    var html = '';
    queueKeys.slice(0, 4).forEach(function(monthKey) {
      var item = state.futureQueue[monthKey];
      html += '<div class="dash-queue-item">' +
        (item.image ? '<img class="dash-queue-item__img" src="' + item.image + '">' : '<div class="dash-queue-item__img"></div>') +
        '<div class="dash-queue-item__month">' + getMonthLabel(monthKey).split(' ')[0].slice(0, 3) + '</div>' +
        '<div class="dash-queue-item__name">' + item.title + '</div>' +
        '</div>';
    });
    if (queueKeys.length > 4) {
      html += '<div class="dash-queue-item" style="opacity:0.5;">' +
        '<div class="dash-queue-item__img" style="display:flex;align-items:center;justify-content:center;font-weight:700;color:#999;">+' + (queueKeys.length - 4) + '</div>' +
        '<div class="dash-queue-item__month">more</div>' +
        '</div>';
    }
    preview.innerHTML = html;
  }
  function renderFragranceHistory() {
    var timeline = $('#fragranceTimeline');
    var empty = $('#fragranceTimelineEmpty');
    if (!timeline) return;
    if (!state.fragranceHistory || state.fragranceHistory.length === 0) {
      timeline.style.display = 'none';
      if (empty) empty.style.display = 'block';
      return;
    }
    timeline.style.display = 'block';
    if (empty) empty.style.display = 'none';
    var ratings = Storage.get('history_ratings') || {};
    var notes = Storage.get('history_notes') || {};
    // Group by month
    var grouped = {};
    var monthOrder = [];
    state.fragranceHistory.forEach(function(entry, i) {
      var monthKey = entry.month || 'Month ' + (i + 1);
      if (!grouped[monthKey]) {
        grouped[monthKey] = [];
        monthOrder.push(monthKey);
      }
      grouped[monthKey].push({ entry: entry, index: i });
    });
    var html = '';
    monthOrder.forEach(function(monthKey) {
      html += '<div class="fh-month-group">';
      html += '<div class="fh-entry__dot"></div>';
      html += '<div class="fh-entry__month">' + monthKey + '</div>';
      grouped[monthKey].forEach(function(item) {
        var entry = item.entry;
        var i = item.index;
        var rating = ratings[i] || 0;
        var note = notes[i] || '';
        var stars = '';
        for (var s = 1; s <= 5; s++) {
          stars += '<svg class="fh-star' + (s <= rating ? ' is-filled' : '') + '" data-entry="' + i + '" data-star="' + s + '" viewBox="0 0 24 24" fill="' + (s <= rating ? 'currentColor' : 'none') + '" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
        }
        var notesHtml = '';
        if (entry.top_notes) notesHtml += '<strong>Top:</strong> ' + entry.top_notes + '<br>';
        if (entry.heart_notes) notesHtml += '<strong>Heart:</strong> ' + entry.heart_notes + '<br>';
        if (entry.base_notes) notesHtml += '<strong>Base:</strong> ' + entry.base_notes;
        html += '<div class="fh-entry">' +
          '<div class="fh-entry__grid">' +
          '<div class="fh-entry__image">' +
          (entry.product_image ? '<img src="' + entry.product_image + '" alt="' + entry.product_title + '" loading="lazy">' : '') +
          '</div>' +
          '<div>' +
          '<h4 class="fh-entry__name">' + (entry.product_title || 'Unknown Fragrance') + '</h4>' +
          (entry.family ? '<span class="fh-entry__family">' + entry.family + '</span>' : '') +
          (notesHtml ? '<div class="fh-entry__notes">' + notesHtml + '</div>' : '') +
          '<div class="fh-stars">' + stars + '</div>' +
          '<div class="fh-user-note">' +
          '<textarea placeholder="Add your notes..." data-note-entry="' + i + '">' + note + '</textarea>' +
          '<button data-save-note="' + i + '">Save</button>' +
          '</div>' +
          '<div class="fh-entry__actions">' +
          (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--again">Get This Again</a>' : '') +
          (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--fullsize">Buy Full Size</a>' : '') +
          '</div></div></div></div>';
      });
      html += '</div>';
    });
    timeline.innerHTML = html;
    // Attach event listeners
    timeline.querySelectorAll('.fh-star').forEach(function(star) {
      star.addEventListener('click', function() {
        var entryIdx = this.dataset.entry;
        var starVal = parseInt(this.dataset.star, 10);
        var r = Storage.get('history_ratings') || {};
        r[entryIdx] = starVal;
        Storage.set('history_ratings', r);
        renderFragranceHistory();
      });
    });
    timeline.querySelectorAll('[data-save-note]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = this.dataset.saveNote;
        var textarea = timeline.querySelector('[data-note-entry="' + idx + '"]');
        if (textarea) {
          var n = Storage.get('history_notes') || {};
          n[idx] = textarea.value;
          Storage.set('history_notes', n);
          btn.textContent = 'Saved!';
          setTimeout(function() { btn.textContent = 'Save'; }, 1500);
        }
      });
    });
  }
  function renderNextShipment() {
    var statusBadge = $('#nsStatusBadge');
    var selected = $('#nsSelected');
    var choose = $('#nsChoose');
    var skipped = $('#nsSkipped');
    if (!statusBadge) return;
    var ns = state.nextShipment;
    var sub = state.subscription;
    // Check if skipped
    if (ns && ns.status === 'skipped') {
      statusBadge.textContent = 'Skipped';
      statusBadge.className = 'ns-status-badge ns-skipped';
      if (selected) selected.style.display = 'none';
      if (choose) choose.style.display = 'none';
      if (skipped) skipped.style.display = 'block';
      return;
    }
    // Determine what fragrance to show
    var fragrance = null;
    var isAuto = false;
    var source = '';
    if (ns && ns.fragrance) {
      fragrance = ns.fragrance;
      isAuto = ns.autoSelected;
      source = ns.source;
    } else if (sub && sub.lines && sub.lines.length > 0) {
      var line = sub.lines[0];
      fragrance = {
        title: line.title || line.productTitle || 'Subscription Item',
        image: line.image || line.imageSrc || '',
        family: line.variantTitle || line.vendor || ''
      };
    }
    if (fragrance) {
      var badgeText = 'Confirmed';
      var badgeClass = 'ns-confirmed';
      
      if (isAuto && source === 'fotm') {
        badgeText = 'Curated Pick';
        badgeClass = 'ns-auto';
      } else if (isAuto) {
        badgeText = 'Auto-Selected';
        badgeClass = 'ns-auto';
      }
      statusBadge.textContent = badgeText;
      statusBadge.className = 'ns-status-badge ' + badgeClass;
      if (selected) {
        selected.style.display = 'block';
        var nsImage = $('#nsImage');
        var nsName = $('#nsName');
