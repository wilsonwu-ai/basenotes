<!-- JAVASCRIPT                              -->
<!-- ═══════════════════════════════════════ -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  'use strict';

  /* ── Hash Router ── */
  var views = document.querySelectorAll('[data-view]');
  var navLinks = document.querySelectorAll('[data-nav]');
  var validRoutes = ['dashboard', 'history', 'next-shipment', 'subscription', 'orders'];

  function navigate(hash) {
    var route = (hash || '').replace('#', '') || 'dashboard';
    if (validRoutes.indexOf(route) === -1) route = 'dashboard';

    views.forEach(function(v) {
      v.style.display = v.dataset.view === route ? '' : 'none';
    });

    navLinks.forEach(function(link) {
      if (link.dataset.nav === route) {
        link.classList.add('is-active');
      } else {
        link.classList.remove('is-active');
      }
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  window.addEventListener('hashchange', function() {
    navigate(location.hash);
  });

  navigate(location.hash);

  /* ── Fragrance History ── */
  var timelineEl = document.getElementById('fragranceTimeline');
  var timelineEmptyEl = document.getElementById('fragranceTimelineEmpty');

  // Try metafield data first, fall back to localStorage
  var historyData = null;
  {% if fh_json != blank %}
    try { historyData = {{ fh_json }}; } catch(e) {}
  {% endif %}

  if (!historyData) {
    try { historyData = JSON.parse(localStorage.getItem('bn_fragrance_history') || 'null'); } catch(e) {}
  }

  function getHistoryRatings() {
    try { return JSON.parse(localStorage.getItem('bn_history_ratings') || '{}'); } catch(e) { return {}; }
  }

  function getHistoryNotes() {
    try { return JSON.parse(localStorage.getItem('bn_history_notes') || '{}'); } catch(e) { return {}; }
  }

  function renderTimeline() {
    if (!timelineEl) return;
    if (!historyData || !historyData.length) {
      if (timelineEl) timelineEl.style.display = 'none';
      if (timelineEmptyEl) timelineEmptyEl.style.display = 'block';
      return;
    }

    if (timelineEmptyEl) timelineEmptyEl.style.display = 'none';
    timelineEl.style.display = 'block';

    var ratings = getHistoryRatings();
    var notes = getHistoryNotes();

    timelineEl.innerHTML = historyData.map(function(entry, i) {
      var rating = ratings[i] || 0;
      var note = notes[i] || '';
      var stars = '';
      for (var s = 1; s <= 5; s++) {
        stars += '<svg class="fh-star' + (s <= rating ? ' is-filled' : '') + '" data-entry="' + i + '" data-star="' + s + '" viewBox="0 0 24 24" fill="' + (s <= rating ? 'currentColor' : 'none') + '" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';
      }

      var notesHtml = '';
      if (entry.top_notes) notesHtml += '<strong>Top:</strong> ' + entry.top_notes + '<br>';
      if (entry.heart_notes) notesHtml += '<strong>Heart:</strong> ' + entry.heart_notes + '<br>';
      if (entry.base_notes) notesHtml += '<strong>Base:</strong> ' + entry.base_notes;

      return '<div class="fh-entry">' +
        '<div class="fh-entry__dot"></div>' +
        '<div class="fh-entry__month">' + (entry.month || 'Month ' + (i + 1)) + '</div>' +
        '<div class="fh-entry__grid">' +
          '<div class="fh-entry__image">' +
            (entry.product_image ? '<img src="' + entry.product_image + '" alt="' + entry.product_title + '" loading="lazy">' : '') +
          '</div>' +
          '<div>' +
            '<h4 class="fh-entry__name">' + (entry.product_title || 'Unknown Fragrance') + '</h4>' +
            (entry.family ? '<span class="fh-entry__family">' + entry.family + '</span>' : '') +
            (notesHtml ? '<div class="fh-entry__notes">' + notesHtml + '</div>' : '') +
            '<div class="fh-stars">' + stars + '</div>' +
            '<div class="fh-user-note">' +
              '<textarea placeholder="Add your notes..." data-note-entry="' + i + '">' + note + '</textarea>' +
              '<button data-save-note="' + i + '">Save</button>' +
            '</div>' +
            '<div class="fh-entry__actions">' +
              (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--again">Get This Again</a>' : '') +
              (entry.product_handle ? '<a href="/products/' + entry.product_handle + '" class="fh-action--fullsize">Buy Full Size</a>' : '') +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');

    // Star click handlers
    timelineEl.querySelectorAll('.fh-star').forEach(function(star) {
      star.addEventListener('click', function() {
        var entryIdx = this.dataset.entry;
        var starVal = parseInt(this.dataset.star);
        var r = getHistoryRatings();
        r[entryIdx] = starVal;
        localStorage.setItem('bn_history_ratings', JSON.stringify(r));
        // TODO: Appstle API — persist rating server-side
        renderTimeline();
      });
    });

    // Note save handlers
    timelineEl.querySelectorAll('[data-save-note]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = this.dataset.saveNote;
        var textarea = timelineEl.querySelector('[data-note-entry="' + idx + '"]');
        if (textarea) {
          var n = getHistoryNotes();
          n[idx] = textarea.value;
          localStorage.setItem('bn_history_notes', JSON.stringify(n));
          // TODO: Appstle API — persist notes server-side
          btn.textContent = 'Saved!';
          setTimeout(function() { btn.textContent = 'Save'; }, 1500);
        }
      });
    });
  }

  renderTimeline();


  /* ── Next Shipment ── */
  var nsStatusBadge = document.getElementById('nsStatusBadge');
  var nsSelected = document.getElementById('nsSelected');
  var nsChoose = document.getElementById('nsChoose');
  var nsSkipped = document.getElementById('nsSkipped');
  var nsImage = document.getElementById('nsImage');
  var nsName = document.getElementById('nsName');
  var nsFamily = document.getElementById('nsFamily');

  function getNextShipment() {
    try { return JSON.parse(localStorage.getItem('bn_next_shipment') || 'null'); } catch(e) { return null; }
  }

  function saveNextShipment(data) {
    localStorage.setItem('bn_next_shipment', JSON.stringify(data));
    // TODO: Appstle API — update next shipment server-side
    renderNextShipment();
  }

  function renderNextShipment() {
    if (!nsStatusBadge) return;
    var data = getNextShipment();

    if (data && data.status === 'skipped') {
      nsStatusBadge.textContent = 'Skipped';
      nsStatusBadge.className = 'ns-status-badge ns-skipped';
      if (nsSelected) nsSelected.style.display = 'none';
      if (nsChoose) nsChoose.style.display = 'none';
      if (nsSkipped) nsSkipped.style.display = 'block';
      return;
    }

    if (data && data.fragrance) {
      var isAuto = data.autoSelected;
      nsStatusBadge.textContent = isAuto ? 'Auto-Selected' : 'Confirmed';
      nsStatusBadge.className = 'ns-status-badge ' + (isAuto ? 'ns-auto' : 'ns-confirmed');
      if (nsSelected) {
        nsSelected.style.display = 'block';
        if (nsImage) nsImage.innerHTML = data.fragrance.image ? '<img src="' + data.fragrance.image + '" alt="' + data.fragrance.title + '" style="width:100%;height:100%;object-fit:cover;border-radius:10px;">' : '';
        if (nsName) nsName.textContent = data.fragrance.title;
        if (nsFamily) nsFamily.textContent = data.fragrance.family || '';
      }
      if (nsChoose) nsChoose.style.display = 'none';
      if (nsSkipped) nsSkipped.style.display = 'none';

      // Also update dashboard preview
      var dashPreview = document.getElementById('dashShipmentPreview');
      if (dashPreview) {
        dashPreview.innerHTML = '<div style="display:flex;align-items:center;gap:16px;padding:8px;">' +
          (data.fragrance.image ? '<img src="' + data.fragrance.image + '" style="width:60px;height:60px;border-radius:8px;object-fit:cover;">' : '') +
          '<div><strong style="color:#2D4641;">' + data.fragrance.title + '</strong>' +
          '<br><span style="font-size:12px;color:#C9A962;">' + (data.fragrance.family || '') + '</span></div></div>';
      }
    } else {
      nsStatusBadge.textContent = 'Action Needed';
      nsStatusBadge.className = 'ns-status-badge ns-action';
      if (nsSelected) nsSelected.style.display = 'none';
      if (nsChoose) nsChoose.style.display = 'block';
      if (nsSkipped) nsSkipped.style.display = 'none';
    }

    // Update dashboard stat
    var statEl = document.getElementById('statNextShipment');
    if (statEl) {
      var nextDate = new Date();
      nextDate.setMonth(nextDate.getMonth() + 1);
      nextDate.setDate(1);
      statEl.textContent = nextDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
    }

    // Update subscription billing
    var billingEl = document.getElementById('subNextBilling');
    if (billingEl) {
      var billDate = new Date();
      billDate.setMonth(billDate.getMonth() + 1);
      billDate.setDate(1);
      billingEl.textContent = billDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    }
  }

  renderNextShipment();

  /* ── Billing Countdown ── */
  function renderBillingCountdown() {
    var countdownEl = document.getElementById('billingCountdown');
    if (!countdownEl) return;

    // Try to get real subscription data from localStorage (set by checkout scripts)
    var subData = null;
    try { subData = JSON.parse(localStorage.getItem('bn_active_subscription') || 'null'); } catch(e) {}

    // Calculate next billing date (anniversary billing: same day next month)
    var now = new Date();
    var nextBill;
    if (subData && subData.nextBillDate) {
      nextBill = new Date(subData.nextBillDate);
      // If next bill is in the past, advance to next month
      while (nextBill < now) {
        nextBill.setMonth(nextBill.getMonth() + 1);
      }
    } else {
      // Fallback: assume billing is on the 1st of next month
      nextBill = new Date(now.getFullYear(), now.getMonth() + 1, 1);
    }

    // Days remaining
    var msPerDay = 86400000;
    var daysLeft = Math.max(0, Math.ceil((nextBill - now) / msPerDay));

    // Progress bar (30-day cycle)
    var cycleDays = 30;
    var elapsed = cycleDays - daysLeft;
    var pct = Math.min(100, Math.max(0, (elapsed / cycleDays) * 100));

    // Update DOM
    var daysEl = document.getElementById('billingDaysLeft');
    var barEl = document.getElementById('billingBar');
    var dateTextEl = document.getElementById('billingDateText');
    var cancelDeadlineEl = document.getElementById('cancelDeadline');

    if (daysEl) daysEl.textContent = daysLeft + ' day' + (daysLeft !== 1 ? 's' : '');
    if (barEl) barEl.style.width = pct + '%';

    var dateOpts = { month: 'long', day: 'numeric', year: 'numeric' };
    if (dateTextEl) dateTextEl.textContent = 'Next charge on ' + nextBill.toLocaleDateString('en-US', dateOpts);

    // Cancel deadline = 1 day before billing
    var cancelDate = new Date(nextBill);
    cancelDate.setDate(cancelDate.getDate() - 1);
    if (cancelDeadlineEl) cancelDeadlineEl.textContent = cancelDate.toLocaleDateString('en-US', dateOpts);

    // Also update the plan details billing field
    var subBillingEl = document.getElementById('subNextBilling');
    if (subBillingEl) subBillingEl.textContent = nextBill.toLocaleDateString('en-US', dateOpts);
  }

  renderBillingCountdown();

  // Choose / Swap button → open fragrance selector
  var chooseBtn = document.getElementById('nsChooseBtn');
  var swapBtn = document.getElementById('nsSwapBtn');

  function openFragranceSelector() {
    document.dispatchEvent(new Event('fragrance-selector:open'));
  }

  if (chooseBtn) chooseBtn.addEventListener('click', openFragranceSelector);
  if (swapBtn) swapBtn.addEventListener('click', openFragranceSelector);

  // Listen for fragrance selection
  document.addEventListener('fragrance:selected', function(e) {
    var frag = e.detail;
    saveNextShipment({
      fragrance: {
        id: frag.id,
        handle: frag.handle,
        title: frag.title,
        image: frag.image,
        family: frag.family
      },
      autoSelected: false,
      status: 'confirmed'
    });
  });

  // Skip
  var skipBtn = document.getElementById('nsSkipBtn');
  if (skipBtn) {
    skipBtn.addEventListener('click', function() {
      if (confirm('Skip this month\'s shipment? You can undo this anytime.')) {
        saveNextShipment({ status: 'skipped' });
      }
    });
  }

  // Undo skip
  var undoSkipBtn = document.getElementById('nsUndoSkip');
  if (undoSkipBtn) {
    undoSkipBtn.addEventListener('click', function() {
      localStorage.removeItem('bn_next_shipment');
      renderNextShipment();
    });
  }

  // Sub page skip/pause
  var subSkipBtn = document.getElementById('subSkipBtn');
  if (subSkipBtn) {
    subSkipBtn.addEventListener('click', function() {
      if (confirm('Skip next month\'s shipment?')) {
        saveNextShipment({ status: 'skipped' });
        // TODO: Appstle API
        alert('Next month\'s shipment has been skipped.');
      }
    });
  }

  var subPauseBtn = document.getElementById('subPauseBtn');
  if (subPauseBtn) {
    subPauseBtn.addEventListener('click', function() {
      // TODO: Appstle API — pause subscription
      alert('To pause your subscription, please contact us at hello@basenote.com or use the subscription portal in your account.');
    });
  }

  // Cancel button → open cancellation flow
  var subCancelBtn = document.getElementById('subCancelBtn');
  if (subCancelBtn) {
    subCancelBtn.addEventListener('click', function() {
      document.dispatchEvent(new Event('cancellation:open'));
    });
  }
});
</script>
