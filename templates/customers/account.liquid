  function renderSubscription() {
    var sub = state.subscription;
    if (!sub) return;
    // Update status badges
    var subStatusBadge = $('#subStatusBadge');
    if (subStatusBadge) {
      var status = sub.status || 'ACTIVE';
      subStatusBadge.textContent = status.charAt(0) + status.slice(1).toLowerCase();
      subStatusBadge.className = 'acct__status-badge';
      if (status === 'ACTIVE') subStatusBadge.classList.add('acct__status-badge--active');
      else if (status === 'PAUSED') subStatusBadge.classList.add('acct__status-badge--paused');
      else subStatusBadge.classList.add('acct__status-badge--cancelled');
    }
    // Plan info
    var planTitle = $('#subPlanTitle');
    var planPrice = $('#subPlanPrice');
    var detailPlan = $('#subDetailPlan');
    var detailPrice = $('#subDetailPrice');
    if (sub.plan) {
      if (planTitle) planTitle.textContent = sub.plan.name + ' Subscription';
      if (planPrice) planPrice.textContent = sub.plan.priceFormatted;
      if (detailPlan) detailPlan.textContent = sub.plan.name;
      if (detailPrice) detailPrice.textContent = sub.plan.priceFormatted;
    }
    // Billing info
    var subNextBilling = $('#subNextBilling');
    if (subNextBilling && sub.nextBillingDate) {
      subNextBilling.textContent = formatDate(sub.nextBillingDate, 'long');
    }
    // Payment method
    var subPaymentMethod = $('#subPaymentMethod');
    if (subPaymentMethod) {
      subPaymentMethod.textContent = sub.paymentMethod;
    }
    // Shipping address
    var subShippingAddress = $('#subShippingAddress');
    if (subShippingAddress) {
      subShippingAddress.textContent = sub.shippingAddress;
    }
    // Contract ID
    var subContractId = $('#subContractId');
    if (subContractId) {
      subContractId.textContent = '#' + (sub.contractId || sub.id);
    }
    // Billing countdown
    renderBillingCountdown();
  }
  function renderBillingCountdown() {
    var sub = state.subscription;
    if (!sub || !sub.nextBillingDate) return;
    var now = new Date();
    var nextBill = sub.nextBillingDate;
    var msPerDay = 86400000;
    var daysLeft = Math.max(0, Math.ceil((nextBill - now) / msPerDay));
    var cycleDays = 30;
    var elapsed = cycleDays - daysLeft;
    var pct = Math.min(100, Math.max(0, (elapsed / cycleDays) * 100));
    var daysEl = $('#billingDaysLeft');
    var barEl = $('#billingBar');
    var dateTextEl = $('#billingDateText');
    var cancelDeadlineEl = $('#cancelDeadline');
    if (daysEl) daysEl.textContent = daysLeft + ' day' + (daysLeft !== 1 ? 's' : '');
    if (barEl) barEl.style.width = pct + '%';
    if (dateTextEl) dateTextEl.textContent = 'Next charge on ' + formatDate(nextBill, 'long');
    var cancelDate = new Date(nextBill);
    cancelDate.setDate(cancelDate.getDate() - 1);
    if (cancelDeadlineEl) cancelDeadlineEl.textContent = formatDate(cancelDate, 'long');
  }
