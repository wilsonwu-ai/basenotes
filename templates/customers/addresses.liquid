{%- layout 'theme' -%}

<section class="acct">
  <div class="container">
    <div class="acct__layout">

      <!-- ═══ Sidebar (matches account.liquid) ═══ -->
      <aside class="acct__sidebar">
        <div class="acct__user">
          <div class="acct__avatar">{{ customer.first_name | slice: 0 }}{{ customer.last_name | slice: 0 }}</div>
          <div>
            <p class="acct__user-greeting">Welcome back,</p>
            <p class="acct__user-name">{{ customer.first_name }} {{ customer.last_name }}</p>
            <p class="acct__user-email">{{ customer.email }}</p>
          </div>
        </div>
        <nav class="acct__nav">
          <a href="{{ routes.account_url }}#dashboard" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Dashboard
          </a>
          <a href="{{ routes.account_url }}#history" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Fragrance History
          </a>
          <a href="{{ routes.account_url }}#next-shipment" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><rect x="3" y="4" width="18" height="16" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
            My Queue
          </a>
          <a href="{{ routes.account_url }}#subscription" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            My Subscription
          </a>
          <a href="{{ routes.account_url }}#orders" class="acct__nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Order History
          </a>
          <a href="{{ routes.account_addresses_url }}" class="acct__nav-link is-active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Addresses
          </a>
        </nav>
        <a href="{{ routes.account_logout_url }}" class="acct__signout">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Sign Out
        </a>
      </aside>

      <!-- ═══ Main Content ═══ -->
      <main class="acct__main">
        <div class="acct__view">

          <div class="acct__welcome-banner">
            <div class="acct__welcome-content">
              <p class="acct__welcome-eyebrow">Account</p>
              <h2 class="acct__welcome-title">Addresses</h2>
              <p class="acct__welcome-meta">Manage your shipping addresses. Orders ship to your default address unless changed.</p>
            </div>
          </div>

          <!-- Add Address CTA -->
          <div class="acct__card acct__card--flush">
            <button type="button" class="btn btn--primary" id="addAddressBtn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Add New Address
            </button>
          </div>

          <!-- New Address Form (hidden by default) -->
          <div id="newAddressForm" class="acct__card addr-form" style="display:none;">
            <div class="acct__card-header">
              <h3 class="acct__card-title">Add New Address</h3>
            </div>
            {%- form 'customer_address', customer.new_address -%}
              <div class="addr-form__grid addr-form__grid--2">
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressFirstName">First name</label>
                  <input type="text" name="address[first_name]" id="AddressFirstName" class="addr-form__input" autocomplete="given-name">
                </div>
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressLastName">Last name</label>
                  <input type="text" name="address[last_name]" id="AddressLastName" class="addr-form__input" autocomplete="family-name">
                </div>
              </div>
              <div class="addr-form__group">
                <label class="addr-form__label" for="AddressCompany">Company <span class="addr-form__optional">(optional)</span></label>
                <input type="text" name="address[company]" id="AddressCompany" class="addr-form__input" autocomplete="organization">
              </div>
              <div class="addr-form__group">
                <label class="addr-form__label" for="AddressAddress1">Address</label>
                <input type="text" name="address[address1]" id="AddressAddress1" class="addr-form__input" autocomplete="address-line1" required>
              </div>
              <div class="addr-form__group">
                <label class="addr-form__label" for="AddressAddress2">Apartment, suite, etc. <span class="addr-form__optional">(optional)</span></label>
                <input type="text" name="address[address2]" id="AddressAddress2" class="addr-form__input" autocomplete="address-line2">
              </div>
              <div class="addr-form__grid addr-form__grid--3">
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressCity">City</label>
                  <input type="text" name="address[city]" id="AddressCity" class="addr-form__input" autocomplete="address-level2" required>
                </div>
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressCountry">Country</label>
                  <select name="address[country]" id="AddressCountry" class="addr-form__input" data-default="{{ customer.default_address.country | default: 'United States' }}">
                    {{ all_country_option_tags }}
                  </select>
                </div>
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressProvince">State / Province</label>
                  <select name="address[province]" id="AddressProvince" class="addr-form__input" data-default="{{ customer.default_address.province }}"></select>
                </div>
              </div>
              <div class="addr-form__grid addr-form__grid--2">
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressZip">Postal / ZIP code</label>
                  <input type="text" name="address[zip]" id="AddressZip" class="addr-form__input" autocomplete="postal-code" required>
                </div>
                <div class="addr-form__group">
                  <label class="addr-form__label" for="AddressPhone">Phone <span class="addr-form__optional">(optional)</span></label>
                  <input type="tel" name="address[phone]" id="AddressPhone" class="addr-form__input" autocomplete="tel">
                </div>
              </div>
              <label class="addr-form__checkbox">
                <input type="checkbox" name="address[default]" value="1">
                <span>Set as default shipping address</span>
              </label>
              <div class="addr-form__actions">
                <button type="submit" class="btn btn--primary">Save Address</button>
                <button type="button" class="btn btn--outline" id="cancelAddressBtn">Cancel</button>
              </div>
            {%- endform -%}
          </div>

          <!-- Existing Addresses -->
          {%- if customer.addresses_count > 0 -%}
            <div class="addr-grid">
              {%- for address in customer.addresses -%}
                {%- assign is_default = false -%}
                {%- if address == customer.default_address -%}{%- assign is_default = true -%}{%- endif -%}
                <div class="acct__card addr-card{% if is_default %} addr-card--default{% endif %}">
                  {%- if is_default -%}
                    <span class="addr-card__badge">Default</span>
                  {%- endif -%}
                  <p class="addr-card__name">{{ address.first_name }} {{ address.last_name }}</p>
                  <p class="addr-card__lines">
                    {%- if address.company != blank -%}{{ address.company }}<br>{%- endif -%}
                    {{ address.address1 }}<br>
                    {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                    {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                    {{ address.country }}
                    {%- if address.phone != blank -%}<br>{{ address.phone }}{%- endif -%}
                  </p>
                  <div class="addr-card__actions">
                    <a href="/account/addresses/{{ address.id }}" class="addr-card__link">Edit</a>
                    <form method="post" action="/account/addresses/{{ address.id }}" class="addr-card__delete-form">
                      <input type="hidden" name="_method" value="delete">
                      <button type="submit" class="addr-card__delete" onclick="return confirm('Are you sure you want to delete this address?')">Delete</button>
                    </form>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="acct__card acct__empty">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40"><path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <p>No addresses saved yet. Add one above to speed up checkout.</p>
            </div>
          {%- endif -%}

        </div>
      </main>
    </div>
  </div>
</section>

<style>
  /* ═══ Account shell (mirrors account.liquid) ═══ */
  .acct { padding: calc(var(--header-height, 110px) + 1.5rem) 0 4rem; background: #FAF8F5; min-height: 80vh; }
  .acct__layout { display: grid; grid-template-columns: 280px 1fr; gap: 2rem; }

  .acct__sidebar { background: #fff; border-radius: 14px; padding: 1.5rem; height: fit-content; position: sticky; top: calc(var(--header-height, 110px) + 1rem); box-shadow: 0 2px 12px rgba(45,70,65,0.04); }
  .acct__user { display: flex; align-items: center; gap: 12px; padding-bottom: 1.25rem; margin-bottom: 1rem; border-bottom: 1px solid #F0EDE8; }
  .acct__avatar { width: 44px; height: 44px; border-radius: 50%; background: #2D4641; color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 14px; letter-spacing: 0.04em; flex-shrink: 0; }
  .acct__user-greeting { font-size: 11px; color: #8a918e; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 2px; font-weight: 700; }
  .acct__user-name { font-size: 15px; font-weight: 700; color: #2D4641; margin: 0 0 2px; }
  .acct__user-email { font-size: 12px; color: #8a918e; margin: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .acct__nav { display: flex; flex-direction: column; gap: 4px; }
  .acct__nav-link { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; font-size: 13px; font-weight: 600; color: #666; text-decoration: none; transition: all 0.2s; }
  .acct__nav-link:hover { background: #F5F3F0; color: #2D4641; }
  .acct__nav-link.is-active { background: #2D4641; color: #fff; }
  .acct__signout { display: inline-flex; align-items: center; gap: 8px; margin-top: 1.25rem; padding: 8px 12px; font-size: 12px; color: #8a918e; text-decoration: none; border-top: 1px solid #F0EDE8; padding-top: 1rem; }
  .acct__signout:hover { color: #c62828; }

  .acct__main { min-width: 0; }
  .acct__view { display: flex; flex-direction: column; gap: 1.5rem; }

  .acct__welcome-banner { background: linear-gradient(135deg, #2D4641 0%, #1f332f 100%); color: #fff; padding: 2rem; border-radius: 14px; display: flex; justify-content: space-between; align-items: flex-start; gap: 1.5rem; }
  .acct__welcome-content { max-width: 100%; }
  .acct__welcome-eyebrow { font-size: 11px; color: #C9A962; text-transform: uppercase; letter-spacing: 0.1em; margin: 0 0 8px; font-weight: 700; }
  .acct__welcome-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2rem; margin: 0 0 8px; font-weight: 400; }
  .acct__welcome-meta { font-size: 13px; color: rgba(255,255,255,0.7); margin: 0; }

  .acct__card { background: #fff; border: 1px solid #EEE9DF; border-radius: 14px; padding: 1.5rem; }
  .acct__card--flush { display: flex; align-items: center; justify-content: space-between; }
  .acct__card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid #F0EDE8; }
  .acct__card-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.5rem; font-weight: 400; color: #2D4641; margin: 0; }

  .acct__empty { text-align: center; padding: 2.5rem 1.5rem; color: #8a918e; display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .acct__empty svg { color: #C9A962; }
  .acct__empty p { margin: 0; font-size: 14px; }

  /* ═══ Address grid + cards ═══ */
  .addr-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .addr-card { position: relative; display: flex; flex-direction: column; gap: 10px; }
  .addr-card--default { border-color: #C9A962; box-shadow: 0 2px 12px rgba(201,169,98,0.08); }
  .addr-card__badge { position: absolute; top: 12px; right: 12px; background: #C9A962; color: #2D4641; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 4px 8px; border-radius: 999px; }
  .addr-card__name { font-size: 15px; font-weight: 700; color: #2D4641; margin: 0; }
  .addr-card__lines { font-size: 13px; color: #666; line-height: 1.55; margin: 0; }
  .addr-card__actions { display: flex; gap: 1rem; align-items: center; margin-top: 8px; padding-top: 12px; border-top: 1px solid #F0EDE8; }
  .addr-card__link, .addr-card__delete { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; text-decoration: none; background: none; border: none; cursor: pointer; padding: 0; font-family: inherit; }
  .addr-card__link { color: #2D4641; }
  .addr-card__link:hover { color: #C9A962; }
  .addr-card__delete { color: #c62828; }
  .addr-card__delete:hover { opacity: 0.7; }
  .addr-card__delete-form { display: inline; margin: 0; padding: 0; }

  /* ═══ Address form ═══ */
  .addr-form .addr-form__grid { display: grid; gap: 12px; margin-bottom: 12px; }
  .addr-form__grid--2 { grid-template-columns: 1fr 1fr; }
  .addr-form__grid--3 { grid-template-columns: 1fr 1fr 1fr; }
  .addr-form__group { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; }
  .addr-form__label { font-size: 12px; font-weight: 700; color: #2D4641; text-transform: uppercase; letter-spacing: 0.06em; }
  .addr-form__optional { font-weight: 400; color: #8a918e; text-transform: none; letter-spacing: 0; font-size: 11px; }
  .addr-form__input { padding: 10px 12px; font-size: 14px; border: 1px solid #EEE9DF; border-radius: 8px; background: #fff; color: #2D4641; font-family: inherit; transition: border-color 0.15s; }
  .addr-form__input:focus { outline: none; border-color: #C9A962; }
  .addr-form__checkbox { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #666; margin: 8px 0 16px; }
  .addr-form__actions { display: flex; gap: 10px; padding-top: 12px; border-top: 1px solid #F0EDE8; }

  /* ═══ Buttons (matches account.liquid) ═══ */
  .btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 12px 24px; font-weight: 700; border-radius: 6px; cursor: pointer; transition: all 0.2s; text-decoration: none; text-transform: uppercase; letter-spacing: 0.08em; font-size: 13px; border: 2px solid transparent; font-family: inherit; }
  .btn--primary { background: #2D4641; color: #fff; border-color: #2D4641; }
  .btn--primary:hover { background: #1a2927; }
  .btn--outline { background: transparent; color: #2D4641; border-color: #D5D0C8; }
  .btn--outline:hover { border-color: #C9A962; color: #C9A962; }

  /* ═══ Responsive ═══ */
  @media (max-width: 992px) {
    .acct__layout { grid-template-columns: 1fr; }
    .acct__sidebar { position: static; }
    .acct__nav { flex-direction: row; flex-wrap: wrap; gap: 6px; }
    .acct__nav-link { padding: 8px 14px; font-size: 12px; }
  }
  @media (max-width: 768px) {
    .acct { padding-top: calc(var(--header-height, 110px) + 1rem); }
    .acct__welcome-banner { flex-direction: column; padding: 1.5rem; }
    .acct__welcome-title { font-size: 1.5rem; }
    .addr-form__grid--2, .addr-form__grid--3 { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const addBtn = document.getElementById('addAddressBtn');
    const cancelBtn = document.getElementById('cancelAddressBtn');
    const form = document.getElementById('newAddressForm');

    if (addBtn && form) {
      addBtn.addEventListener('click', function() {
        form.style.display = 'block';
        addBtn.parentElement.style.display = 'none';
        form.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    if (cancelBtn && form && addBtn) {
      cancelBtn.addEventListener('click', function() {
        form.style.display = 'none';
        addBtn.parentElement.style.display = '';
      });
    }
  });
</script>
