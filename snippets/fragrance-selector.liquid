{% comment %}
  Fragrance Selector — Reusable modal/grid for choosing subscription fragrances

  Usage:
    {% render 'fragrance-selector', mode: 'modal' %}
    {% render 'fragrance-selector', mode: 'inline' %}

  Dispatches CustomEvent 'fragrance:selected' with detail: { id, handle, title, image, family }
  Listen with: document.addEventListener('fragrance:selected', (e) => { ... })
  Open with: document.dispatchEvent(new Event('fragrance-selector:open'))
{% endcomment %}

{%- assign fs_collection = settings.sub_fragrance_collection -%}
{%- assign fs_products = collections[fs_collection].products -%}
{%- if fs_products == blank -%}
  {%- assign fs_products = collections['all'].products -%}
{%- endif -%}

{%- comment -%}
  Bug A fix (July 16 2026): build the filter tabs from the fragrance families that are ACTUALLY
  present in the rendered products, instead of a hardcoded taxonomy (woody/floral/fresh/oriental/
  leather/spicy/musk) that did not match the store's real `custom.fragrance_family` vocabulary and
  emptied the grid on every filter. `.value | join` is metafield-type-robust: for a list metafield
  it joins the array; for a single-line metafield it passes the string through; if unset it falls
  back to product.type. Tab scope == grid scope (both `limit: 20`), so a tab can never be empty.
{%- endcomment -%}
{%- assign fs_family_blob = '' -%}
{%- for product in fs_products limit: 20 -%}
  {%- assign p_ff = product.metafields.custom.fragrance_family.value -%}
  {%- if p_ff == blank -%}{%- assign p_ff = product.type -%}{%- endif -%}
  {%- comment -%} Normalize to individual families: `join` flattens a list metafield or passes a
       single string; `replace ','` also splits comma-delimited single-field values; strip each so
       whitespace-carrying values can't create duplicate or mismatched tabs. {%- endcomment -%}
  {%- assign p_ff_arr = p_ff | join: '~~' | replace: ',', '~~' | split: '~~' -%}
  {%- for fv in p_ff_arr -%}
    {%- assign fvs = fv | strip -%}
    {%- unless fvs == blank -%}
      {%- assign fs_family_blob = fs_family_blob | append: '~~' | append: fvs -%}
    {%- endunless -%}
  {%- endfor -%}
{%- endfor -%}
{%- assign fs_families = fs_family_blob | split: '~~' | uniq | sort_natural -%}

{%- if mode == 'modal' -%}
<div class="fs-overlay" id="fragranceSelectorOverlay" style="display:none;" aria-hidden="true">
  <div class="fs-overlay__bg" data-fs-close></div>
  <div class="fs-panel" role="dialog" aria-label="Choose your fragrance">
{%- endif -%}

    <div class="fs-header">
      <div>
        <h3 class="fs-header__title">Choose Your Fragrance</h3>
        <p class="fs-header__subtitle">Select from our exclusive collection of luxury scents</p>
      </div>
      {%- if mode == 'modal' -%}
        <button class="fs-header__close" data-fs-close aria-label="Close">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="24" height="24">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      {%- endif -%}
    </div>

    <div class="fs-filters-wrap">
      <div class="fs-filters" role="tablist">
        <button class="fs-filter is-active" data-fs-filter="all">All</button>
        {%- for fam in fs_families -%}
          {%- assign fam_clean = fam | strip -%}
          {%- unless fam_clean == blank or fam_clean == 'Fragrance' -%}
            <button class="fs-filter" data-fs-filter="{{ fam_clean | downcase }}">{{ fam_clean }}</button>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="fs-grid">
      {%- for product in fs_products limit: 20 -%}
        {%- comment -%} Bug A fix: robust family derivation (list- or single-metafield, or product.type fallback).
             Element-wise strip so tab tokens and card keys match exactly.
             card_ff_display = human label ("Fresh, Citrus"); card_ff_key = "|fresh|citrus|" for delimiter-safe JS match;
             card_ff_primary = first family for the queue event payload. {%- endcomment -%}
        {%- assign card_ff = product.metafields.custom.fragrance_family.value -%}
        {%- if card_ff == blank -%}{%- assign card_ff = product.type -%}{%- endif -%}
        {%- assign card_ff_key = '|' -%}
        {%- assign card_ff_display = '' -%}
        {%- assign card_ff_primary = '' -%}
        {%- assign card_ff_arr = card_ff | join: '~~' | replace: ',', '~~' | split: '~~' -%}
        {%- for fv in card_ff_arr -%}
          {%- assign fvs = fv | strip -%}
          {%- unless fvs == blank -%}
            {%- assign fvl = fvs | downcase -%}
            {%- assign card_ff_key = card_ff_key | append: fvl | append: '|' -%}
            {%- if card_ff_display == blank -%}
              {%- assign card_ff_display = fvs -%}
              {%- assign card_ff_primary = fvs -%}
            {%- else -%}
              {%- assign card_ff_display = card_ff_display | append: ', ' | append: fvs -%}
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
        {%- assign top_notes = product.metafields.custom.top_notes -%}
        {%- assign heart_notes = product.metafields.custom.heart_notes -%}
        {%- assign base_notes = product.metafields.custom.base_notes -%}
        <div class="fs-card"
             data-fs-id="{{ product.id }}"
             data-fs-handle="{{ product.handle }}"
             data-fs-family="{{ card_ff_key }}">
          <div class="fs-card__image">
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.title }}"
                loading="lazy"
                width="200"
                height="200"
              >
            {%- else -%}
              <div class="fs-card__placeholder">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="48" height="48">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
                  <path d="M12 6v6l4 2"/>
                </svg>
              </div>
            {%- endif -%}
          </div>
          <div class="fs-card__content">
            <h4 class="fs-card__name">{{ product.title }}</h4>
            <span class="fs-card__family">{{ card_ff_display }}</span>
            {%- if top_notes != blank -%}
              <div class="fs-card__notes">
                <span class="fs-card__notes-label">Top:</span> {{ top_notes }}
              </div>
            {%- endif -%}
            <div class="fs-card__price">
              <span class="fs-card__retail">{{ product.price | money }} retail value</span>
            </div>
            <button class="btn btn--primary btn--small fs-card__select"
                    data-fs-select
                    data-product-id="{{ product.id }}"
                    data-product-handle="{{ product.handle }}"
                    data-product-title="{{ product.title | escape }}"
                    data-product-image="{{ product.featured_image | image_url: width: 400 }}"
                    data-product-family="{{ card_ff_primary }}">
              Add to Queue
            </button>
          </div>
        </div>
      {%- endfor -%}
    </div>

    {%- if fs_products.size == 0 -%}
      <div class="fs-empty">
        <p>No fragrances available. Please check back soon.</p>
      </div>
    {%- endif -%}

{%- if mode == 'modal' -%}
  </div>
</div>
{%- endif -%}

<style>
  /* Overlay */
  .fs-overlay {
    position: fixed;
    inset: 0;
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fs-overlay__bg {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
  }

  /* Panel */
  .fs-panel {
    position: relative;
    z-index: 1;
    background: var(--color-background, #FAF8F5);
    border-radius: 12px;
    max-width: 900px;
    width: 94%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 2rem;
    box-shadow: 0 25px 50px rgba(0,0,0,0.25);
  }

  /* Header */
  .fs-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .fs-header__title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.75rem;
    color: var(--color-primary, #2D4641);
    margin: 0;
  }
  .fs-header__subtitle {
    color: var(--color-text-muted, #666);
    font-size: 0.9rem;
    margin: 0.25rem 0 0;
  }
  .fs-header__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    color: var(--color-primary, #2D4641);
    border-radius: 50%;
    transition: background 0.2s;
  }
  .fs-header__close:hover {
    background: rgba(0,0,0,0.05);
  }

  /* Filters */
  .fs-filters-wrap {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .fs-filters-wrap::after {
    content: "";
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0.25rem;
    width: 28px;
    pointer-events: none;
    background: linear-gradient(to left, #fff, rgba(255,255,255,0));
  }
  .fs-filters {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0 0 0.25rem 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .fs-filters::-webkit-scrollbar { height: 4px; }
  .fs-filters::-webkit-scrollbar-thumb { background: #D5CFC3; border-radius: 2px; }
  .fs-filter {
    background: transparent;
    border: 1px solid var(--color-border, #E8E6E3);
    padding: 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
    color: var(--color-primary, #2D4641);
  }
  .fs-filter:hover {
    border-color: var(--color-secondary, #C9A962);
    color: var(--color-secondary, #C9A962);
  }
  .fs-filter.is-active {
    background: var(--color-primary, #2D4641);
    color: #fff;
    border-color: var(--color-primary, #2D4641);
  }

  /* Grid */
  .fs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* Card */
  .fs-card {
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .fs-card:hover {
    border-color: var(--color-secondary, #C9A962);
    box-shadow: 0 4px 20px rgba(201,169,98,0.15);
  }
  .fs-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background: #f5f5f5;
  }
  .fs-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .fs-card:hover .fs-card__image img {
    transform: scale(1.05);
  }
  .fs-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ccc;
  }
  .fs-card__content {
    padding: 1rem;
  }
  .fs-card__name {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary, #2D4641);
    margin: 0 0 0.25rem;
  }
  .fs-card__family {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary, #C9A962);
    margin-bottom: 0.5rem;
  }
  .fs-card__notes {
    font-size: 0.8rem;
    color: var(--color-text-muted, #666);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  .fs-card__notes-label {
    font-weight: 600;
    color: var(--color-primary, #2D4641);
  }
  .fs-card__price {
    margin-bottom: 0.75rem;
  }
  .fs-card__retail {
    font-size: 0.8rem;
    color: var(--color-text-muted, #666);
  }
  .fs-card__select {
    width: 100%;
    font-size: 0.75rem;
    padding: 0.6rem 1rem;
  }

  .fs-empty {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted, #666);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .fs-panel {
      width: 100%;
      height: 100%;
      max-height: 100vh;
      border-radius: 0;
      padding: 1.25rem;
    }
    .fs-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .fs-header__title {
      font-size: 1.35rem;
    }
    .fs-card__content {
      padding: 0.75rem;
    }
    /* Brand framework §7.1: minimum 44px touch targets on mobile */
    .fs-filter {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>

<script>
(function() {
  'use strict';

  var overlay = document.getElementById('fragranceSelectorOverlay');
  if (!overlay) return;

  function openSelector() {
    overlay.style.display = '';
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeSelector() {
    overlay.style.display = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Open event
  document.addEventListener('fragrance-selector:open', openSelector);

  // Close buttons
  overlay.querySelectorAll('[data-fs-close]').forEach(function(el) {
    el.addEventListener('click', closeSelector);
  });

  // Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.style.display !== 'none') {
      closeSelector();
    }
  });

  // Filters
  var filterBtns = overlay.querySelectorAll('[data-fs-filter]');
  var cards = overlay.querySelectorAll('.fs-card');

  filterBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var family = btn.dataset.fsFilter;

      filterBtns.forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');

      cards.forEach(function(card) {
        if (family === 'all') {
          card.style.display = '';
        } else {
          // data-fs-family is a pipe-delimited key like "|fresh|citrus|"; match the whole token
          // (not a substring) so "fresh" never matches "freshwater" and multi-family cards work.
          var cardFamily = (card.dataset.fsFamily || '').toLowerCase();
          card.style.display = cardFamily.indexOf('|' + family + '|') !== -1 ? '' : 'none';
        }
      });
    });
  });

  // Select fragrance
  overlay.querySelectorAll('[data-fs-select]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var detail = {
        id: btn.dataset.productId,
        handle: btn.dataset.productHandle,
        title: btn.dataset.productTitle,
        image: btn.dataset.productImage,
        family: btn.dataset.productFamily
      };

      document.dispatchEvent(new CustomEvent('fragrance:selected', { detail: detail }));
      closeSelector();
    });
  });
})();
</script>
