{%- comment -%}
  email-welcome-subscriber
  ------------------------
  Klaviyo flow: "Welcome New Subscriber — First Order Confirmation"
  Trigger: Shopify → Order Placed (filter: order contains subscription line item)
  Timing: send within 30 min of purchase (Klaviyo flow: 'Wait 30 min' after trigger)

  This email is the ROSCA-compliant post-purchase disclosure:
  - Confirms the subscription
  - States next charge date + amount
  - One-click Cancel link to /account#subscription
  - Clear opt-out path

  Wilson: paste this HTML into Klaviyo → Templates → Create New → HTML template.
  Personalize with Klaviyo event variables where indicated.
{%- endcomment -%}

<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>You're subscribed to Base Note</title>
</head>
<body style="margin:0;padding:0;background:#FAF8F5;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:#2D4641;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAF8F5;padding:40px 20px;">
    <tr>
      <td align="center">
        <table role="presentation" width="560" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;max-width:560px;">

          <!-- Header -->
          <tr>
            <td style="padding:28px 32px;border-bottom:1px solid #EDE8DC;text-align:center;">
              <img src="{{ 'logo.svg' | asset_url | prepend: 'https:' }}" alt="Base Note" width="120" style="display:block;margin:0 auto;">
            </td>
          </tr>

          <!-- Hero -->
          <tr>
            <td style="padding:36px 32px 20px;text-align:center;">
              <h1 style="font:700 26px/1.2 'Cormorant Garamond',Georgia,serif;color:#2D4641;margin:0 0 10px;">
                Welcome to Base Note, {% raw %}{{ first_name|default:"friend" }}{% endraw %}.
              </h1>
              <p style="font:400 15px/1.5 -apple-system,sans-serif;color:#5a6a63;margin:0;">
                Your subscription is active. Here's exactly what happens next.
              </p>
            </td>
          </tr>

          <!-- Subscription summary card -->
          <tr>
            <td style="padding:0 32px 20px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FAF8F5;border-radius:10px;padding:20px;border-left:3px solid #C9A961;">
                <tr>
                  <td>
                    <p style="font:700 11px/1 -apple-system,sans-serif;letter-spacing:0.1em;text-transform:uppercase;color:#8a918e;margin:0 0 10px;">
                      Your subscription
                    </p>
                    <p style="font:700 16px/1.4 -apple-system,sans-serif;color:#2D4641;margin:0 0 6px;">
                      Base Note Monthly — {{ settings.subscription_price | default: '$20' }}/month
                    </p>
                    <p style="font:400 14px/1.5 -apple-system,sans-serif;color:#5a6a63;margin:0 0 12px;">
                      You paid {% raw %}{{ event.total_price|default:"$15" }}{% endraw %} today for your first month.
                    </p>
                    <p style="font:400 14px/1.5 -apple-system,sans-serif;color:#2D4641;margin:0;">
                      <strong>Next charge:</strong> {% raw %}{{ event.next_charge_date|default:"in 30 days" }}{% endraw %}<br>
                      <strong>Amount:</strong> {{ settings.subscription_price | default: '$20' }}<br>
                      <strong>Shipping:</strong> Free
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- What happens next -->
          <tr>
            <td style="padding:10px 32px 20px;">
              <h2 style="font:700 16px/1.3 -apple-system,sans-serif;color:#2D4641;margin:0 0 12px;">What happens next</h2>
              <ol style="font:400 14px/1.7 -apple-system,sans-serif;color:#2D4641;margin:0;padding-left:20px;">
                <li><strong>This week:</strong> We'll ship your first 5ml vial.</li>
                <li><strong>Before your next charge:</strong> Pick your next fragrance in the queue (or let us curate).</li>
                <li><strong>Anytime:</strong> Swap, skip, pause, or cancel with one click.</li>
              </ol>
            </td>
          </tr>

          <!-- Primary CTA: pick next fragrance -->
          <tr>
            <td style="padding:10px 32px 8px;text-align:center;">
              <a href="{{ shop.url }}/account#next-shipment"
                 style="display:inline-block;padding:14px 28px;background:#2D4641;color:#fff;text-decoration:none;border-radius:8px;font:700 14px/1 -apple-system,sans-serif;letter-spacing:0.04em;">
                Pick Your Next Fragrance →
              </a>
            </td>
          </tr>

          <!-- ROSCA-mandated cancel disclosure -->
          <tr>
            <td style="padding:24px 32px 10px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#FFF9ED;border:1px solid #E8D8A8;border-radius:8px;padding:16px;">
                <tr>
                  <td>
                    <p style="font:700 13px/1.3 -apple-system,sans-serif;color:#4D3E1F;margin:0 0 6px;">
                      Don't want to continue? Cancel in one click.
                    </p>
                    <p style="font:400 13px/1.5 -apple-system,sans-serif;color:#6B5A2B;margin:0 0 10px;">
                      We mean it — no phone calls, no friction. Cancel anytime before your next charge and you won't be billed again.
                    </p>
                    <a href="{{ shop.url }}/account#subscription"
                       style="color:#B08C2E;text-decoration:underline;font:700 13px/1 -apple-system,sans-serif;">
                      Cancel my subscription →
                    </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:28px 32px;border-top:1px solid #EDE8DC;font:400 12px/1.5 -apple-system,sans-serif;color:#8a918e;text-align:center;">
              <p style="margin:0 0 6px;">
                Questions? Reply to this email — a human reads every one.
              </p>
              <p style="margin:0;">
                Base Note · <a href="{{ shop.url }}" style="color:#8a918e;">{{ shop.domain }}</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
