{% comment %}
  Email Reference: Dunning Day 1 — Soft Payment Reminder
  PURPOSE: Klaviyo design reference — NOT rendered by the theme.
  Sent 1 day after a failed payment attempt. Tone: friendly, helpful.
{% endcomment %}

<!-- DUNNING DAY 1 EMAIL -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quick heads up about your payment</title>
</head>
<body style="margin:0;padding:0;background:#F5F3F0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <!-- Header -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#2D4641;">
    <tr>
      <td align="center" style="padding:24px;">
        <span style="font-family:Georgia,'Times New Roman',serif;font-size:24px;font-weight:bold;color:#fff;letter-spacing:0.05em;">BASE NOTE</span>
      </td>
    </tr>
  </table>

  <!-- Body -->
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;">

          <!-- Gold accent bar -->
          <tr><td style="height:4px;background:#C9A962;"></td></tr>

          <tr>
            <td style="padding:40px 32px;text-align:center;">

              <!-- Friendly icon -->
              <div style="margin-bottom:20px;">
                <span style="display:inline-block;width:56px;height:56px;background:rgba(201,169,98,0.1);border-radius:50%;line-height:56px;font-size:28px;">&#128179;</span>
              </div>

              <h1 style="font-family:Georgia,'Times New Roman',serif;font-size:26px;color:#2D4641;margin:0 0 12px;">Quick heads up, {{ first_name }}</h1>
              <p style="font-size:16px;color:#666;line-height:1.6;margin:0 0 28px;max-width:440px;display:inline-block;">We tried to process your subscription payment of <strong style="color:#2D4641;">{{ charge_amount }}</strong> but it didn't go through. This happens sometimes — no worries!</p>

              <!-- What happened -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#FAF8F5;border-radius:12px;margin-bottom:28px;">
                <tr>
                  <td style="padding:20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Amount</td>
                        <td style="font-size:14px;color:#2D4641;font-weight:bold;text-align:right;padding:6px 0;">{{ charge_amount }}</td>
                      </tr>
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Card ending in</td>
                        <td style="font-size:14px;color:#2D4641;font-weight:bold;text-align:right;padding:6px 0;">{{ card_last_four }}</td>
                      </tr>
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Next retry</td>
                        <td style="font-size:14px;color:#2D4641;font-weight:bold;text-align:right;padding:6px 0;">{{ next_retry_date }}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <p style="font-size:14px;color:#666;line-height:1.6;margin:0 0 24px;">The most common fix is simply updating your card details. We'll retry automatically in 2 days, but you can fix it now to keep your subscription active.</p>

              <!-- CTA -->
              <a href="{{ update_payment_url }}" style="display:inline-block;padding:16px 48px;background:#2D4641;color:#fff;font-size:14px;font-weight:bold;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;border-radius:6px;">Update Payment Method</a>

              <hr style="border:none;border-top:1px solid #E8E6E3;margin:32px 0;">

              <p style="font-size:12px;color:#999;margin:0;">Need help? Reply to this email or contact <a href="mailto:hello@basenote.com" style="color:#C9A962;">hello@basenote.com</a></p>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table width="600" cellpadding="0" cellspacing="0">
          <tr>
            <td style="padding:24px;text-align:center;">
              <p style="font-size:12px;color:#999;margin:0 0 8px;">Base Note — Luxury Fragrances, Delivered Monthly</p>
              <p style="font-size:11px;color:#bbb;margin:0;"><a href="{{ unsubscribe_url }}" style="color:#bbb;">Unsubscribe</a> | <a href="{{ manage_preferences_url }}" style="color:#bbb;">Manage Preferences</a></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

</body>
</html>
