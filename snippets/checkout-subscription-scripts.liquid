{%- comment -%}
  Checkout Subscription Scripts
  PURPOSE: Additional scripts for Shopify's hosted checkout page.
  USAGE: Paste this content into Settings > Checkout > Additional Scripts in Shopify Admin.
  These scripts run on the order status / thank-you page after checkout.
{%- endcomment -%}

<script>
  // ─── Subscription Disclosure & Consent Tracking ───
  // Runs on the Shopify order status page after a subscription purchase.
  (function() {
    if (typeof Shopify === 'undefined' || typeof Shopify.checkout === 'undefined') return;

    var checkout = Shopify.checkout;
    var lineItems = checkout.line_items || [];

    // Detect if any line item has a selling plan (= subscription)
    var hasSubscription = lineItems.some(function(item) {
      return item.selling_plan_allocation != null;
    });

    if (!hasSubscription) return;

    // ─── 1. Store consent timestamp for chargeback evidence ───
    var consentData = {
      orderId: checkout.order_id,
      orderNumber: checkout.order_number,
      email: checkout.email,
      consentTimestamp: new Date().toISOString(),
      subscriptionItems: lineItems
        .filter(function(item) { return item.selling_plan_allocation != null; })
        .map(function(item) {
          return {
            title: item.title,
            variantTitle: item.variant_title,
            sellingPlan: item.selling_plan_allocation.selling_plan.name,
            price: item.price
          };
        })
    };

    // Store locally for reference
    try {
      localStorage.setItem('bn_subscription_consent_' + checkout.order_id, JSON.stringify(consentData));
    } catch(e) {}

    // ─── 2. Display subscription confirmation banner ───
    var statusSection = document.querySelector('.os-step__special-description') ||
                        document.querySelector('.content-box') ||
                        document.querySelector('.main__content');

    if (statusSection) {
      var banner = document.createElement('div');
      banner.style.cssText = 'background:#2D4641;color:#fff;padding:20px 24px;border-radius:8px;margin:16px 0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;';
      banner.innerHTML = [
        '<div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">',
        '  <span style="display:inline-flex;width:32px;height:32px;background:rgba(201,169,98,0.2);border-radius:50%;align-items:center;justify-content:center;font-size:18px;">&#10003;</span>',
        '  <strong style="font-size:16px;">Your Subscription is Active</strong>',
        '</div>',
        '<p style="font-size:14px;color:rgba(255,255,255,0.8);margin:0 0 8px;line-height:1.5;">',
        '  Your subscription will auto-renew on the same date each month. You can manage, skip, or cancel anytime from your account dashboard.',
        '</p>',
        '<p style="font-size:12px;color:rgba(255,255,255,0.5);margin:0;">',
        '  Consent recorded at ' + consentData.consentTimestamp.replace('T', ' ').split('.')[0] + ' UTC',
        '</p>'
      ].join('');

      statusSection.parentNode.insertBefore(banner, statusSection.nextSibling);
    }

    // ─── 3. Calculate and display next billing date ───
    var nextBillDate = new Date();
    nextBillDate.setMonth(nextBillDate.getMonth() + 1);
    var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    var nextBillStr = months[nextBillDate.getMonth()] + ' ' + nextBillDate.getDate() + ', ' + nextBillDate.getFullYear();

    var billNotice = document.createElement('div');
    billNotice.style.cssText = 'background:#FAF8F5;border:1px solid #E8E6E3;padding:16px 20px;border-radius:8px;margin:12px 0;font-family:-apple-system,BlinkMacSystemFont,sans-serif;';
    billNotice.innerHTML = [
      '<p style="font-size:13px;color:#666;margin:0;">',
      '  <strong style="color:#2D4641;">Next billing date:</strong> ' + nextBillStr,
      '  &nbsp;&middot;&nbsp; <a href="/account#subscription" style="color:#C9A962;text-decoration:underline;">Manage subscription</a>',
      '</p>'
    ].join('');

    if (statusSection) {
      var existingBanner = statusSection.nextSibling ? statusSection.nextSibling.nextSibling : null;
      if (existingBanner) {
        existingBanner.parentNode.insertBefore(billNotice, existingBanner.nextSibling);
      } else {
        statusSection.parentNode.appendChild(billNotice);
      }
    }

    // ─── 4. Store subscription data for account portal ───
    try {
      localStorage.setItem('bn_active_subscription', JSON.stringify({
        active: true,
        orderId: checkout.order_id,
        startDate: new Date().toISOString(),
        nextBillDate: nextBillDate.toISOString(),
        plan: consentData.subscriptionItems[0] ? consentData.subscriptionItems[0].sellingPlan : 'Monthly'
      }));
    } catch(e) {}

  })();
</script>
