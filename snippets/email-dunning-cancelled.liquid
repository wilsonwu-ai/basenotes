{% comment %}
  Email Reference: Dunning — Subscription Cancelled
  PURPOSE: Klaviyo design reference — NOT rendered by the theme.
  Sent 7 days after initial failure when subscription is cancelled. Tone: empathetic, reactivation CTA.
{% endcomment %}

<!-- DUNNING CANCELLED EMAIL -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your subscription has been cancelled</title>
</head>
<body style="margin:0;padding:0;background:#F5F3F0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;">

  <!-- Header -->
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#2D4641;">
    <tr>
      <td align="center" style="padding:24px;">
        <span style="font-family:Georgia,'Times New Roman',serif;font-size:24px;font-weight:bold;color:#fff;letter-spacing:0.05em;">BASE NOTE</span>
      </td>
    </tr>
  </table>

  <!-- Body -->
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center" style="padding:32px 16px;">
        <table width="600" cellpadding="0" cellspacing="0" style="background:#fff;border-radius:12px;overflow:hidden;">

          <!-- Gray accent bar -->
          <tr><td style="height:4px;background:#9E9E9E;"></td></tr>

          <tr>
            <td style="padding:40px 32px;text-align:center;">

              <h1 style="font-family:Georgia,'Times New Roman',serif;font-size:26px;color:#2D4641;margin:0 0 12px;">We're sorry to see you go, {{ first_name }}</h1>
              <p style="font-size:16px;color:#666;line-height:1.6;margin:0 0 28px;max-width:460px;display:inline-block;">Your Base Note subscription has been cancelled due to a payment issue. We understand things happen and we'd love to have you back whenever you're ready.</p>

              <!-- What happened -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:#FAF8F5;border-radius:12px;margin-bottom:28px;">
                <tr>
                  <td style="padding:20px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Status</td>
                        <td style="font-size:14px;color:#9E9E9E;font-weight:bold;text-align:right;padding:6px 0;">Cancelled</td>
                      </tr>
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Reason</td>
                        <td style="font-size:14px;color:#2D4641;font-weight:bold;text-align:right;padding:6px 0;">Payment failed (3 attempts)</td>
                      </tr>
                      <tr>
                        <td style="font-size:13px;color:#999;padding:6px 0;">Effective Date</td>
                        <td style="font-size:14px;color:#2D4641;font-weight:bold;text-align:right;padding:6px 0;">{{ cancellation_date }}</td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Reactivation offer -->
              <table width="100%" cellpadding="0" cellspacing="0" style="background:rgba(201,169,98,0.06);border:1px dashed #C9A962;border-radius:10px;margin-bottom:28px;">
                <tr>
                  <td style="padding:24px;text-align:center;">
                    <p style="font-size:18px;font-weight:bold;color:#2D4641;margin:0 0 4px;font-family:Georgia,'Times New Roman',serif;">Come back and save 20%</p>
                    <p style="font-size:14px;color:#666;margin:0 0 16px;">Reactivate your subscription within 30 days and get 20% off your first month back.</p>
                    <a href="{{ reactivation_url }}" style="display:inline-block;padding:14px 36px;background:#C9A962;color:#2D4641;font-size:14px;font-weight:bold;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;border-radius:6px;">Reactivate for 20% Off</a>
                  </td>
                </tr>
              </table>

              <!-- What you keep -->
              <p style="font-size:13px;color:#666;line-height:1.6;margin:0 0 8px;"><strong style="color:#2D4641;">What you keep:</strong></p>
              <p style="font-size:13px;color:#666;margin:0 0 24px;">Your fragrance history, ratings, and notes are saved in your account. They'll be right where you left them if you come back.</p>

              <a href="{{ account_url }}" style="display:inline-block;padding:14px 36px;background:#2D4641;color:#fff;font-size:13px;font-weight:bold;text-transform:uppercase;letter-spacing:0.08em;text-decoration:none;border-radius:6px;">View Your Account</a>

              <hr style="border:none;border-top:1px solid #E8E6E3;margin:32px 0;">

              <p style="font-size:12px;color:#999;margin:0;">We're here if you need anything. <a href="mailto:hello@basenote.com" style="color:#C9A962;">hello@basenote.com</a></p>
            </td>
          </tr>
        </table>

        <!-- Footer -->
        <table width="600" cellpadding="0" cellspacing="0">
          <tr>
            <td style="padding:24px;text-align:center;">
              <p style="font-size:12px;color:#999;margin:0 0 8px;">Base Note — Luxury Fragrances, Delivered Monthly</p>
              <p style="font-size:11px;color:#bbb;margin:0;"><a href="{{ unsubscribe_url }}" style="color:#bbb;">Unsubscribe</a> | <a href="{{ manage_preferences_url }}" style="color:#bbb;">Manage Preferences</a></p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

</body>
</html>
