{% doc %}
  @prompt
    I want an AI chatbot where the user can ask and receive fragrance recommendations like I like this cologne, what else should I try. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-fragrance-chatbot-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-fragrance-chatbot__container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: {{ block.settings.chat_height }}px;
  }

  .ai-fragrance-chatbot__header-{{ ai_gen_id }} {
    background-color: {{ block.settings.header_bg_color }};
    color: {{ block.settings.header_text_color }};
    padding: 20px;
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-fragrance-chatbot__title-{{ ai_gen_id }} {
    margin: 0 0 4px 0;
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-fragrance-chatbot__subtitle-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.subtitle_size }}px;
    opacity: 0.8;
  }

  .ai-fragrance-chatbot__messages-{{ ai_gen_id }} {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background-color: {{ block.settings.messages_bg_color }};
  }

  .ai-fragrance-chatbot__message-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    animation: ai-fragrance-chatbot-fade-in-{{ ai_gen_id }} 0.3s ease-out;
  }

  @keyframes ai-fragrance-chatbot-fade-in-{{ ai_gen_id }} {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ai-fragrance-chatbot__message--user-{{ ai_gen_id }} {
    flex-direction: row-reverse;
  }

  .ai-fragrance-chatbot__avatar-{{ ai_gen_id }} {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
  }

  .ai-fragrance-chatbot__avatar--bot-{{ ai_gen_id }} {
    background-color: {{ block.settings.bot_avatar_bg }};
    color: {{ block.settings.bot_avatar_color }};
  }

  .ai-fragrance-chatbot__avatar--user-{{ ai_gen_id }} {
    background-color: {{ block.settings.user_avatar_bg }};
    color: {{ block.settings.user_avatar_color }};
  }

  .ai-fragrance-chatbot__bubble-{{ ai_gen_id }} {
    max-width: 75%;
    padding: 12px 16px;
    border-radius: {{ block.settings.bubble_radius }}px;
    font-size: {{ block.settings.message_size }}px;
    line-height: 1.5;
  }

  .ai-fragrance-chatbot__bubble--bot-{{ ai_gen_id }} {
    background-color: {{ block.settings.bot_bubble_bg }};
    color: {{ block.settings.bot_bubble_color }};
  }

  .ai-fragrance-chatbot__bubble--user-{{ ai_gen_id }} {
    background-color: {{ block.settings.user_bubble_bg }};
    color: {{ block.settings.user_bubble_color }};
  }

  .ai-fragrance-chatbot__product-card-{{ ai_gen_id }} {
    margin-top: 8px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 8px;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-fragrance-chatbot__product-image-{{ ai_gen_id }} {
    width: 100%;
    height: 150px;
    object-fit: cover;
  }

  .ai-fragrance-chatbot__product-info-{{ ai_gen_id }} {
    padding: 12px;
  }

  .ai-fragrance-chatbot__product-title-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: {{ block.settings.text_color }};
  }

  .ai-fragrance-chatbot__product-price-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.accent_color }};
    margin-bottom: 8px;
  }

  .ai-fragrance-chatbot__product-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: 12px;
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-fragrance-chatbot__typing-{{ ai_gen_id }} {
    display: none;
    gap: 4px;
    padding: 12px 16px;
  }

  .ai-fragrance-chatbot__typing-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.typing_dot_color }};
    animation: ai-fragrance-chatbot-typing-{{ ai_gen_id }} 1.4s infinite;
  }

  .ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }}:nth-child(2) {
    animation-delay: 0.2s;
  }

  .ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }}:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes ai-fragrance-chatbot-typing-{{ ai_gen_id }} {
    0%, 60%, 100% {
      transform: translateY(0);
      opacity: 0.7;
    }
    30% {
      transform: translateY(-10px);
      opacity: 1;
    }
  }

  .ai-fragrance-chatbot__input-area-{{ ai_gen_id }} {
    padding: 16px;
    border-top: 1px solid {{ block.settings.border_color }};
    background-color: {{ block.settings.background_color }};
  }

  .ai-fragrance-chatbot__suggestions-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .ai-fragrance-chatbot__suggestion-{{ ai_gen_id }} {
    padding: 8px 14px;
    background-color: {{ block.settings.suggestion_bg }};
    color: {{ block.settings.suggestion_color }};
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 20px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .ai-fragrance-chatbot__suggestion-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.suggestion_hover_bg }};
    border-color: {{ block.settings.accent_color }};
  }

  .ai-fragrance-chatbot__input-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-fragrance-chatbot__input-{{ ai_gen_id }} {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.input_radius }}px;
    font-size: 14px;
    background-color: {{ block.settings.input_bg }};
    color: {{ block.settings.text_color }};
  }

  .ai-fragrance-chatbot__input-{{ ai_gen_id }}:focus {
    outline: none;
    border-color: {{ block.settings.accent_color }};
  }

  .ai-fragrance-chatbot__send-btn-{{ ai_gen_id }} {
    padding: 12px 20px;
    background-color: {{ block.settings.send_btn_bg }};
    color: {{ block.settings.send_btn_color }};
    border: none;
    border-radius: {{ block.settings.input_radius }}px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: background-color 0.2s ease;
  }

  .ai-fragrance-chatbot__send-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.send_btn_hover_bg }};
  }

  .ai-fragrance-chatbot__send-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-fragrance-chatbot__disclaimer-{{ ai_gen_id }} {
    margin-top: 8px;
    font-size: 11px;
    color: {{ block.settings.disclaimer_color }};
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-fragrance-chatbot__container-{{ ai_gen_id }} {
      height: {{ block.settings.chat_height | times: 0.8 }}px;
    }

    .ai-fragrance-chatbot__bubble-{{ ai_gen_id }} {
      max-width: 85%;
    }

    .ai-fragrance-chatbot__suggestions-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<fragrance-chatbot-{{ ai_gen_id }}
  class="ai-fragrance-chatbot-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-fragrance-chatbot__container-{{ ai_gen_id }}">
    <div class="ai-fragrance-chatbot__header-{{ ai_gen_id }}">
      <h3 class="ai-fragrance-chatbot__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
      <p class="ai-fragrance-chatbot__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    </div>

    <div class="ai-fragrance-chatbot__messages-{{ ai_gen_id }}" data-messages>
      <div class="ai-fragrance-chatbot__message-{{ ai_gen_id }}">
        <div class="ai-fragrance-chatbot__avatar-{{ ai_gen_id }} ai-fragrance-chatbot__avatar--bot-{{ ai_gen_id }}">
          {{ block.settings.bot_avatar_icon }}
        </div>
        <div class="ai-fragrance-chatbot__bubble-{{ ai_gen_id }} ai-fragrance-chatbot__bubble--bot-{{ ai_gen_id }}">
          {{ block.settings.welcome_message }}
        </div>
      </div>
    </div>

    <div class="ai-fragrance-chatbot__input-area-{{ ai_gen_id }}">
      <div class="ai-fragrance-chatbot__suggestions-{{ ai_gen_id }}" data-suggestions>
        {% assign suggestions = block.settings.quick_suggestions | split: '|' %}
        {% for suggestion in suggestions %}
          <button class="ai-fragrance-chatbot__suggestion-{{ ai_gen_id }}" data-suggestion>
            {{ suggestion }}
          </button>
        {% endfor %}
      </div>

      <div class="ai-fragrance-chatbot__input-wrapper-{{ ai_gen_id }}">
        <input
          type="text"
          class="ai-fragrance-chatbot__input-{{ ai_gen_id }}"
          placeholder="{{ block.settings.input_placeholder }}"
          data-input
          aria-label="Type your message"
        >
        <button
          class="ai-fragrance-chatbot__send-btn-{{ ai_gen_id }}"
          data-send
          aria-label="Send message"
        >
          {{ block.settings.send_button_text }}
        </button>
      </div>

      {% if block.settings.show_disclaimer %}
        <p class="ai-fragrance-chatbot__disclaimer-{{ ai_gen_id }}">
          {{ block.settings.disclaimer_text }}
        </p>
      {% endif %}
    </div>
  </div>
</fragrance-chatbot-{{ ai_gen_id }}>

<script>
  (function() {
    class FragranceChatbot{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.messagesContainer = this.querySelector('[data-messages]');
        this.input = this.querySelector('[data-input]');
        this.sendBtn = this.querySelector('[data-send]');
        this.suggestionsContainer = this.querySelector('[data-suggestions]');
        
        this.fragranceDatabase = [
          {
            name: 'Dior Sauvage',
            price: '$89',
            notes: ['bergamot', 'pepper', 'ambroxan'],
            profile: 'fresh woody aromatic',
            url: '/products/dior-sauvage',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          },
          {
            name: 'Bleu de Chanel',
            price: '$95',
            notes: ['citrus', 'cedar', 'sandalwood'],
            profile: 'woody aromatic',
            url: '/products/bleu-de-chanel',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          },
          {
            name: 'Tom Ford Oud Wood',
            price: '$240',
            notes: ['oud', 'rosewood', 'cardamom'],
            profile: 'woody spicy',
            url: '/products/tom-ford-oud-wood',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          },
          {
            name: 'Creed Aventus',
            price: '$445',
            notes: ['pineapple', 'birch', 'musk'],
            profile: 'fruity woody',
            url: '/products/creed-aventus',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          },
          {
            name: 'Acqua di Gio',
            price: '$82',
            notes: ['marine', 'citrus', 'rosemary'],
            profile: 'aquatic aromatic',
            url: '/products/acqua-di-gio',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          },
          {
            name: 'Yves Saint Laurent La Nuit',
            price: '$98',
            notes: ['cardamom', 'lavender', 'cedar'],
            profile: 'aromatic spicy',
            url: '/products/ysl-la-nuit',
            image: 'https://cdn.shopify.com/s/files/1/0000/0000/0000/products/placeholder.jpg'
          }
        ];
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.sendBtn.addEventListener('click', () => this.handleSend());
        this.input.addEventListener('keypress', (e) => {
          if (e.key === 'Enter') {
            this.handleSend();
          }
        });

        this.querySelectorAll('[data-suggestion]').forEach(btn => {
          btn.addEventListener('click', (e) => {
            this.input.value = e.target.textContent.trim();
            this.handleSend();
          });
        });
      }

      handleSend() {
        const message = this.input.value.trim();
        if (!message) return;

        this.addMessage(message, 'user');
        this.input.value = '';
        this.hideSuggestions();

        this.showTyping();
        setTimeout(() => {
          this.hideTyping();
          this.generateResponse(message);
        }, 1500);
      }

      addMessage(text, sender) {
        const messageDiv = document.createElement('div');
        messageDiv.className = `ai-fragrance-chatbot__message-{{ ai_gen_id }} ${sender === 'user' ? 'ai-fragrance-chatbot__message--user-{{ ai_gen_id }}' : ''}`;

        const avatar = document.createElement('div');
        avatar.className = `ai-fragrance-chatbot__avatar-{{ ai_gen_id }} ai-fragrance-chatbot__avatar--${sender}-{{ ai_gen_id }}`;
        avatar.innerHTML = sender === 'bot' ? '{{ block.settings.bot_avatar_icon }}' : '{{ block.settings.user_avatar_icon }}';

        const bubble = document.createElement('div');
        bubble.className = `ai-fragrance-chatbot__bubble-{{ ai_gen_id }} ai-fragrance-chatbot__bubble--${sender}-{{ ai_gen_id }}`;
        bubble.textContent = text;

        messageDiv.appendChild(avatar);
        messageDiv.appendChild(bubble);
        this.messagesContainer.appendChild(messageDiv);
        this.scrollToBottom();
      }

      addProductCard(product) {
        const messageDiv = document.createElement('div');
        messageDiv.className = 'ai-fragrance-chatbot__message-{{ ai_gen_id }}';

        const avatar = document.createElement('div');
        avatar.className = 'ai-fragrance-chatbot__avatar-{{ ai_gen_id }} ai-fragrance-chatbot__avatar--bot-{{ ai_gen_id }}';
        avatar.innerHTML = '{{ block.settings.bot_avatar_icon }}';

        const bubble = document.createElement('div');
        bubble.className = 'ai-fragrance-chatbot__bubble-{{ ai_gen_id }} ai-fragrance-chatbot__bubble--bot-{{ ai_gen_id }}';

        const card = document.createElement('div');
        card.className = 'ai-fragrance-chatbot__product-card-{{ ai_gen_id }}';
        card.innerHTML = `
          <img src="${product.image}" alt="${product.name}" class="ai-fragrance-chatbot__product-image-{{ ai_gen_id }}" loading="lazy">
          <div class="ai-fragrance-chatbot__product-info-{{ ai_gen_id }}">
            <h4 class="ai-fragrance-chatbot__product-title-{{ ai_gen_id }}">${product.name}</h4>
            <p class="ai-fragrance-chatbot__product-price-{{ ai_gen_id }}">${product.price}</p>
            <a href="${product.url}" class="ai-fragrance-chatbot__product-link-{{ ai_gen_id }}">View details →</a>
          </div>
        `;

        bubble.appendChild(card);
        messageDiv.appendChild(avatar);
        messageDiv.appendChild(bubble);
        this.messagesContainer.appendChild(messageDiv);
        this.scrollToBottom();
      }

      generateResponse(userMessage) {
        const lowerMessage = userMessage.toLowerCase();
        
        if (lowerMessage.includes('sauvage') || lowerMessage.includes('dior')) {
          this.addMessage('Great choice! If you like Dior Sauvage, you might also enjoy these similar fragrances:', 'bot');
          setTimeout(() => {
            this.addProductCard(this.fragranceDatabase[1]);
            setTimeout(() => this.addProductCard(this.fragranceDatabase[4]), 500);
          }, 300);
        } else if (lowerMessage.includes('fresh') || lowerMessage.includes('citrus') || lowerMessage.includes('summer')) {
          this.addMessage('For fresh, citrusy scents perfect for summer, I recommend:', 'bot');
          setTimeout(() => {
            this.addProductCard(this.fragranceDatabase[4]);
            setTimeout(() => this.addProductCard(this.fragranceDatabase[1]), 500);
          }, 300);
        } else if (lowerMessage.includes('woody') || lowerMessage.includes('warm') || lowerMessage.includes('winter')) {
          this.addMessage('For warm, woody fragrances ideal for cooler weather:', 'bot');
          setTimeout(() => {
            this.addProductCard(this.fragranceDatabase[2]);
            setTimeout(() => this.addProductCard(this.fragranceDatabase[1]), 500);
          }, 300);
        } else if (lowerMessage.includes('luxury') || lowerMessage.includes('expensive') || lowerMessage.includes('premium')) {
          this.addMessage('Here are some premium luxury fragrances:', 'bot');
          setTimeout(() => {
            this.addProductCard(this.fragranceDatabase[3]);
            setTimeout(() => this.addProductCard(this.fragranceDatabase[2]), 500);
          }, 300);
        } else if (lowerMessage.includes('spicy') || lowerMessage.includes('evening') || lowerMessage.includes('date')) {
          this.addMessage('For evening wear with spicy notes:', 'bot');
          setTimeout(() => {
            this.addProductCard(this.fragranceDatabase[5]);
            setTimeout(() => this.addProductCard(this.fragranceDatabase[2]), 500);
          }, 300);
        } else {
          this.addMessage('Based on your preferences, here are some fragrances you might love:', 'bot');
          setTimeout(() => {
            const randomIndex = Math.floor(Math.random() * this.fragranceDatabase.length);
            this.addProductCard(this.fragranceDatabase[randomIndex]);
            const secondIndex = (randomIndex + 1) % this.fragranceDatabase.length;
            setTimeout(() => this.addProductCard(this.fragranceDatabase[secondIndex]), 500);
          }, 300);
        }
      }

      showTyping() {
        const typingDiv = document.createElement('div');
        typingDiv.className = 'ai-fragrance-chatbot__message-{{ ai_gen_id }}';
        typingDiv.setAttribute('data-typing', '');

        const avatar = document.createElement('div');
        avatar.className = 'ai-fragrance-chatbot__avatar-{{ ai_gen_id }} ai-fragrance-chatbot__avatar--bot-{{ ai_gen_id }}';
        avatar.innerHTML = '{{ block.settings.bot_avatar_icon }}';

        const bubble = document.createElement('div');
        bubble.className = 'ai-fragrance-chatbot__bubble-{{ ai_gen_id }} ai-fragrance-chatbot__bubble--bot-{{ ai_gen_id }}';

        const typing = document.createElement('div');
        typing.className = 'ai-fragrance-chatbot__typing-{{ ai_gen_id }} active';
        typing.innerHTML = `
          <div class="ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }}"></div>
          <div class="ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }}"></div>
          <div class="ai-fragrance-chatbot__typing-dot-{{ ai_gen_id }}"></div>
        `;

        bubble.appendChild(typing);
        typingDiv.appendChild(avatar);
        typingDiv.appendChild(bubble);
        this.messagesContainer.appendChild(typingDiv);
        this.scrollToBottom();
      }

      hideTyping() {
        const typingIndicator = this.querySelector('[data-typing]');
        if (typingIndicator) {
          typingIndicator.remove();
        }
      }

      hideSuggestions() {
        this.suggestionsContainer.style.display = 'none';
      }

      scrollToBottom() {
        this.messagesContainer.scrollTop = this.messagesContainer.scrollHeight;
      }
    }

    customElements.define('fragrance-chatbot-{{ ai_gen_id }}', FragranceChatbot{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Fragrance AI chatbot",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Fragrance Finder"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Ask me for personalized recommendations"
    },
    {
      "type": "textarea",
      "id": "welcome_message",
      "label": "Welcome message",
      "default": "Hi! I'm your fragrance expert. Tell me about a cologne you love, and I'll recommend similar scents you might enjoy."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "e.g., I like Dior Sauvage..."
    },
    {
      "type": "text",
      "id": "send_button_text",
      "label": "Send button text",
      "default": "Send"
    },
    {
      "type": "textarea",
      "id": "quick_suggestions",
      "label": "Quick suggestions",
      "default": "I like fresh citrus scents|Recommend something woody|What's good for summer?|Show me luxury fragrances",
      "info": "Separate suggestions with | character"
    },
    {
      "type": "header",
      "content": "Avatars"
    },
    {
      "type": "text",
      "id": "bot_avatar_icon",
      "label": "Bot avatar icon",
      "default": "🌿"
    },
    {
      "type": "text",
      "id": "user_avatar_icon",
      "label": "User avatar icon",
      "default": "👤"
    },
    {
      "type": "header",
      "content": "Disclaimer"
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show disclaimer",
      "default": true
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "default": "AI-powered recommendations. Results may vary."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "chat_height",
      "label": "Chat height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "bubble_radius",
      "label": "Message bubble radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "input_radius",
      "label": "Input radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "subtitle_size",
