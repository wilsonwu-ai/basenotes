{% doc %}
  @prompt
    Create a "Fragrance Finder" section for a perfume/fragrance brand called Base Note. The section should feature an AI-powered chatbot interface embedded directly on the page (not a popup widget) where customers can describe fragrances they already love (e.g., "I like YSL Y, what else would I like?") and receive personalized fragrance recommendations from the store's product catalog. The section should have an elegant, editorial design that fits a luxury fragrance brand — think dark/moody tones or clean minimalist aesthetic. It should include a heading like "Find Your Scent", a short description inviting customers to describe their preferences, a chat input area where users can type their question, a conversation display area showing the back-and-forth, and recommendation cards that surface matching products with name, image, and a link to buy. The chatbot responses should be powered by an AI API call (e.g., OpenAI) that is given context about the store's fragrance products to make relevant recommendations., could the fragrances recommended only be for this store. Using themes of store, can we make the conversation box 1/4 the size, can i make this a popup option for the user, center
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    min-height: {{ block.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: {{ block.settings.overlay_color }};
  }

  .ai-hero-banner-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .ai-hero-banner-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-hero-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px 20px;
    color: {{ block.settings.text_color }};
  }

  .ai-hero-banner-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_size }}px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 16px;
    color: {{ block.settings.eyebrow_color }};
    font-family: {{ block.settings.font_heading.family }}, {{ block.settings.font_heading.fallback_families }};
  }

  .ai-hero-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 20px;
    font-family: {{ block.settings.font_heading.family }}, {{ block.settings.font_heading.fallback_families }};
  }

  .ai-hero-banner-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin: 0 0 32px;
    opacity: 0.9;
    font-family: {{ block.settings.font_body.family }}, {{ block.settings.font_body.fallback_families }};
  }

  .ai-hero-banner-buttons-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .ai-hero-banner-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: 2px solid transparent;
    font-family: {{ block.settings.font_body.family }}, {{ block.settings.font_body.fallback_families }};
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_primary_bg }};
    color: {{ block.settings.button_primary_text_color }};
    border-color: {{ block.settings.button_primary_bg }};
  }

  .ai-hero-banner-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_primary_hover_bg }};
    border-color: {{ block.settings.button_primary_hover_bg }};
    transform: translateY(-2px);
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.button_secondary_bg }};
    color: {{ block.settings.button_secondary_text_color }};
    border-color: {{ block.settings.button_secondary_border }};
  }

  .ai-hero-banner-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_secondary_hover_bg }};
    color: {{ block.settings.button_secondary_hover_text }};
    border-color: {{ block.settings.button_secondary_hover_border }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner-{{ ai_gen_id }} {
      min-height: {{ block.settings.min_height_mobile }}px;
    }

    .ai-hero-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-hero-banner-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-hero-banner-buttons-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-hero-banner-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <img
      src="{{ block.settings.background_image | image_url: width: 2000 }}"
      alt="{{ block.settings.background_image.alt | escape }}"
      class="ai-hero-banner-bg-{{ ai_gen_id }}"
      loading="eager"
      width="{{ block.settings.background_image.width }}"
      height="{{ block.settings.background_image.height }}"
    >
  {% endif %}

  <div class="ai-hero-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-hero-banner-content-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-hero-banner-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow }}
      </div>
    {% endif %}

    {% if block.settings.heading != blank %}
      <h1 class="ai-hero-banner-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h1>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-hero-banner-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    <div class="ai-hero-banner-buttons-{{ ai_gen_id }}">
      {% if block.settings.button_primary_label != blank %}
        <a
          href="{{ block.settings.button_primary_link }}"
          class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-primary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_primary_label }}
        </a>
      {% endif %}

      {% if block.settings.button_secondary_label != blank %}
        <a
          href="{{ block.settings.button_secondary_link }}"
          class="ai-hero-banner-button-{{ ai_gen_id }} ai-hero-banner-button-secondary-{{ ai_gen_id }}"
        >
          {{ block.settings.button_secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

