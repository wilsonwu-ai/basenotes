{% doc %}
  @prompt
    Create a price comparison table section with the following columns: "Fragrance", "Competitors", "Our Price". The table should display these rows:
    - Creed Aventus 5ml | $35–45 | $20 / month
    - Parfums de Marly Layton 5ml | $30–40 | $20 / month
    - Tom Ford Ombré Leather 5ml | $30–38 | $20 / month
    - Bond No. 9 Bleecker St. 5ml | $32–42 | $20 / month
    
    Style it with an earthy, premium aesthetic. The "Our Price" column should be visually highlighted to stand out (e.g., bold, accent color, or checkmark). Make it mobile-responsive., change tom ford ombre leather to tom ford oud wood
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-price-comparison-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-price-comparison__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-price-comparison__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-price-comparison__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-price-comparison__table-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .ai-price-comparison__table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    background-color: {{ block.settings.table_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  .ai-price-comparison__table-{{ ai_gen_id }} thead {
    background-color: {{ block.settings.header_background }};
  }

  .ai-price-comparison__table-{{ ai_gen_id }} th {
    padding: {{ block.settings.cell_padding }}px;
    text-align: left;
    font-size: {{ block.settings.header_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.header_text_color }};
    border-bottom: 2px solid {{ block.settings.border_color }};
  }

  .ai-price-comparison__table-{{ ai_gen_id }} td {
    padding: {{ block.settings.cell_padding }}px;
    font-size: {{ block.settings.body_font_size }}px;
    color: {{ block.settings.body_text_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-price-comparison__table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-price-comparison__table-{{ ai_gen_id }} tbody tr:hover {
    background-color: {{ block.settings.row_hover_color }};
  }

  .ai-price-comparison__highlight-cell-{{ ai_gen_id }} {
    background-color: {{ block.settings.highlight_background }} !important;
    font-weight: 700;
    color: {{ block.settings.highlight_text_color }};
    position: relative;
  }

  .ai-price-comparison__checkmark-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .ai-price-comparison__checkmark-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .ai-price-comparison__competitor-price-{{ ai_gen_id }} {
    color: {{ block.settings.competitor_price_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-price-comparison__table-{{ ai_gen_id }} th,
    .ai-price-comparison__table-{{ ai_gen_id }} td {
      padding: {{ block.settings.cell_padding | times: 0.7 }}px;
      font-size: {{ block.settings.body_font_size | times: 0.9 }}px;
    }

    .ai-price-comparison__table-{{ ai_gen_id }} th {
      font-size: {{ block.settings.header_font_size | times: 0.9 }}px;
    }

    .ai-price-comparison__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-price-comparison__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-price-comparison__checkmark-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }
  }
{% endstyle %}

<price-comparison-{{ ai_gen_id }}
  class="ai-price-comparison-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-price-comparison__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-price-comparison__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-price-comparison__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-price-comparison__table-wrapper-{{ ai_gen_id }}">
    <table class="ai-price-comparison__table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>{{ block.settings.column_1_header }}</th>
          <th>{{ block.settings.column_2_header }}</th>
          <th>{{ block.settings.column_3_header }}</th>
        </tr>
      </thead>
      <tbody>
        {% for i in (1..4) %}
          {% liquid
            assign product_key = 'row_' | append: i | append: '_product'
            assign competitor_key = 'row_' | append: i | append: '_competitor'
            assign price_key = 'row_' | append: i | append: '_price'

            assign product_name = block.settings[product_key]
            assign competitor_price = block.settings[competitor_key]
            assign our_price = block.settings[price_key]
          %}

          {% if product_name != blank %}
            <tr>
              <td>{{ product_name }}</td>
              <td class="ai-price-comparison__competitor-price-{{ ai_gen_id }}">{{ competitor_price }}</td>
              <td class="ai-price-comparison__highlight-cell-{{ ai_gen_id }}">
                <span class="ai-price-comparison__checkmark-{{ ai_gen_id }}">
                  {% if block.settings.show_checkmark %}
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  {% endif %}
                  <span>{{ our_price }}</span>
                </span>
              </td>
            </tr>
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  </div>
</price-comparison-{{ ai_gen_id }}>

<script>
  (function() {
    class PriceComparison{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('price-comparison-{{ ai_gen_id }}', PriceComparison{{ ai_gen_id }});
  })();
</script>

