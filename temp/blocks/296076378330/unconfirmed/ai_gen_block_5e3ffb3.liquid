<subscription-benefits-{{ ai_gen_id }} class="ai-sub-benefits-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sub-benefits__container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow != blank %}
      <div class="ai-sub-benefits__eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-sub-benefits__headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subhead != blank %}
      <div class="ai-sub-benefits__subhead-{{ ai_gen_id }}">{{ block.settings.subhead }}</div>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-sub-benefits__divider-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-sub-benefits__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% assign benefit_enabled_key = 'benefit_' | append: i | append: '_enabled' %}
        {% assign benefit_icon_key = 'benefit_' | append: i | append: '_icon' %}
        {% assign benefit_label_key = 'benefit_' | append: i | append: '_label' %}
        {% assign benefit_title_key = 'benefit_' | append: i | append: '_title' %}
        {% assign benefit_desc_key = 'benefit_' | append: i | append: '_description' %}

        {% if block.settings[benefit_enabled_key] %}
          <div class="ai-sub-benefits__card-{{ ai_gen_id }}">
            <div class="ai-sub-benefits__icon-wrap-{{ ai_gen_id }}">
              <div class="ai-sub-benefits__icon-{{ ai_gen_id }}">
                {{ block.settings[benefit_icon_key] }}
              </div>
            </div>
            {% if block.settings[benefit_label_key] != blank %}
              <div class="ai-sub-benefits__label-{{ ai_gen_id }}">{{ block.settings[benefit_label_key] }}</div>
            {% endif %}
            {% if block.settings[benefit_title_key] != blank %}
              <h3 class="ai-sub-benefits__title-{{ ai_gen_id }}">{{ block.settings[benefit_title_key] }}</h3>
            {% endif %}
            {% if block.settings[benefit_desc_key] != blank %}
              <div class="ai-sub-benefits__desc-{{ ai_gen_id }}">{{ block.settings[benefit_desc_key] }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_seasons %}
      <div class="ai-sub-benefits__scent-strip-{{ ai_gen_id }}">
        {% for i in (1..4) %}
          {% assign season_enabled_key = 'season_' | append: i | append: '_enabled' %}
          {% assign season_icon_key = 'season_' | append: i | append: '_icon' %}
          {% assign season_name_key = 'season_' | append: i | append: '_name' %}
          {% assign season_note_key = 'season_' | append: i | append: '_note' %}

          {% if block.settings[season_enabled_key] %}
            <div class="ai-sub-benefits__season-{{ ai_gen_id }}" data-season="{{ i }}">
              <span class="ai-sub-benefits__season-icon-{{ ai_gen_id }}">{{ block.settings[season_icon_key] }}</span>
              <span class="ai-sub-benefits__season-name-{{ ai_gen_id }}">{{ block.settings[season_name_key] }}</span>
              <div class="ai-sub-benefits__season-note-{{ ai_gen_id }}">{{ block.settings[season_note_key] }}</div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <div class="ai-sub-benefits__cta-row-{{ ai_gen_id }}">
      {% if block.settings.primary_button_text != blank %}
        <a href="{{ block.settings.primary_button_link }}" class="ai-sub-benefits__btn-primary-{{ ai_gen_id }}">
          {{ block.settings.primary_button_text }}
        </a>
      {% endif %}
      {% if block.settings.secondary_button_text != blank %}
        <a href="{{ block.settings.secondary_button_link }}" class="ai-sub-benefits__btn-ghost-{{ ai_gen_id }}">
          {{ block.settings.secondary_button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</subscription-benefits-{{ ai_gen_id }}>

<script>
  (function() {
    class SubscriptionBenefits{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.seasons = this.querySelectorAll('.ai-sub-benefits__season-{{ ai_gen_id }}');
        this.setupSeasonInteractions();
      }

      setupSeasonInteractions() {
        this.seasons.forEach((season) => {
          season.addEventListener('click', () => {
            this.seasons.forEach((s) => s.classList.remove('active'));
            season.classList.add('active');
          });
        });
      }
    }

    customElements.define('subscription-benefits-{{ ai_gen_id }}', SubscriptionBenefits{{ ai_gen_id }});
  })();
</script>

