{% doc %}
  @prompt
    Create a compact, minimal "quick review and idea capture" block with a short quote or testimonial text, a star rating, and a simple call-to-action button. Keep it concise and clean with an earthy, premium aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-review-capture-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 32px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-review-capture__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-review-capture__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .ai-review-capture__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-capture__quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    font-style: italic;
    margin: 0;
  }

  .ai-review-capture__author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_size }}px;
    color: {{ block.settings.author_color }};
    margin: 0;
  }

  .ai-review-capture__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: background-color 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-review-capture__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-review-capture-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-review-capture__content-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

<div class="ai-review-capture-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-review-capture__content-{{ ai_gen_id }}">
    {% if block.settings.show_stars %}
      <div class="ai-review-capture__stars-{{ ai_gen_id }}">
        {% for i in (1..block.settings.star_rating) %}
          <svg class="ai-review-capture__star-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
          </svg>
        {% endfor %}
      </div>
    {% endif %}

    {% if block.settings.quote_text != blank %}
      <p class="ai-review-capture__quote-{{ ai_gen_id }}">
        "{{ block.settings.quote_text }}"
      </p>
    {% endif %}

    {% if block.settings.author_name != blank %}
      <p class="ai-review-capture__author-{{ ai_gen_id }}">
        — {{ block.settings.author_name }}
      </p>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <div>
        <a 
          href="{{ block.settings.button_link }}" 
          class="ai-review-capture__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Quick review capture",
  "settings": [
    {
      "type": "header",
      "content": "Review content"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "range",
      "id": "star_rating",
      "label": "Star rating",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Quote text",
      "default": "This fragrance subscription has completely transformed my collection. Every month feels like a curated gift."
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Sarah M."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Share your story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Star rating"
    },
    {
      "type": "range",
      "id": "star_size",
      "label": "Star size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#c9a86c"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Quote color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "author_size",
      "label": "Author size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "author_color",
      "label": "Author color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button text size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_hover_bg_color",
      "label": "Button hover background",
      "default": "#c9a86c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Quick review capture"
    }
  ]
}
{% endschema %}
