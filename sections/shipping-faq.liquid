{%- comment -%}
  Section: Shipping FAQ
  Use on a Shopify Page with template `page.shipping`.
{%- endcomment -%}

<section class="shipping-faq">
  <div class="shipping-faq__container">

    <p class="shipping-faq__eyebrow">{{ section.settings.eyebrow }}</p>
    <h1 class="shipping-faq__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.intro != blank -%}
      <p class="shipping-faq__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="shipping-faq__cards">
      {%- for block in section.blocks -%}
        <div class="shipping-faq__card" {{ block.shopify_attributes }}>
          <h3 class="shipping-faq__card-title">{{ block.settings.title }}</h3>
          <div class="shipping-faq__card-body">{{ block.settings.body }}</div>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.contact_text != blank -%}
      <p class="shipping-faq__contact">{{ section.settings.contact_text }}</p>
    {%- endif -%}

  </div>
</section>

<style>
  .shipping-faq { padding: 80px 24px; background: #f7f2e6; }
  .shipping-faq__container { max-width: 760px; margin: 0 auto; }
  .shipping-faq__eyebrow { font: 600 10px/1.4 'Montserrat', sans-serif; letter-spacing: 0.35em; text-transform: uppercase; color: #8a6e30; margin-bottom: 16px; }
  .shipping-faq__heading { font: 300 clamp(2rem, 4vw, 3rem)/1.15 'Cormorant Garamond', Georgia, serif; color: #1e4035; margin-bottom: 16px; }
  .shipping-faq__intro { font: 300 1rem/1.8 'Montserrat', sans-serif; color: #6b5e4a; margin-bottom: 48px; max-width: 600px; }
  .shipping-faq__cards { display: grid; grid-template-columns: 1fr; gap: 16px; margin-bottom: 48px; }
  .shipping-faq__card { background: #fff; border: 1px solid rgba(90,70,40,0.15); padding: 28px 32px; border-radius: 4px; }
  .shipping-faq__card-title { font: 400 1.3rem/1.3 'Cormorant Garamond', Georgia, serif; color: #1e4035; margin-bottom: 10px; }
  .shipping-faq__card-body { font: 300 0.92rem/1.7 'Montserrat', sans-serif; color: #2a2520; }
  .shipping-faq__card-body p { margin-bottom: 8px; }
  .shipping-faq__card-body p:last-child { margin-bottom: 0; }
  .shipping-faq__contact { font: 300 0.88rem/1.7 'Montserrat', sans-serif; color: #6b5e4a; padding: 24px; border-top: 1px solid rgba(90,70,40,0.15); }
  .shipping-faq__contact a { color: #b8974a; text-decoration: underline; }
</style>

{% schema %}
{
  "name": "Shipping FAQ",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "SHIPPING & RETURNS" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shipping" },
    { "type": "richtext", "id": "intro", "label": "Intro paragraph", "default": "<p>Everything you need to know about how Base Note ships, where we ship, and how long it takes.</p>" },
    { "type": "richtext", "id": "contact_text", "label": "Contact line", "default": "<p>Question we didn't answer? Email <a href='mailto:hello@basenotescent.com'>hello@basenotescent.com</a> and we'll get back to you within one business day.</p>" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "title", "label": "Question" },
        { "type": "richtext", "id": "body", "label": "Answer" }
      ]
    }
  ],
  "default": {
    "settings": {
      "eyebrow": "SHIPPING & RETURNS",
      "heading": "Shipping"
    },
    "blocks": [
      {
        "type": "faq",
        "settings": {
          "title": "Where do you ship?",
          "body": "<p>We ship throughout the United States. If your state isn't showing at checkout, email us at <a href='mailto:hello@basenotescent.com'>hello@basenotescent.com</a> and we'll confirm coverage.</p>"
        }
      },
      {
        "type": "faq",
        "settings": {
          "title": "When will my fragrance arrive?",
          "body": "<p>Subscriptions ship on the 20th of each month and typically arrive within 3–7 business days of dispatch. You'll get a tracking email as soon as your order leaves our fulfillment partner.</p>"
        }
      },
      {
        "type": "faq",
        "settings": {
          "title": "How much does shipping cost?",
          "body": "<p>Standard shipping is included in your monthly subscription — no hidden fees or surcharges.</p>"
        }
      },
      {
        "type": "faq",
        "settings": {
          "title": "Can I change my shipping address?",
          "body": "<p>Yes. Update your address in <a href='/account'>My Account</a> at any time before the 19th of the month to take effect for the upcoming shipment.</p>"
        }
      },
      {
        "type": "faq",
        "settings": {
          "title": "Returns",
          "body": "<p>Because each fragrance is hand-decanted to order, we don't accept returns of opened vials. If your order arrives damaged or you receive the wrong fragrance, email <a href='mailto:hello@basenotescent.com'>hello@basenotescent.com</a> within 7 days and we'll make it right.</p>"
        }
      }
    ]
  }
}
{% endschema %}
