{% comment %}
  About / Founder section. Bound to templates/page.about.json (OS 2.0).
  Renders the hero + body (page.content from admin) + closing CTA + AboutPage/Person schema.
{% endcomment %}

<article class="about-page">

  <section class="about-hero">
    <div class="about-hero__container">
      <div class="about-hero__media">
        {%- if page.metafields.founder.headshot -%}
          <img
            src="{{ page.metafields.founder.headshot | image_url: width: 900 }}"
            srcset="{{ page.metafields.founder.headshot | image_url: width: 600 }} 600w, {{ page.metafields.founder.headshot | image_url: width: 900 }} 900w, {{ page.metafields.founder.headshot | image_url: width: 1200 }} 1200w"
            sizes="(max-width: 860px) 100vw, 480px"
            alt="Wilson Wu, founder of Base Note"
            class="about-hero__image"
            width="900" height="1125">
        {%- else -%}
          <div class="about-hero__placeholder" aria-label="Founder photo placeholder">
            <svg viewBox="0 0 200 240" fill="none" stroke="currentColor" stroke-width="1.2">
              <circle cx="100" cy="90" r="42"/>
              <path d="M30 230 C30 170, 170 170, 170 230"/>
            </svg>
            <span class="about-hero__placeholder-caption">Headshot coming soon</span>
          </div>
        {%- endif -%}
      </div>
      <div class="about-hero__copy">
        <span class="about-hero__eyebrow">About the founders</span>
        <h1 class="about-hero__title">Jeff Theefs &amp; Alex</h1>
        <p class="about-hero__kicker">Founder &amp; cofounder, Base Note</p>
      </div>
    </div>
  </section>

  <section class="about-body">
    <div class="about-body__container rte">
      {{ page.content }}
    </div>
  </section>

  <section class="about-cta">
    <div class="about-cta__container">
      <h2 class="about-cta__title">Try one for yourself.</h2>
      <p class="about-cta__subtitle">$20 flat. Every fragrance. No surcharges. Cancel in one click.</p>
      <a href="/pages/find-your-scent" class="about-cta__button">Find My Scent</a>
      <p class="about-cta__secondary">
        Prefer reading first?
        <a href="/blogs/hub/best-fragrance-subscriptions-2026-comparison">The honest comparison</a>
        &middot;
        <a href="/blogs/hub/scentbird-alternatives-what-subscribers-switch-to">Scentbird alternatives</a>
      </p>
    </div>
  </section>

</article>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "url": "{{ shop.url }}{{ page.url }}",
  "name": "About Base Note",
  "description": "The founder story behind Base Note, a flat-priced luxury fragrance subscription.",
  "mainEntity": {
    "@type": "Person",
    "name": "Wilson Wu",
    "jobTitle": "Founder",
    "worksFor": {
      "@type": "Organization",
      "name": "Base Note",
      "url": "{{ shop.url }}"
    },
    "email": "hello@basenotescent.com",
    "knowsAbout": [
      "fragrance",
      "subscription commerce",
      "direct-to-consumer brands",
      "luxury perfumery"
    ]
  }
}
</script>

<style>
  .about-page { color: #1a1a1a; }
  .about-hero { background: #f8f8f6; padding: 64px 20px 56px; }
  .about-hero__container {
    max-width: 1000px; margin: 0 auto; display: grid;
    grid-template-columns: 1fr 1.2fr; gap: 48px; align-items: center;
  }
  .about-hero__media { position: relative; }
  .about-hero__image { width: 100%; height: auto; border-radius: 6px; aspect-ratio: 4 / 5; object-fit: cover; }
  .about-hero__placeholder {
    aspect-ratio: 4 / 5; border-radius: 6px; background: #fff;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    color: #c4b48a; border: 1px dashed #d7c79d;
  }
  .about-hero__placeholder svg { width: 38%; max-width: 160px; }
  .about-hero__placeholder-caption { margin-top: 12px; font-size: 0.82rem; color: #a89770; letter-spacing: 0.5px; }
  .about-hero__eyebrow { display: block; font-size: 0.78rem; letter-spacing: 2px; color: #888; text-transform: uppercase; margin-bottom: 12px; }
  .about-hero__title { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 10px; }
  .about-hero__kicker { margin: 0; color: #555; font-size: 1.1rem; }

  .about-body { padding: 56px 20px 16px; }
  .about-body__container { max-width: 720px; margin: 0 auto; font-size: 1.08rem; line-height: 1.75; color: #2a2a2a; }
  .about-body__container p { margin: 0 0 1.2em; }
  .about-body__container h2 { font-size: 1.5rem; margin: 2em 0 0.6em; letter-spacing: -0.01em; }
  .about-body__container h3 { font-size: 1.2rem; margin: 1.6em 0 0.4em; }
  .about-body__container blockquote { border-left: 3px solid #c9a86c; padding-left: 20px; margin: 1.5em 0; color: #555; font-style: italic; }
  .about-body__container a { color: #1a1a1a; }

  .about-cta { padding: 40px 20px 80px; text-align: center; }
  .about-cta__container { max-width: 640px; margin: 0 auto; }
  .about-cta__title { font-size: clamp(1.6rem, 4vw, 2.2rem); margin: 0 0 12px; letter-spacing: -0.01em; }
  .about-cta__subtitle { color: #555; font-size: 1.05rem; margin: 0 0 24px; }
  .about-cta__button {
    display: inline-block; background: #1a1a1a; color: #fff; text-decoration: none;
    padding: 14px 28px; border-radius: 4px; font-weight: 600; font-size: 1rem;
  }
  .about-cta__button:hover { background: #2a2a2a; }
  .about-cta__secondary { margin: 24px 0 0; font-size: 0.9rem; color: #888; }
  .about-cta__secondary a { color: #1a1a1a; }

  @media (max-width: 760px) {
    .about-hero__container { grid-template-columns: 1fr; gap: 24px; text-align: center; }
    .about-hero__media { max-width: 320px; margin: 0 auto; }
  }
</style>

{% schema %}
{
  "name": "Main page (about)",
  "settings": []
}
{% endschema %}
