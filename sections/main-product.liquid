    border-radius: var(--radius-full);
  }

  .purchase-box__details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .purchase-detail {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .purchase-detail svg {
    width: 18px;
    height: 18px;
    color: var(--color-secondary);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .purchase-box {
      padding: var(--spacing-lg);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // ─── Product Variants Data ───
    const productVariants = [
      {%- for variant in product.variants -%}
        {
          id: {{ variant.id }},
          title: {{ variant.title | json }},
          price: {{ variant.price }},
          compareAtPrice: {{ variant.compare_at_price | default: 0 }},
          available: {{ variant.available }},
          options: {{ variant.options | json }},
          featuredImage: {{ variant.featured_image | json }}{%- if variant.featured_image -%},
          imageUrl: {{ variant.featured_image | image_url: width: 1000 | json }},
          imageSrcset: "{{ variant.featured_image | image_url: width: 500 }} 500w, {{ variant.featured_image | image_url: width: 750 }} 750w, {{ variant.featured_image | image_url: width: 1000 }} 1000w"
          {%- endif -%}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ];

    // ─── DOM References ───
    const subscriptionView = document.getElementById('subscriptionView');
    const purchaseView = document.getElementById('purchaseView');
    const variantIdInput = document.getElementById('variantId');
    const addToCartBtn = document.getElementById('addToCartButton');
    const addToCartText = document.getElementById('addToCartText');

    // PRD-01: If arrived via empty-slot from account page, re-label CTA to the target month
    (function labelCTAForQueueTarget() {
      var params = new URLSearchParams(window.location.search);
      var m = params.get('queue_target_month');
      if (!/^\d{4}-(0[1-9]|1[0-2])$/.test(m || '')) return;
      if (!addToCartText) return;
      var parts = m.split('-');
      var d = new Date(parseInt(parts[0], 10), parseInt(parts[1], 10) - 1, 1);
      var monthName = d.toLocaleString('en-US', { month: 'long' });
      addToCartText.textContent = 'Add to ' + monthName + ' Slot';
      // Persist for originalText recapture during async flows
      addToCartText.dataset.queueTargetLabel = 'Add to ' + monthName + ' Slot';
    })();
    const purchasePrice = document.getElementById('purchasePrice');
    const comparePrice = document.getElementById('comparePrice');
    const savingsBadge = document.getElementById('savingsBadge');
    const mainImage = document.getElementById('mainProductImage');
    const variantSelectors = document.querySelectorAll('.variant-select');
    const productForm = document.querySelector('[data-product-form]');
    const sellingPlanSelector = document.getElementById('sellingPlanSelector');
    const appstleWidget = document.getElementById('appstle_subscription_widget');

    // ─── Helpers ───
    function isSubscriptionVariant(variant) {
      if (!variant) return true;
      const title = variant.title.toLowerCase();
      return title.includes('5ml') || title.includes('5 ml') || title.includes('atomizer') || title.includes('subscription');
    }

    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2).replace(/\.00$/, '');
    }

    function findVariantFromOptions() {
      const selectedOptions = [];
      variantSelectors.forEach(function(select) {
        selectedOptions.push(select.value);
      });

      return productVariants.find(function(variant) {
        return variant.options.every(function(opt, index) {
          return opt === selectedOptions[index];
        });
      });
    }

    // ─── Variant Change Handler ───
    function onVariantChange() {
      const variant = findVariantFromOptions();
      if (!variant) return;

      // Update hidden variant ID
      variantIdInput.value = variant.id;

      // Update URL without reload
      const url = new URL(window.location);
      url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', url);

      // Determine variant type (single-variant only counts as subscription if it has selling plans)
      const hasSellPlans = document.getElementById('sellingPlanSelector') !== null || (appstleWidget && appstleWidget.innerHTML.trim() !== '');
      const isSub = (productVariants.length === 1 && hasSellPlans) || isSubscriptionVariant(variant);

      // Toggle views — subscription-only model, never show purchase view
      if (subscriptionView) subscriptionView.style.display = '';
      if (purchaseView) purchaseView.style.display = 'none';

      // Toggle selling plan visibility (only for subscription variants)
      if (sellingPlanSelector) sellingPlanSelector.style.display = isSub ? '' : 'none';
      if (appstleWidget) appstleWidget.style.display = isSub ? '' : 'none';

      // Update button text
      if (addToCartText && variant.available) {
        addToCartText.textContent = 'Start My Subscription — $20/month';
      }

      // Update purchase view pricing (for full-bottle variants)
      if (!isSub) {
        if (purchasePrice) purchasePrice.textContent = formatMoney(variant.price);

        if (variant.compareAtPrice > variant.price) {
          if (comparePrice) {
            comparePrice.textContent = formatMoney(variant.compareAtPrice);
            comparePrice.parentElement.style.display = '';
          }
          if (savingsBadge) {
            savingsBadge.textContent = 'Save ' + formatMoney(variant.compareAtPrice - variant.price);
            savingsBadge.style.display = '';
          }
        } else {
          if (comparePrice) comparePrice.parentElement.style.display = 'none';
          if (savingsBadge) savingsBadge.style.display = 'none';
        }
      }

      // Update availability
      if (addToCartBtn) {
        addToCartBtn.disabled = !variant.available;
        if (!variant.available && addToCartText) {
          addToCartText.textContent = 'Sold Out';
        }
      }

      // Update featured image if variant has one
      if (variant.featuredImage && mainImage) {
        mainImage.src = variant.imageUrl;
        if (variant.imageSrcset) mainImage.srcset = variant.imageSrcset;

        // Highlight matching thumbnail
        const thumbs = document.querySelectorAll('.product-gallery__thumb');
        thumbs.forEach(function(thumb) {
          thumb.classList.toggle('is-active', thumb.dataset.imageUrl === variant.imageUrl);
        });
      }

      // Update Appstle widget variant (if loaded)
      if (window.AppstleSubscription && typeof window.AppstleSubscription.updateVariant === 'function') {
        window.AppstleSubscription.updateVariant(variant.id);
      }
    }

    // ─── Bind Variant Selectors ───
    variantSelectors.forEach(function(select) {
      select.addEventListener('change', onVariantChange);
    });

    // ─── Gallery Thumbnails ───
    const thumbnails = document.querySelectorAll('.product-gallery__thumb');
    thumbnails.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbnails.forEach(function(t) { t.classList.remove('is-active'); });
        this.classList.add('is-active');
        if (mainImage) {
          mainImage.src = this.dataset.imageUrl;
          mainImage.srcset = this.dataset.imageSrcset;
        }
      });
    });

    // ─── Queue / Rotation System (PRD-01: month-indexed) ───
    const QUEUE_KEY = 'basenotes_queue';

    function getQueueTargetMonth() {
      var params = new URLSearchParams(window.location.search);
      var m = params.get('queue_target_month');
      // Validate format YYYY-MM
      return /^\d{4}-(0[1-9]|1[0-2])$/.test(m || '') ? m : null;
    }

    function getRotationQueue() {
      try { return JSON.parse(localStorage.getItem(QUEUE_KEY)) || []; }
      catch(e) { return []; }
    }

    function saveRotationQueue(queue) {
      localStorage.setItem(QUEUE_KEY, JSON.stringify(queue));
    }

    function pad2(n) { return n < 10 ? '0' + n : '' + n; }
    function monthStrFromOffset(offset) {
      var d = new Date(); d.setDate(1); d.setMonth(d.getMonth() + offset);
      return d.getFullYear() + '-' + pad2(d.getMonth() + 1);
    }

    function addToRotationQueue(productData) {
      var queue = getRotationQueue();
      var targetMonth = getQueueTargetMonth();

      if (targetMonth) {
        // Targeted insert: upsert at that month (replaces any existing slot at same month)
        var idx = queue.findIndex(function(e){ return e.shipMonth === targetMonth; });
        var entry = Object.assign({ shipMonth: targetMonth, locked: false }, productData);
        if (idx >= 0) queue[idx] = entry;
        else queue.push(entry);
      } else {
        // No target → assign next available future month slot (first 5 not already filled)
        if (queue.some(function(item) { return item.productId === productData.productId; })) return false;
        var filledMonths = {};
        queue.forEach(function(e){ if (e.shipMonth) filledMonths[e.shipMonth] = true; });
        var targetMonthFallback = null;
        for (var i = 0; i < 5; i++) {
          var m = monthStrFromOffset(i);
          if (!filledMonths[m]) { targetMonthFallback = m; break; }
        }
        queue.push(Object.assign({ shipMonth: targetMonthFallback, locked: false }, productData));
      }

      saveRotationQueue(queue);
      return true;
    }

    function showSwapModal(existingTitle, newTitle, onSwap, onAddToRotation) {
      // Remove existing modal if any
      var existing = document.getElementById('swapModal');
      if (existing) existing.remove();

      var modal = document.createElement('div');
      modal.id = 'swapModal';
      modal.style.cssText = 'position:fixed;inset:0;z-index:10000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(2px);';
      modal.innerHTML = '<div style="background:#fff;border-radius:12px;padding:2rem;max-width:420px;width:90%;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,0.2);">' +
        '<h3 style="margin:0 0 0.5rem;font-size:1.25rem;">You already have a fragrance selected</h3>' +
        '<p style="color:#666;font-size:0.9rem;margin:0 0 1.5rem;">Your queue for this month already includes <strong>' + existingTitle + '</strong>. What would you like to do?</p>' +
        '<div style="display:flex;flex-direction:column;gap:0.5rem;">' +
          '<button id="swapBtn" style="padding:0.75rem;background:#1a1a1a;color:#fff;border:none;border-radius:6px;font-size:0.9rem;font-weight:600;cursor:pointer;text-transform:uppercase;letter-spacing:0.05em;">Swap to ' + newTitle + '</button>' +
          '<button id="rotationBtn" style="padding:0.75rem;background:#c9a86c;color:#fff;border:none;border-radius:6px;font-size:0.9rem;font-weight:600;cursor:pointer;text-transform:uppercase;letter-spacing:0.05em;">Add ' + newTitle + ' to My Rotation</button>' +
          '<button id="cancelSwapBtn" style="padding:0.75rem;background:none;color:#666;border:1px solid #ddd;border-radius:6px;font-size:0.9rem;cursor:pointer;">Cancel</button>' +
        '</div>' +
      '</div>';

      document.body.appendChild(modal);

      document.getElementById('swapBtn').addEventListener('click', function() {
        modal.remove();
        onSwap();
      });
      document.getElementById('rotationBtn').addEventListener('click', function() {
        modal.remove();
        onAddToRotation();
      });
      document.getElementById('cancelSwapBtn').addEventListener('click', function() {
        modal.remove();
      });
      modal.addEventListener('click', function(e) {
        if (e.target === modal) modal.remove();
      });
    }

    // ─── Queue for Future Month (Apr 23 follow-up) ───
    var queueForFutureBtn = document.getElementById('queueForFutureBtn');
    if (queueForFutureBtn) {
      queueForFutureBtn.addEventListener('click', function() {
        openMonthPickerModal();
      });
    }

    function openMonthPickerModal() {
      var existing = document.getElementById('monthPickerModal');
      if (existing) existing.remove();

      function pad2(n){ return n < 10 ? '0'+n : ''+n; }
      var now = new Date();
      var months = [];
      for (var i = 0; i < 5; i++) {
        var d = new Date(now.getFullYear(), now.getMonth() + i, 1);
        var monthStr = d.getFullYear() + '-' + pad2(d.getMonth()+1);
        var label = d.toLocaleString('en-US', { month: 'long', year: 'numeric' });
        months.push({ str: monthStr, label: label, isCurrent: i === 0 });
      }

      // Get existing queue to show which slots are filled
      var existingQueue = [];
      try { existingQueue = JSON.parse(localStorage.getItem('basenotes_queue') || '[]'); } catch(e) {}
      var filledByMonth = {};
      existingQueue.forEach(function(entry){ if (entry.shipMonth) filledByMonth[entry.shipMonth] = entry; });

      var pTitle = {{ product.title | json }};

      var modal = document.createElement('div');
      modal.id = 'monthPickerModal';
      modal.style.cssText = 'position:fixed;inset:0;z-index:10000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.5);backdrop-filter:blur(3px);padding:1rem;';

      var monthListHtml = months.map(function(m) {
        var filled = filledByMonth[m.str];
        var sub = filled ? 'Currently: ' + (filled.title || '—') : (m.isCurrent ? 'Ships Immediately' : 'Empty slot');
        var cls = filled ? 'mpm-slot mpm-slot--filled' : 'mpm-slot';
        return '<button type="button" class="' + cls + '" data-month="' + m.str + '">' +
          '<div class="mpm-slot__month">' + m.label + '</div>' +
          '<div class="mpm-slot__sub">' + sub + '</div>' +
          '</button>';
      }).join('');

      modal.innerHTML =
        '<div class="mpm-box">' +
          '<button type="button" class="mpm-close" aria-label="Close">✕</button>' +
          '<h3 class="mpm-title">Queue ' + pTitle + '</h3>' +
          '<p class="mpm-desc">Pick a month to add this fragrance to your queue. You will not be charged now — this schedules the shipment.</p>' +
          '<div class="mpm-list">' + monthListHtml + '</div>' +
        '</div>' +
        '<style>' +
          '.mpm-box { background:#fff; border-radius:14px; padding:1.75rem; max-width:460px; width:100%; box-shadow:0 16px 48px rgba(0,0,0,0.25); max-height:90vh; overflow-y:auto; position:relative; }' +
          '.mpm-close { position:absolute; top:12px; right:12px; width:32px; height:32px; background:#F5F3EF; border:none; border-radius:50%; cursor:pointer; font-size:14px; color:#666; }' +
          '.mpm-close:hover { background:#EEE9DF; color:#2D4641; }' +
          '.mpm-title { margin:0 0 0.5rem; font-size:1.25rem; color:#2D4641; padding-right:2rem; }' +
          '.mpm-desc { margin:0 0 1.25rem; color:#666; font-size:0.875rem; line-height:1.45; }' +
          '.mpm-list { display:flex; flex-direction:column; gap:0.5rem; }' +
          '.mpm-slot { text-align:left; padding:0.85rem 1rem; background:#FAF8F5; border:1px solid #EEE9DF; border-radius:10px; cursor:pointer; transition:all 0.15s; font-family:inherit; }' +
          '.mpm-slot:hover { border-color:#C9A962; background:#fff; transform:translateX(2px); }' +
          '.mpm-slot--filled { background:#fff; border-color:#C9A962; }' +
          '.mpm-slot--filled::after { content:"Replace"; float:right; font-size:10px; color:#C9A962; text-transform:uppercase; letter-spacing:0.08em; font-weight:700; }' +
          '.mpm-slot__month { font-weight:700; color:#2D4641; font-size:0.95rem; }' +
          '.mpm-slot__sub { font-size:0.8125rem; color:#8a918e; margin-top:2px; }' +
        '</style>';

      document.body.appendChild(modal);

      modal.querySelectorAll('[data-month]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var monthStr = btn.getAttribute('data-month');
          var variantEl = document.getElementById('variantId');
          var productData = {
            productId: {{ product.id }},
            title: {{ product.title | json }},
            url: {{ product.url | json }},
            image: {{ product.featured_image | image_url: width: 200 | json }},
            family: {{ product.vendor | json }},
            variantId: variantEl ? parseInt(variantEl.value, 10) : 0,
            addedAt: new Date().toISOString()
          };
          var queue = [];
          try { queue = JSON.parse(localStorage.getItem('basenotes_queue') || '[]'); } catch(e) {}
          var idx = queue.findIndex(function(q){ return q.shipMonth === monthStr; });
          var entry = Object.assign({ shipMonth: monthStr, locked: false }, productData);
          if (idx >= 0) queue[idx] = entry;
          else queue.push(entry);
          localStorage.setItem('basenotes_queue', JSON.stringify(queue));
          window.location.href = '/account#next-shipment';
        });
      });

      modal.querySelector('.mpm-close').addEventListener('click', function(){ modal.remove(); });
      modal.addEventListener('click', function(e){ if (e.target === modal) modal.remove(); });
    }

    // ─── Add to Cart ───
    if (productForm && addToCartBtn) {
      productForm.addEventListener('submit', function(e) {
        e.preventDefault();

        const formData = new FormData(productForm);
        const variantId = formData.get('id');

        // PRD-01: Queue-target flow — skip cart entirely, write to queue localStorage, bounce back to account
        var queueTarget = getQueueTargetMonth();
        if (queueTarget) {
          var qTitle = {{ product.title | json }};
          var qId = {{ product.id }};
          var qUrl = {{ product.url | json }};
          var qImg = {{ product.featured_image | image_url: width: 200 | json }};
          var qFamily = {{ product.vendor | json }};
          addToRotationQueue({
            productId: qId, title: qTitle, url: qUrl, image: qImg, family: qFamily,
            variantId: parseInt(variantId), addedAt: new Date().toISOString()
          });
          if (addToCartText) addToCartText.textContent = 'Added!';
          addToCartBtn.classList.add('is-added');
          setTimeout(function(){ window.location.href = '/account#next-shipment'; }, 600);
          return;
        }

        // Auto-select first selling plan if none chosen (all purchases are subscriptions)
        var sellingPlan = formData.get('selling_plan');
        if (!sellingPlan) {
          var fallbackPlan = document.querySelector('input[name="selling_plan"]');
          if (fallbackPlan) sellingPlan = fallbackPlan.value;
        }
        {%- if product.selling_plan_groups.size > 0 -%}
        if (!sellingPlan) sellingPlan = '{{ product.selling_plan_groups[0].selling_plans[0].id }}';
        {%- endif -%}
        const isSubscription = !!sellingPlan;
        const productTitle = {{ product.title | json }};
        const productId = {{ product.id }};
        const productUrl = {{ product.url | json }};
        const productImage = {{ product.featured_image | image_url: width: 200 | json }};

        addToCartBtn.classList.add('is-loading');
        const originalText = addToCartText ? addToCartText.textContent : 'Start My Subscription — $20/month';

        // For subscription items, enforce single-item cart
        if (isSubscription) {
          fetch('/cart.js')
            .then(function(res) {
              if (!res.ok) throw new Error('Failed to fetch cart');
              return res.json();
            })
            .then(function(cart) {
              var existingSub = null;
              cart.items.forEach(function(item) {
                if (item.selling_plan_allocation) {
                  existingSub = item;
                }
              });

              if (existingSub) {
                // Already has subscription item — show swap modal
                addToCartBtn.classList.remove('is-loading');
                showSwapModal(
                  existingSub.product_title,
                  productTitle,
                  function onSwap() {
                    // Remove existing, then add new
                    addToCartBtn.classList.add('is-loading');
                    fetch('/cart/change.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ id: existingSub.key, quantity: 0 })
                    })
                    .then(function(res) {
                      if (!res.ok) throw new Error('Failed to remove existing subscription item');
                      return res.json();
                    })
                    .then(function() {
                      doAddToCart(variantId, sellingPlan, originalText);
                    })
                    .catch(function(err) {
                      console.error('Swap error:', err);
                      if (addToCartBtn) addToCartBtn.classList.remove('is-loading');
                      if (addToCartText) addToCartText.textContent = 'Swap Failed — Try Again';
                      setTimeout(function() {
                        if (addToCartText) addToCartText.textContent = originalText;
                      }, 3000);
                    });
                  },
                  function onAddToRotation() {
                    addToRotationQueue({
                      productId: productId,
                      title: productTitle,
                      url: productUrl,
                      image: productImage,
                      variantId: parseInt(variantId),
                      addedAt: new Date().toISOString()
                    });
                    if (addToCartText) addToCartText.textContent = 'Added to Rotation!';
                    addToCartBtn.classList.remove('is-loading');
                    addToCartBtn.classList.add('is-added');
                    addToCartBtn.style.background = '#c9a86c';
                    setTimeout(function() {
                      addToCartBtn.classList.remove('is-added');
                      if (addToCartText) addToCartText.textContent = originalText;
                      addToCartBtn.style.background = '';
                    }, 2500);
                  }
                );
              } else {
                // No existing subscription — add normally
                doAddToCart(variantId, sellingPlan, originalText);
              }
            });
          return;
        }

        // Fallback add-to-cart (selling plan should always be set by now)
        const cartPayload = { id: parseInt(variantId), quantity: 1 };
        if (sellingPlan) cartPayload.selling_plan = parseInt(sellingPlan);

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(cartPayload)
        })
        .then(function(response) {
          if (!response.ok) {
            return response.json().then(function(err) {
              throw new Error(err.description || err.message || 'Could not add item to cart');
            });
          }
          return response.json();
        })
        .then(function(data) {
          addToCartBtn.classList.remove('is-loading');
          addToCartBtn.classList.add('is-added');
          if (addToCartText) addToCartText.textContent = 'Added to Queue!';

          // Refresh cart drawer with new content and open it
          if (window.refreshAndOpenCartDrawer) {
            window.refreshAndOpenCartDrawer();
          }

          setTimeout(function() {
            addToCartBtn.classList.remove('is-added');
            if (addToCartText) addToCartText.textContent = originalText;
          }, 2000);
        })
        .catch(function(error) {
          console.error('Add to cart error:', error);
          addToCartBtn.classList.remove('is-loading');
          addToCartBtn.classList.remove('is-added');
          if (addToCartText) addToCartText.textContent = 'Error — Try Again';
          addToCartBtn.style.background = '#c0392b';
          setTimeout(function() {
            if (addToCartText) addToCartText.textContent = originalText;
            addToCartBtn.style.background = '';
          }, 3000);
        });
      });
    }

    // ─── doAddToCart helper (used by subscription swap flow) ───
    function doAddToCart(variantId, sellingPlan, originalText) {
      var payload = { id: parseInt(variantId), quantity: 1 };
      if (sellingPlan) payload.selling_plan = parseInt(sellingPlan);

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
      .then(function(response) {
        if (!response.ok) {
          return response.json().then(function(err) {
            throw new Error(err.description || err.message || 'Could not add item to cart');
          });
        }
        return response.json();
      })
      .then(function(data) {
        if (addToCartBtn) {
          addToCartBtn.classList.remove('is-loading');
          addToCartBtn.classList.add('is-added');
        }
        if (addToCartText) addToCartText.textContent = 'Added to Queue!';

        // Refresh cart drawer with new content and open it
        if (window.refreshAndOpenCartDrawer) {
          window.refreshAndOpenCartDrawer();
        }

        setTimeout(function() {
          if (addToCartBtn) addToCartBtn.classList.remove('is-added');
          if (addToCartText) addToCartText.textContent = originalText;
        }, 2000);
      })
      .catch(function(error) {
        console.error('Add to cart error:', error);
        if (addToCartBtn) addToCartBtn.classList.remove('is-loading');
        if (addToCartText) addToCartText.textContent = 'Error — Try Again';
        if (addToCartBtn) addToCartBtn.style.background = '#c0392b';
        setTimeout(function() {
          if (addToCartText) addToCartText.textContent = originalText;
          if (addToCartBtn) addToCartBtn.style.background = '';
        }, 3000);
      });
    }

    // ─── Copy Link ───
    document.querySelectorAll('[data-copy-link]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var url = this.dataset.copyLink;
        navigator.clipboard.writeText(url).then(function() {
          var orig = btn.innerHTML;
          btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(function() { btn.innerHTML = orig; }, 2000);
        });
      });
    });
  });
</script>

