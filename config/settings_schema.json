  {
    "name": "Email Marketing",
    "settings": [
      {
        "type": "header",
        "content": "Email Marketing Platform"
      },
      {
        "type": "paragraph",
        "content": "Connect your email marketing platform to capture leads and run campaigns. Customer data collected through forms will be sent to your selected platform."
      },
      {
        "type": "select",
        "id": "email_platform",
        "label": "Email platform",
        "options": [
          {
            "value": "shopify",
            "label": "Shopify Email (default)"
          },
          {
            "value": "klaviyo",
            "label": "Klaviyo"
          },
          {
            "value": "mailchimp",
            "label": "Mailchimp"
          },
          {
            "value": "omnisend",
            "label": "Omnisend"
          }
        ],
        "default": "shopify",
        "info": "Select your email marketing platform"
      },
      {
        "type": "header",
        "content": "Klaviyo Settings"
      },
      {
        "type": "text",
        "id": "klaviyo_public_api_key",
        "label": "Klaviyo Public API Key",
        "info": "Found in Klaviyo under Account > Settings > API Keys"
      },
      {
        "type": "text",
        "id": "klaviyo_list_id",
        "label": "Klaviyo List ID",
        "info": "The ID of the list to add subscribers to"
      },
      {
        "type": "header",
        "content": "Mailchimp Settings"
      },
      {
        "type": "text",
        "id": "mailchimp_form_action",
        "label": "Mailchimp Form Action URL",
        "info": "The action URL from your Mailchimp embedded form"
      },
      {
        "type": "header",
        "content": "Omnisend Settings"
      },
      {
        "type": "text",
        "id": "omnisend_brand_id",
        "label": "Omnisend Brand ID",
        "info": "Found in your Omnisend account settings"
      }
    ]
  },
  {
    "name": "Email Popup",
    "settings": [
      {
        "type": "header",
        "content": "Email Capture Popup"
      },
      {
        "type": "checkbox",
        "id": "popup_enabled",
        "label": "Enable email popup",
        "default": true,
        "info": "Shows a popup to capture email addresses from guest visitors"
      },
      {
        "type": "range",
        "id": "popup_delay",
        "label": "Popup delay (seconds)",
        "min": 0,
        "max": 60,
        "step": 1,
        "unit": "s",
        "default": 5,
        "info": "Time before popup appears"
      },
      {
        "type": "checkbox",
        "id": "popup_exit_intent",
        "label": "Show on exit intent",
        "default": true,
        "info": "Show popup when user moves mouse to leave the page (desktop only)"
      },
      {
        "type": "header",
        "content": "Popup Content"
      },
      {
        "type": "text",
        "id": "popup_eyebrow",
        "label": "Eyebrow text",
        "default": "Exclusive Offer"
      },
      {
        "type": "text",
        "id": "popup_heading",
        "label": "Heading",
        "default": "Get 15% Off Your First Month"
      },
      {
        "type": "textarea",
        "id": "popup_description",
        "label": "Description",
        "default": "Join our inner circle for exclusive offers, new arrivals, and fragrance tips. Plus, enjoy 15% off your first subscription!"
      },
      {
        "type": "text",
        "id": "popup_button_text",
        "label": "Button text",
        "default": "Unlock My 15% Off"
      },
      {
        "type": "text",
        "id": "popup_skip_text",
        "label": "Skip link text",
        "default": "No thanks, I'll pay full price"
      },
      {
        "type": "header",
        "content": "Success Message"
      },
      {
        "type": "text",
        "id": "popup_success_heading",
        "label": "Success heading",
        "default": "Welcome to Base Note!"
      },
      {
        "type": "text",
        "id": "popup_success_message",
        "label": "Success message",
        "default": "Check your email for your 15% off code."
      },
      {
        "type": "header",
        "content": "Tagging"
      },
      {
        "type": "text",
        "id": "popup_customer_tags",
        "label": "Customer tags",
        "default": "newsletter,popup,prospect",
        "info": "Comma-separated tags to apply to captured leads"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "header",
        "content": "Cart Behavior"
      },
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          {
            "value": "drawer",
